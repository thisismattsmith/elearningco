---
// src/components/layout/Layout.astro
import '../../styles/global.css';

interface Props {
  title: string;
  description: string;
  noindex?: boolean;
}

const { title, description, noindex = false } = Astro.props;

// Determine the active top-level section from the current URL so the
// matching nav link can be highlighted. Pages don't need to pass anything
// in — this works automatically based on the URL.
const pathname = Astro.url.pathname;
const activeSection: 'pricing' | 'about' | 'resources' | 'blog' | 'training' | null =
  pathname.startsWith('/pricing')   ? 'pricing'   :
  pathname.startsWith('/about')     ? 'about'     :
  pathname.startsWith('/resources') ? 'resources' :
  pathname.startsWith('/blog')      ? 'blog'      :
  pathname.startsWith('/training')  ? 'training'  :
  null;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />

    <!-- Sitemap -->
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Fonts: Archivo Black (display), Inter (workhorse), JetBrains Mono (meta) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <nav class="nav-container">
        <div class="nav-content">
          <a href="/" class="logo" aria-label="The eLearning Company — home">
            <span class="logo-mark" aria-hidden="true"></span>
            <span class="logo-text">The eLearning Co.</span>
          </a>

          <div class="nav-links">
            <a href="/pricing" class:list={[{ active: activeSection === 'pricing' }]}>Pricing</a>
            <a href="/about" class:list={[{ active: activeSection === 'about' }]}>How it works</a>
            <a href="/resources" class:list={[{ active: activeSection === 'resources' }]}>Resources</a>
            <a href="/blog" class:list={[{ active: activeSection === 'blog' }]}>Blog</a>
            <a href="/contact" class="nav-cta">Get a quote</a>
          </div>

          <button class="mobile-menu-toggle" aria-label="Toggle menu" aria-expanded="false">
            <span></span>
            <span></span>
            <span></span>
          </button>
        </div>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-container">
        <div class="footer-grid">
          <div class="footer-col">
            <div class="footer-brand">The eLearning Co.</div>
            <p class="footer-tagline">
              Effective eLearning, delivered. Based in Australia.
            </p>
          </div>

          <div class="footer-col">
            <h4>Services</h4>
            <ul>
              <li><a href="/pricing">Pricing</a></li>
              <li><a href="/about">How it works</a></li>
              <li><a href="/training">Training categories</a></li>
            </ul>
          </div>

          <div class="footer-col">
            <h4>Company</h4>
            <ul>
              <li><a href="/about">About us</a></li>
              <li><a href="/resources">Resources</a></li>
              <li><a href="/blog">Blog</a></li>
              <li><a href="/contact">Contact</a></li>
            </ul>
          </div>

          <div class="footer-col">
            <h4>Get started</h4>
            <p class="footer-cta-text">Ready to build your eLearning course?</p>
            <a href="/contact" class="footer-cta-btn">Get a quote</a>
          </div>
        </div>

        <div class="footer-locations">
          <p class="footer-locations-text">
            We can help you create eLearning in
            <a href="/locations/melbourne">Melbourne</a>,
            <a href="/locations/sydney">Sydney</a>,
            <a href="/locations/canberra">Canberra</a>,
            <a href="/locations/adelaide">Adelaide</a>,
            <a href="/locations/perth">Perth</a>,
            <a href="/locations/brisbane">Brisbane</a>, and
            <a href="/locations/hobart">Hobart</a>.
            We also work virtually and flexibly across all regions.
          </p>
        </div>

        <div class="footer-bottom">
          <p>&copy; {new Date().getFullYear()} The eLearning Company. All rights reserved.</p>
          <p class="meta">All prices in AUD + GST</p>
        </div>
      </div>
    </footer>

    <script>
      // Mobile menu toggle
      const mobileMenuToggle = document.querySelector('.mobile-menu-toggle');
      const navLinks = document.querySelector('.nav-links');

      mobileMenuToggle?.addEventListener('click', () => {
        const isActive = navLinks?.classList.toggle('active');
        mobileMenuToggle.classList.toggle('active');
        mobileMenuToggle.setAttribute('aria-expanded', String(!!isActive));
      });

      // Close mobile menu when clicking outside
      document.addEventListener('click', (e) => {
        const target = e.target as HTMLElement | null;
        if (target && !target.closest('.nav-content')) {
          navLinks?.classList.remove('active');
          mobileMenuToggle?.classList.remove('active');
          mobileMenuToggle?.setAttribute('aria-expanded', 'false');
        }
      });
    </script>

    <!-- 100% privacy-first analytics -->
    <script async src="https://scripts.simpleanalyticscdn.com/latest.js"></script>
  </body>
</html>
