---
// src/pages/training/[slug].astro
import Layout from '../../components/layout/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const categories = await getCollection('training-categories');
  return categories.map(category => ({
    params: { slug: category.slug },
    props: { category },
  }));
}

const { category } = Astro.props;
const { Content } = await category.render();

// Mockup content per category. Each entry gives the browser mockup
// realistic, category-specific content. Falls back to topic[0] if a
// category isn't explicitly mapped (the page still renders correctly).
type MockupQuestion = {
  number: number;
  question: string;
  prompt: string;
  options: string[];
};

type MockupCompletion = {
  heading: string;
  subheading: string;
  cta: string;
  // Element id within the page to scroll to when CTA is clicked
  ctaTarget: string;
};

type MockupSlide = {
  moduleLabel: string;
  timeLeft: string;
  progressPercent: number;
  totalQuestions: number;
  // Initial visible question (shown server-side)
  question: string;
  prompt: string;
  options: string[];
  startQuestionNumber: number;
  // Optional follow-up questions cycled by Continue clicks
  additionalQuestions?: MockupQuestion[];
  // Optional completion screen after the final question
  completion?: MockupCompletion;
};

