        ],
      },
    ],
    completion: {
      heading: 'Check in complete',
      subheading: "Let's move to part 3: First aid basics",
      cta: 'Our process',
      ctaTarget: 'our-process',
    },
  },

  'change-management': {
    moduleLabel: 'Check in',
    timeLeft: '2 min remaining',
    progressPercent: 85,
    totalQuestions: 5,
    startQuestionNumber: 3,
    question: 'Reading the room',
    prompt: "A significant change has been announced. Your team's reactions are mixed. What's a useful first move?",
    options: [
      "Make space for people to react before pushing for buy-in",
      'Listen for what people are actually worried about',
      "Be honest about what you do and don't know",
    ],
    additionalQuestions: [
      {
        number: 4,
        question: 'Keeping the work moving',
        prompt: "You're in the middle of a transition. What helps the team stay productive?",
        options: [
          'Be clear about what isn\'t changing',
          "Set short-term priorities so people aren't stuck",
          "Make the new ways of working visible early",
        ],
      },
      {
        number: 5,
        question: 'Making it stick',
        prompt: "A few weeks in, some people are reverting to old habits. What's worth doing?",
        options: [
          'Acknowledge the pull — old habits are easier',
          'Make the new way the easier option, wherever you can',
          "Reinforce what's working without punishing slips",
        ],
      },
    ],
    completion: {
      heading: 'Check in complete',
      subheading: "Let's move to part 3: Sustaining the change",
      cta: 'Our process',
      ctaTarget: 'our-process',
