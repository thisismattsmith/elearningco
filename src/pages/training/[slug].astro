    additionalQuestions: [
      {
        number: 4,
        question: 'When it doesn\'t work as expected',
        prompt: "The system isn't doing what you expected. What's worth trying before you escalate?",
        options: [
          'Refresh and try the exact same steps again',
          'Check whether something obvious is missing — a flag, a field, a permission',
          "Look up the issue in the team's troubleshooting notes",
        ],
      },
      {
        number: 5,
        question: 'Getting help',
        prompt: "You've tried what you can and you're still stuck. What's the right next step?",
        options: [
          "Post in the team channel with context — what you tried, what you saw",
          'Log a support ticket if it\'s a system issue',
          "Capture a screenshot or screen recording before the problem moves",
        ],
      },
    ],
    completion: {
      heading: 'Check in complete',
      subheading: "Let's move to part 3: Reporting and dashboards",
      cta: 'Our process',
      ctaTarget: 'our-process',
    },
  },

  'process-procedure': {
    moduleLabel: 'Check in',
    timeLeft: '2 min remaining',
    progressPercent: 85,
    totalQuestions: 5,
    startQuestionNumber: 3,
    question: 'Getting the steps right',
    prompt: "You're running through a standard process. Which of these reduce the chance of mistakes?",
    options: [
      'Follow the documented order — even when it feels slow',
      "Tick steps off as you complete them",
      "Check the latest version of the procedure before you start",
    ],
    additionalQuestions: [
      {
        number: 4,
        question: 'When you hit an exception',
        prompt: "The case in front of you doesn't fit the standard process. What helps?",
        options: [
          'Document what makes this one different',
          'Check whether there\'s a documented exception path',
          "Escalate before improvising",
        ],
      },
      {
        number: 5,
        question: 'When something looks wrong',
        prompt: "Halfway through, you realise an earlier step was skipped. What now?",
        options: [
          'Stop and assess before continuing',
          'Document what was missed and when',
          "Tell whoever needs to know so it can be addressed",
        ],
      },
    ],
    completion: {
      heading: 'Check in complete',
      subheading: "Let's move to part 3: Continuous improvement",
      cta: 'Our process',
      ctaTarget: 'our-process',
    },
  },

  'quality-management': {
    moduleLabel: 'Check in',
    timeLeft: '2 min remaining',
    progressPercent: 85,
    totalQuestions: 5,
    startQuestionNumber: 3,
    question: 'Spotting a defect',
    prompt: "Something has come through that isn't to standard. What's the right first response?",
    options: [
      'Stop it from moving further down the line',
      "Document what you found, where, and when",
      'Capture evidence before anything changes',
    ],
    additionalQuestions: [
      {
        number: 4,
        question: 'The documentation that matters',
        prompt: "Which of these are worth getting right for traceability?",
        options: [
          'The batch or lot reference',
          'Who handled it and at what step',
          "What was tested and what the result was",
        ],
      },
      {
        number: 5,
        question: 'Escalating an issue',
        prompt: "The issue might be more than a one-off. What helps your investigation start well?",
        options: [
          'Get the relevant records together early',
