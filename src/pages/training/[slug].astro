<script>
  // Mockup interactivity — toggle options, advance through additional
  // questions, show completion screen, then reset. All visual; nothing
  // is persisted.
  const browser = document.querySelector('.browser');
  if (browser) {
    const dataEl = browser.querySelector('.mockup-data');
    const data = dataEl ? JSON.parse(dataEl.textContent || '{}') : null;
    if (!data) {
      // Should not happen, but bail rather than throw
      console.warn('Mockup data missing');
    }

    const questionView = browser.querySelector<HTMLElement>('[data-view="question"]');
    const completionView = browser.querySelector<HTMLElement>('[data-view="completion"]');
    const questionEl = browser.querySelector<HTMLElement>('.course-q');
    const promptEl = browser.querySelector<HTMLElement>('.course-prompt');
    const optionsList = browser.querySelector<HTMLElement>('.course-options');
    const progressFill = browser.querySelector<HTMLElement>('.progress-fill');
    const progressText = browser.querySelector<HTMLElement>('.course-progress-text');

    // Snapshot the first server-rendered <li> as a template. We clone this
    // for subsequent questions instead of building HTML strings, which
    // preserves Astro's scoped-CSS data-* attributes. Strings via innerHTML
    // lose those attributes and lose all the styling with them.
    const optionTemplate = optionsList?.querySelector<HTMLLIElement>('li')?.cloneNode(true) as HTMLLIElement | undefined;

    // Index 0 = the initial question (already rendered), 1+ = additional
    // questions, length = trigger completion view
    let stepIndex = 0;
    let progress = data?.progressStart ?? 85;

    const renderQuestion = (q: { number: number; question: string; prompt: string; options: string[] }) => {
      if (questionEl) questionEl.textContent = q.question;
      if (promptEl) promptEl.textContent = q.prompt;
      if (optionsList && optionTemplate) {
        // Wipe existing options
        optionsList.replaceChildren();
        // Clone the template for each option and set its label/state
        q.options.slice(0, 3).forEach((opt: string) => {
          const li = optionTemplate.cloneNode(true) as HTMLLIElement;
          const btn = li.querySelector<HTMLButtonElement>('.course-option');
          const label = li.querySelector<HTMLElement>('.option-label');
          if (btn) btn.setAttribute('aria-pressed', 'false');
          if (label) label.textContent = opt;
          optionsList.appendChild(li);
        });
        attachOptionHandlers();
      }
      if (progressText) progressText.textContent = `Question ${q.number} of ${data.total}`;
    };

    const showCompletion = () => {
      if (questionView) questionView.hidden = true;
      if (completionView) completionView.hidden = false;
      if (progressFill) progressFill.style.width = '100%';
      if (progressText) progressText.textContent = 'Complete';
    };

    const resetToStart = () => {
      stepIndex = 0;
      progress = data.progressStart;
      if (questionView) questionView.hidden = false;
      if (completionView) completionView.hidden = true;
      if (progressFill) progressFill.style.width = `${progress}%`;
      renderQuestion(data.start);
    };

    const attachOptionHandlers = () => {
      const options = browser.querySelectorAll<HTMLButtonElement>('.course-option');
      options.forEach((opt) => {
        opt.addEventListener('click', () => {
          const pressed = opt.getAttribute('aria-pressed') === 'true';
          opt.setAttribute('aria-pressed', String(!pressed));
        });
      });
    };

    attachOptionHandlers();

    // Continue button on the question view
    const continueBtn = questionView?.querySelector<HTMLButtonElement>('.course-continue');
    continueBtn?.addEventListener('click', () => {
      stepIndex += 1;
      const hasMore = stepIndex <= (data.additional?.length || 0);
      if (!hasMore) {
        // No more questions — show completion or reset
        if (data.completion) {
          showCompletion();
        } else {
          resetToStart();
        }
        return;
      }
      // Advance progress by 5%, render next question
      progress = Math.min(95, progress + 5);
      if (progressFill) progressFill.style.width = `${progress}%`;
      const next = data.additional[stepIndex - 1];
      renderQuestion(next);
    });

    // CTA on completion view — scrolls the page to the matching section,
    // then quietly resets the demo so it's ready when the user scrolls back up.
    const completionBtn = completionView?.querySelector<HTMLButtonElement>('.course-continue');
    completionBtn?.addEventListener('click', () => {
      const targetId = completionBtn.getAttribute('data-scroll-target');
      if (targetId) {
        const targetEl = document.getElementById(targetId);
        if (targetEl) {
          targetEl.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      }
      // Reset after a short delay so the scroll has started before
      // the visible state changes (avoids flicker in the user's peripheral vision)
      setTimeout(resetToStart, 800);
    });
  }
</script>

