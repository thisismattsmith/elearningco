  },
};

// Build a sensible default if a category isn't explicitly mapped.
const fallbackMockup: MockupSlide = {
  moduleLabel: 'Check in',
  timeLeft: '2 min remaining',
  progressPercent: 85,
  totalQuestions: 5,
  startQuestionNumber: 3,
  question: category.data.topics?.[0] || `Introduction to ${category.data.title.toLowerCase()}`,
  prompt: 'Think about the last time this came up in your workplace. Which of these best describes what happened?',
  options: (category.data.topics || []).slice(1, 4).map(t => t),
};

const mockup = mockupBySlug[category.slug] || fallbackMockup;

// URL shown in the browser bar — full slug, matches the actual page path
const urlSlug = category.slug;
---

<Layout
  title={`${category.data.title} eLearning Development | The eLearning Company`}
  description={`Professional ${category.data.title.toLowerCase()} courses delivered in 3 weeks from $5,500 + GST. ${category.data.description}`}
>
  <!-- ============================================================
       1. Hero — lilac · asymmetric 2-col with browser mockup
       ============================================================ -->
  <section class="section section--lilac category-hero">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span class="breadcrumb-sep">/</span>
        <a href="/training">Training categories</a>
        <span class="breadcrumb-sep">/</span>
        <span class="breadcrumb-current">{category.data.title}</span>
      </nav>

      <div class="hero-grid">
        <div class="hero-copy">
          <span class="pill-meta hero-pill">{category.data.category}</span>

          <h1 class="display display-lg page-title">
            {category.data.title}<br />
            <span class="accent-blue">eLearning development.</span>
          </h1>
          <p class="lede page-subtitle">{category.data.description}</p>

          <div class="hero-cta">
            <a href={`/contact?category=${encodeURIComponent(category.data.title)}`} class="btn btn--primary">Get a quote</a>
            <a href="/pricing" class="btn btn--secondary">View pricing</a>
          </div>
        </div>

        <!-- ===== Course browser mockup ===== -->
        <div class="mockup-col">
          <div class="browser" role="region" aria-label={`Sample ${category.data.title} course module`}>
            <div class="browser-bar">
              <div class="browser-dots" aria-hidden="true">
                <span class="dot dot--red"></span>
                <span class="dot dot--yellow"></span>
                <span class="dot dot--green"></span>
              </div>
              <div class="browser-controls" aria-hidden="true">
                <svg class="browser-arrow browser-arrow--inactive" viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M10 4 6 8l4 4" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <svg class="browser-arrow browser-arrow--inactive" viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M6 4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <div class="browser-url">
                <svg class="url-lock" viewBox="0 0 12 14" width="10" height="12" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                  <rect x="2" y="6" width="8" height="6" rx="1"/>
                  <path d="M4 6V4a2 2 0 0 1 4 0v2" stroke-linecap="round"/>
                </svg>
                <span class="url-text">elc.training/{urlSlug}</span>
              </div>
              <div class="browser-controls-right" aria-hidden="true">
                <span class="control-dot"></span>
                <span class="control-dot"></span>
                <span class="control-dot"></span>
              </div>
            </div>

            <div class="browser-tab-strip" aria-hidden="true">
              <div class="browser-tab browser-tab--active">
                <span class="tab-favicon"></span>
                <span class="tab-title">{category.data.title} · Module</span>
                <span class="tab-close">×</span>
              </div>
              <div class="browser-tab browser-tab--inactive">
                <span class="tab-favicon tab-favicon--alt"></span>
                <span class="tab-title">Dashboard</span>
              </div>
              <span class="tab-add" aria-hidden="true">+</span>
            </div>

            <div class="course-screen">
              <div class="course-meta-row">
                <span class="course-module-label">{mockup.moduleLabel}</span>
                <span class="course-time-left">{mockup.timeLeft}</span>
              </div>

              <div class="progress-track" aria-hidden="true">
                <div class="progress-fill" style={`width: ${mockup.progressPercent}%`}></div>
              </div>

              <!-- Question view (default) -->
              <div class="course-question-view" data-view="question">
                <h3 class="course-q">{mockup.question}</h3>
                <p class="course-prompt">{mockup.prompt}</p>

                <ul class="course-options" role="list">
                  {mockup.options.slice(0, 3).map((opt) => (
                    <li>
                      <button type="button" class="course-option" aria-pressed="false">
                        <span class="option-box" aria-hidden="true">
                          <svg class="option-check" viewBox="0 0 12 12" width="9" height="9" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M2 6l3 3 5-6" stroke-linecap="round" stroke-linejoin="round"/>
                          </svg>
                        </span>
                        <span class="option-label">{opt}</span>
                      </button>
                    </li>
                  ))}
                </ul>

                <div class="course-footer">
                  <span class="course-progress-text">Question {mockup.startQuestionNumber} of {mockup.totalQuestions}</span>
                  <button class="course-continue" type="button">
                    Continue <span aria-hidden="true">→</span>
                  </button>
                </div>
              </div>

              <!-- Completion view (hidden by default; shown after final question) -->
              {mockup.completion && (
                <div class="course-completion-view" data-view="completion" hidden>
                  <div class="completion-icon" aria-hidden="true">
                    <svg viewBox="0 0 32 32" width="36" height="36" fill="none" stroke="currentColor" stroke-width="2.5">
                      <path d="M6 16l7 7L26 9" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </div>
                  <h3 class="completion-heading">{mockup.completion.heading}</h3>
                  <p class="completion-subheading">{mockup.completion.subheading}</p>
                  <button class="course-continue completion-cta" type="button" data-scroll-target={mockup.completion.ctaTarget}>
                    {mockup.completion.cta} <span aria-hidden="true">→</span>
                  </button>
                </div>
              )}

              <!-- Mockup data embedded for the runtime script -->
              <script type="application/json" class="mockup-data" set:html={JSON.stringify({
                start: {
                  number: mockup.startQuestionNumber,
                  question: mockup.question,
                  prompt: mockup.prompt,
                  options: mockup.options.slice(0, 3),
                },
                progressStart: mockup.progressPercent,
                total: mockup.totalQuestions,
                additional: mockup.additionalQuestions || [],
                completion: mockup.completion || null,
              })} />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       2. Intro — paper-deep · subtle separation from hero. Sells the
       category emotionally before structured info kicks in. Falls
       back to description if no `intro` is provided in frontmatter.
       ============================================================ -->
  <section class="section section--paper-deep intro-section">
    <div class="container">
      <p class="intro-lede">
        {category.data.intro || category.data.description}
      </p>
    </div>
  </section>

  <!-- ============================================================
       3. What you get — paper
       ============================================================ -->
  <section class="section section--paper what-you-get-section">
    <div class="container">
      <span class="section-kicker">What you get</span>
      <h2 class="display display-md section-title">Development without drama.</h2>

      <div class="features-grid">
        <div class="feature-item">
          <span class="meta feature-num">01</span>
          <h3 class="heading-sm">3-week delivery</h3>
          <p>From kickoff to final course.</p>
        </div>
        <div class="feature-item">
          <span class="meta feature-num">02</span>
          <h3 class="heading-sm">Fixed pricing</h3>
          <p>From $5,500 + GST. No hidden costs.</p>
        </div>
        <div class="feature-item">
          <span class="meta feature-num">03</span>
          <h3 class="heading-sm">Unlimited revisions</h3>
          <p>During weeks 2 and 3 of development.</p>
        </div>
        <div class="feature-item">
          <span class="meta feature-num">04</span>
          <h3 class="heading-sm">Modern design</h3>
          <p>Responsive, works on all devices.</p>
        </div>
        <div class="feature-item">
          <span class="meta feature-num">05</span>
          <h3 class="heading-sm">SCORM compliant</h3>
          <p>Works with any LMS platform.</p>
        </div>
        <div class="feature-item">
          <span class="meta feature-num">06</span>
          <h3 class="heading-sm">Source files</h3>
          <p>Full files provided for future updates.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       4. Process — turquoise · id="our-process" for mockup scroll
       ============================================================ -->
  <section class="section section--turquoise process-section" id="our-process">
    <div class="container">
      <span class="section-kicker">Our process</span>
      <h2 class="display display-md section-title">
        Three simple steps.<br />
        Three easy weeks.
      </h2>

      <div class="process-steps">
        <div class="process-step">
          <div class="step-badge">Week 1</div>
          <h3 class="heading-sm">We build</h3>
          <p>We start as soon as you send us your brief, branding and resources.</p>
        </div>
        <div class="process-step">
          <div class="step-badge">Week 2</div>
          <h3 class="heading-sm">You review</h3>
          <p>You receive the complete first draft for review. Provide feedback via our review link with your whole team.</p>
        </div>
        <div class="process-step">
          <div class="step-badge">Week 3</div>
          <h3 class="heading-sm">We deliver</h3>
          <p>We'll continue to implement your feedback and finalise the course. Then, at the end of the third week we'll deliver the SCORM package ready for your LMS.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       5. Pricing — paper · follows process
       ============================================================ -->
  <section class="section section--paper pricing-section">
    <div class="container">
      <span class="section-kicker">Pricing</span>
      <h2 class="display display-md section-title">
        Pricing for {category.data.title.toLowerCase()} training.
      </h2>
      <p class="lede section-subtitle">
        You don't need to blow your training budget to get high quality {category.data.title.toLowerCase()} eLearning.
      </p>

      <div class="pricing-tiers">
        <!-- Tier 1 -->
        <div class="tier-card">
          <div class="tier-badge">Tier 1</div>
          <h3 class="heading-md tier-name">Content ready</h3>
          <div class="tier-price">
            <span class="price-amount">$5,500</span>
            <span class="price-gst">+ GST</span>
          </div>
          <p class="tier-description">You have a complete script ready to build.</p>

          <div class="best-for-block best-for-block--lilac">
            <span class="meta best-for-label">Example</span>
            <p class="best-for-example">"{category.data.tier1Example}"</p>
          </div>

          <a href={`/contact?tier=1&category=${encodeURIComponent(category.data.title)}`} class="btn btn--secondary tier-cta">Choose tier 1</a>
        </div>

        <!-- Tier 2 -->
        <div class="tier-card">
          <div class="tier-badge">Tier 2</div>
          <h3 class="heading-md tier-name">Content needs shaping</h3>
          <div class="tier-price">
            <span class="price-amount">$7,500</span>
            <span class="price-gst">+ GST</span>
          </div>
          <p class="tier-description">You have content materials that need structuring.</p>

          <div class="best-for-block best-for-block--yellow">
            <span class="meta best-for-label">Example</span>
            <p class="best-for-example">"{category.data.tier2Example}"</p>
          </div>

          <a href={`/contact?tier=2&category=${encodeURIComponent(category.data.title)}`} class="btn btn--secondary tier-cta">Choose tier 2</a>
        </div>

        <!-- Tier 3 -->
        <div class="tier-card">
          <div class="tier-badge">Tier 3</div>
          <h3 class="heading-md tier-name">Start from scratch</h3>
          <div class="tier-price">
            <span class="price-amount">$10,500</span>
            <span class="price-gst">+ GST</span>
          </div>
          <p class="tier-description">We create everything from your expertise.</p>

          <div class="best-for-block best-for-block--turquoise">
            <span class="meta best-for-label">Example</span>
            <p class="best-for-example">"{category.data.tier3Example}"</p>
          </div>

          <a href={`/contact?tier=3&category=${encodeURIComponent(category.data.title)}`} class="btn btn--secondary tier-cta">Choose tier 3</a>
        </div>
      </div>

      <div class="pricing-note">
        <p>Not sure which tier? <a href={`/contact?category=${encodeURIComponent(category.data.title)}`} class="inline-link">Contact us</a> and we'll help you choose.</p>
      </div>
    </div>
  </section>

  <!-- ============================================================
       6. Topics — paper-deep · moved to follow pricing
       ============================================================ -->
  <section class="section section--paper-deep topics-section">
    <div class="container">
      <span class="section-kicker">Topics</span>
      <h2 class="display display-md section-title">
        Common {category.data.title.toLowerCase()} topics we cover.
      </h2>

      <ul class="topics-grid">
        {category.data.topics.map((topic) => (
          <li class="topic-item">
            <span class="topic-marker" aria-hidden="true">→</span>
            <span class="topic-text">{topic}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ============================================================
       7. Common mistakes — navy · only if data present
       Heading now category-specific. Capped at 6 items for an even
       3x2 or 2x3 grid.
       ============================================================ -->
  {category.data.commonMistakes && category.data.commonMistakes.length > 0 && (
    <section class="section section--navy mistakes-section">
      <div class="container">
        <span class="section-kicker">Common mistakes</span>
        <h2 class="display display-md section-title">
          Common mistakes with <span class="mark--lilac">{category.data.title.toLowerCase()}</span>.
        </h2>

        <div class="mistakes-grid">
          {category.data.commonMistakes.slice(0, 6).map((mistake, index) => (
            <div class="mistake-card">
              <span class="meta mistake-num">{String(index + 1).padStart(2, '0')}</span>
              <p class="mistake-text">{mistake}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ============================================================
       8. FAQ — paper · 4 items so the 2x2 grid renders cleanly.
       Heading + kicker now category-specific for SEO.
       ============================================================ -->
  <section class="section section--paper category-faq-section">
    <div class="container">
      <span class="section-kicker">Frequently asked questions</span>
      <h2 class="heading-xl section-title">
        FAQs about our {category.data.title.toLowerCase()} eLearning development.
      </h2>

      <div class="faq-list">
        <div class="faq-item content-card">
          <h3 class="heading-sm">Do you have experience with {category.data.title.toLowerCase()}?</h3>
          <p>Yes. We've developed {category.data.title.toLowerCase()} courses for organisations across multiple industries. Our 15+ years of eLearning experience means we understand both the learning design and the subject-specific requirements.</p>
        </div>

