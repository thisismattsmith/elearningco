    prompt: "Someone on your team is consistently missing the mark on a key part of their role. What sets up a useful first conversation?",
    options: [
      "Be specific about what's not landing, with examples",
      "Ask what they're seeing — there may be context you don't have",
      "Agree on what good looks like before talking about gaps",
    ],
    additionalQuestions: [
      {
        number: 4,
        question: 'A behaviour concern',
        prompt: "Their work is strong but their behaviour in meetings is shutting others down. How do you raise it?",
        options: [
          "Describe the behaviour, not the person",
          "Talk about the impact on others, not your interpretation",
          "Be specific — vague feedback is easy to dismiss",
        ],
      },
      {
        number: 5,
        question: 'A growth conversation',
        prompt: "You want to talk to a high performer about what's next. What makes the conversation useful?",
        options: [
          "Ask what they're interested in, before suggesting paths",
          "Be honest about what you can and can't offer",
          "Talk about specific next steps, not vague aspirations",
        ],
      },
    ],
    completion: {
      heading: 'Check in complete',
      subheading: "Let's move to part 3: Documenting the conversation",
      cta: 'Our process',
      ctaTarget: 'our-process',
    },
  },

  'product-training': {
