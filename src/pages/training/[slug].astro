---
// src/pages/training/[slug].astro
import Layout from '../../components/layout/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const categories = await getCollection('training-categories');
  return categories.map(category => ({
    params: { slug: category.slug },
    props: { category },
  }));
}

const { category } = Astro.props;
const { Content } = await category.render();
---

<Layout 
  title={`${category.data.title} eLearning Development | The eLearning Company`}
  description={`Professional ${category.data.title.toLowerCase()} courses delivered in 3 weeks from $5,500 + GST. ${category.data.description}`}
>
  <!-- Hero Section -->
  <section class="category-hero">
    <div class="container">
      <div class="breadcrumb">
        <a href="/">Home</a> / <a href="/training">Training Categories</a> / <span>{category.data.title}</span>
      </div>
      <h1 class="page-title">{category.data.title} eLearning Development</h1>
      <p class="page-subtitle">{category.data.description}</p>
      <div class="hero-cta">
        <a href="/contact?category={category.data.title}" class="btn-primary">Get a Quote</a>
        <a href="/pricing" class="btn-secondary">View Pricing</a>
      </div>
    </div>
  </section>

  <!-- What You Get Section -->
  <section class="what-you-get-section">
    <div class="container">
      <h2 class="section-title">What You Get</h2>
      <div class="features-grid">
        <div class="feature-card">
          <div class="feature-icon">⚡</div>
          <h3>3-Week Delivery</h3>
          <p>From kickoff to final course, guaranteed</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">💎</div>
          <h3>Fixed Pricing</h3>
          <p>From $5,500 + GST, no hidden costs</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">🔄</div>
          <h3>Unlimited Revisions</h3>
          <p>During weeks 2-3 of development</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">📱</div>
          <h3>Modern Design</h3>
          <p>Responsive, works on all devices</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">📦</div>
          <h3>SCORM Compliant</h3>
          <p>Works with any LMS platform</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">✅</div>
          <h3>Source Files</h3>
          <p>Full files provided for future updates</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Process Section -->
  <section class="process-section">
    <div class="container">
      <h2 class="section-title">Our Simple 3-Week Process</h2>
      <div class="process-steps">
        <div class="process-step">
          <div class="step-number">Week 1</div>
          <h3>Content Kickoff & Development</h3>
          <p>You send us your brief, branding and resources. We start building immediately.</p>
        </div>
        <div class="process-arrow">→</div>
        <div class="process-step">
          <div class="step-number">Week 2</div>
          <h3>First Draft Review</h3>
          <p>You receive the complete first draft for review. Provide feedback via our review link with your whole team.</p>
        </div>
        <div class="process-arrow">→</div>
        <div class="process-step">
          <div class="step-number">Week 3</div>
          <h3>Revisions & Delivery</h3>
          <p>We implement your feedback, finalise the course, and deliver the SCORM package ready for your LMS.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Topics Section -->
  <section class="topics-section">
    <div class="container">
      <h2 class="section-title">Common {category.data.title} Topics We Cover</h2>
      <div class="topics-grid">
        {category.data.topics.map((topic) => (
          <div class="topic-item">
            <span class="topic-icon">✓</span>
            <span>{topic}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Pricing Tiers Section -->
  <section class="pricing-section">
    <div class="container">
      <h2 class="section-title">Pricing for {category.data.title} Training</h2>
      <p class="section-subtitle">Choose the tier that matches your content readiness</p>
      
      <div class="pricing-tiers">
        <!-- Tier 1 -->
        <div class="tier-card">
          <h3>Tier 1: Build & Develop</h3>
          <div class="tier-price">$5,500 <span>+ GST</span></div>
          <p class="tier-description">You have a complete script ready to build</p>
          <div class="tier-example">
            <strong>Example:</strong>
            <p>{category.data.tier1Example}</p>
          </div>
          <a href="/contact?tier=1&category={category.data.title}" class="tier-btn">Choose Tier 1</a>
        </div>

        <!-- Tier 2 -->
        <div class="tier-card featured">
          <div class="popular-badge">Most Popular</div>
          <h3>Tier 2: Structure & Develop</h3>
          <div class="tier-price">$7,500 <span>+ GST</span></div>
          <p class="tier-description">You have content materials that need structuring</p>
          <div class="tier-example">
            <strong>Example:</strong>
            <p>{category.data.tier2Example}</p>
          </div>
          <a href="/contact?tier=2&category={category.data.title}" class="tier-btn">Choose Tier 2</a>
        </div>

        <!-- Tier 3 -->
        <div class="tier-card">
          <h3>Tier 3: Design & Develop</h3>
          <div class="tier-price">$10,500 <span>+ GST</span></div>
          <p class="tier-description">We create everything from your expertise</p>
          <div class="tier-example">
            <strong>Example:</strong>
            <p>{category.data.tier3Example}</p>
          </div>
          <a href="/contact?tier=3&category={category.data.title}" class="tier-btn">Choose Tier 3</a>
        </div>
      </div>

      <div class="pricing-note">
        <p>Not sure which tier? <a href="/contact?category={category.data.title}">Contact us</a> and we'll help you choose.</p>
      </div>
    </div>
  </section>

  <!-- Why Custom Training Matters -->
  <section class="why-custom-section">
    <div class="container">
      <h2 class="section-title">Why Custom {category.data.title} Training Matters</h2>
      <div class="content-wrapper">
        <Content />
      </div>
    </div>
  </section>

  <!-- Common Mistakes (if provided) -->
  {category.data.commonMistakes && category.data.commonMistakes.length > 0 && (
    <section class="mistakes-section">
      <div class="container">
        <h2 class="section-title">Common Mistakes to Avoid</h2>
        <div class="mistakes-grid">
          {category.data.commonMistakes.map((mistake) => (
            <div class="mistake-card">
              <span class="mistake-icon">⚠️</span>
              <p>{mistake}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- FAQ Section -->
  <section class="category-faq-section">
    <div class="container">
      <h2 class="section-title">Frequently Asked Questions</h2>
      <div class="faq-list">
        <div class="faq-item">
          <h3>How long does a {category.data.title.toLowerCase()} course take to develop?</h3>
          <p>We deliver all courses in 3 weeks from kickoff. Week 1 is development, weeks 2-3 are for your review and unlimited revisions.</p>
        </div>

        <div class="faq-item">
          <h3>Can you customize the content for our organisation?</h3>
          <p>Absolutely! All our courses are custom-built for your specific needs, policies, and procedures. We incorporate your branding, terminology, and examples.</p>
        </div>

        <div class="faq-item">
          <h3>What if we need to make changes after delivery?</h3>
          <p>We provide unlimited revisions during the 2-week review period. After delivery, we can make updates for an additional fee, or you can use the source files we provide.</p>
        </div>

        <div class="faq-item">
          <h3>Do you have experience with {category.data.title.toLowerCase()}?</h3>
          <p>Yes! We've developed {category.data.title.toLowerCase()} courses for organisations across multiple industries. Our 15+ years of eLearning experience means we understand both the learning design and compliance requirements.</p>
        </div>

        <div class="faq-item">
          <h3>What format will the course be delivered in?</h3>
          <p>We deliver SCORM 1.2 and 2004 packages that work with any LMS. We also provide the source files (Articulate Rise or Storyline) so you can make future updates if needed.</p>
        </div>

        <div class="faq-item">
          <h3>Can you handle urgent timelines?</h3>
          <p>Our standard timeline is 3 weeks, but we can accommodate rush projects for an additional fee. Contact us to discuss your specific deadline.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="final-cta-section">
    <div class="container">
      <div class="cta-card">
        <h2>Ready to Develop Your {category.data.title} Course?</h2>
        <p>Get a fixed-price quote within 24 hours. No obligation, completely transparent pricing.</p>
        <div class="cta-buttons">
          <a href="/contact?category={category.data.title}" class="btn-primary">Get a Quote</a>
          <a href="/pricing" class="btn-secondary">View Full Pricing</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Hero */
  .category-hero {
    padding: 80px 0 60px;
    background: var(--bg-primary);
  }

  .breadcrumb {
    font-size: 0.9rem;
    color: var(--text-secondary);
    margin-bottom: 24px;
  }

  .breadcrumb a {
    color: var(--accent-primary);
    text-decoration: none;
  }

  .breadcrumb a:hover {
    text-decoration: underline;
  }

  .breadcrumb span {
    color: var(--text-primary);
  }

  .page-title {
    font-size: 3rem;
    font-weight: 800;
    margin-bottom: 20px;
    letter-spacing: -0.02em;
  }

  .page-subtitle {
    font-size: 1.25rem;
    color: var(--text-secondary);
    margin-bottom: 32px;
    max-width: 800px;
  }

  .hero-cta {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .btn-primary,
  .btn-secondary {
    display: inline-block;
    padding: 14px 32px;
    border-radius: 10px;
    text-decoration: none;
    font-weight: 700;
    transition: all 0.3s ease;
  }

  .btn-primary {
    background: var(--accent-gradient);
    color: white;
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 24px rgba(99, 102, 241, 0.5);
  }

  .btn-secondary {
    background: var(--bg-tertiary);
    color: var(--text-primary);
    border: 2px solid var(--border-color);
  }

  .btn-secondary:hover {
    border-color: var(--accent-primary);
  }

  /* What You Get */
  .what-you-get-section {
    padding: 80px 0;
    background: var(--bg-secondary);
  }

  .section-title {
    font-size: 2.5rem;
    font-weight: 800;
    text-align: center;
    margin-bottom: 60px;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 32px;
  }

  .feature-card {
    text-align: center;
    padding: 24px;
  }

  .feature-icon {
    font-size: 2.5rem;
    margin-bottom: 16px;
  }

  .feature-card h3 {
    font-size: 1.25rem;
    margin-bottom: 8px;
    font-weight: 700;
  }

  .feature-card p {
    color: var(--text-secondary);
  }

  /* Process */
  .process-section {
    padding: 80px 0;
    background: var(--bg-primary);
  }

  .process-steps {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    max-width: 1000px;
    margin: 0 auto;
  }

  .process-step {
    flex: 1;
    text-align: center;
  }

  .step-number {
    background: var(--accent-gradient);
    color: white;
    padding: 8px 20px;
    border-radius: 20px;
    display: inline-block;
    font-weight: 700;
    margin-bottom: 16px;
  }

  .process-step h3 {
    font-size: 1.25rem;
    margin-bottom: 12px;
    font-weight: 700;
  }

  .process-step p {
    color: var(--text-secondary);
    line-height: 1.6;
  }

  .process-arrow {
    color: var(--accent-primary);
    font-size: 2rem;
    font-weight: 700;
  }

  /* Topics */
  .topics-section {
    padding: 80px 0;
    background: var(--bg-secondary);
  }

  .topics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 16px;
  }

  .topic-item {
    background: var(--bg-tertiary);
    padding: 16px 20px;
    border-radius: 8px;
    border: 1px solid var(--border-color);
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .topic-icon {
    color: var(--accent-primary);
    font-weight: 700;
  }

  /* Pricing */
  .pricing-section {
    padding: 80px 0;
    background: var(--bg-primary);
  }

  .section-subtitle {
    text-align: center;
    color: var(--text-secondary);
    font-size: 1.125rem;
    margin-bottom: 48px;
  }

  .pricing-tiers {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 32px;
    margin-bottom: 32px;
  }

  .tier-card {
    background: var(--bg-tertiary);
    border: 2px solid var(--border-color);
    border-radius: 20px;
    padding: 40px;
    position: relative;
    transition: all 0.3s ease;
  }

  .tier-card:hover {
    transform: translateY(-4px);
    border-color: var(--accent-primary);
  }

  .tier-card.featured {
    border-color: var(--accent-primary);
    box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.1);
  }

  .popular-badge {
    background: var(--accent-gradient);
    color: white;
    padding: 6px 16px;
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: 700;
    display: inline-block;
    margin-bottom: 16px;
  }

  .tier-card h3 {
    font-size: 1.5rem;
    margin-bottom: 16px;
    font-weight: 700;
  }

  .tier-price {
    font-size: 2.5rem;
    font-weight: 800;
    background: var(--accent-gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 12px;
  }

  .tier-price span {
    font-size: 1rem;
    color: var(--text-secondary);
  }

  .tier-description {
    color: var(--text-secondary);
    margin-bottom: 24px;
    padding-bottom: 24px;
    border-bottom: 1px solid var(--border-color);
  }

  .tier-example {
    margin-bottom: 24px;
  }

  .tier-example strong {
    display: block;
    margin-bottom: 8px;
    font-size: 0.9rem;
    color: var(--accent-primary);
  }

  .tier-example p {
    color: var(--text-secondary);
    font-size: 0.95rem;
    line-height: 1.6;
    font-style: italic;
  }

  .tier-btn {
    display: block;
    background: var(--accent-gradient);
    color: white;
    text-align: center;
    padding: 14px;
    border-radius: 10px;
    text-decoration: none;
    font-weight: 700;
    transition: all 0.3s ease;
  }

  .tier-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 24px rgba(99, 102, 241, 0.5);
  }

  .pricing-note {
    text-align: center;
    padding: 32px;
    background: var(--bg-tertiary);
    border-radius: 12px;
    border: 2px dashed var(--border-color);
  }

  .pricing-note a {
    color: var(--accent-primary);
    text-decoration: none;
    font-weight: 600;
  }

  .pricing-note a:hover {
    text-decoration: underline;
  }

  /* Why Custom */
  .why-custom-section {
    padding: 80px 0;
    background: var(--bg-secondary);
  }

  .content-wrapper {
    max-width: 800px;
    margin: 0 auto;
    color: var(--text-secondary);
    line-height: 1.8;
    font-size: 1.125rem;
  }

  .content-wrapper :global(h2) {
    color: var(--text-primary);
    margin-top: 32px;
    margin-bottom: 16px;
  }

  .content-wrapper :global(p) {
    margin-bottom: 20px;
  }

  /* Mistakes */
  .mistakes-section {
    padding: 80px 0;
    background: var(--bg-primary);
  }

  .mistakes-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 24px;
  }

  .mistake-card {
    background: var(--bg-tertiary);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 24px;
    display: flex;
    gap: 16px;
  }

  .mistake-icon {
    font-size: 1.5rem;
    flex-shrink: 0;
  }

  .mistake-card p {
    color: var(--text-secondary);
    line-height: 1.6;
  }

  /* FAQ */
  .category-faq-section {
    padding: 80px 0;
    background: var(--bg-secondary);
  }

  .faq-list {
    max-width: 900px;
    margin: 0 auto;
  }

  .faq-item {
    background: var(--bg-tertiary);
    padding: 32px;
    border-radius: 12px;
    margin-bottom: 24px;
    border: 1px solid var(--border-color);
  }

  .faq-item h3 {
    font-size: 1.25rem;
    margin-bottom: 12px;
    font-weight: 700;
  }

  .faq-item p {
    color: var(--text-secondary);
    line-height: 1.7;
  }

  /* Final CTA */
  .final-cta-section {
    padding: 80px 0;
    background: var(--bg-primary);
  }

  .cta-card {
    background: linear-gradient(135deg, rgba(99, 102, 241, 0.15) 0%, rgba(139, 92, 246, 0.15) 100%);
    border: 2px solid var(--accent-primary);
    border-radius: 20px;
    padding: 60px 40px;
    text-align: center;
  }

  .cta-card h2 {
    font-size: 2.5rem;
    margin-bottom: 16px;
    font-weight: 800;
  }

  .cta-card p {
    font-size: 1.25rem;
    color: var(--text-secondary);
    margin-bottom: 32px;
  }

  .cta-buttons {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .process-steps {
      flex-direction: column;
    }

    .process-arrow {
      transform: rotate(90deg);
    }
  }

  @media (max-width: 768px) {
    .page-title {
      font-size: 2rem;
    }

    .pricing-tiers {
      grid-template-columns: 1fr;
    }

    .hero-cta,
    .cta-buttons {
      flex-direction: column;
    }

    .btn-primary,
    .btn-secondary {
      width: 100%;
      text-align: center;
    }
  }
</style>