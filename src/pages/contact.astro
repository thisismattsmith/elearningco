---
// src/pages/contact.astro
import Layout from '../components/layout/Layout.astro';

// NOTE on architecture: this site builds statically (no SSR adapter), which
// means Astro.request.url cannot read per-visitor query params at build time.
// Tier locking and description prefill therefore happen client-side via the
// inline script at the bottom of this file. The tierCopy data is embedded
// as a JSON script tag so the client-side JS can read it without duplication.

// Tier copy — single source of truth. Rendered into a JSON <script> tag
// so the client-side handler can read it. Centralised so the hero, the
// confirmation card, and the meta title all stay in sync.
const tierCopy = {
  tier1: {
    label: 'Tier 1 — Content ready',
    price: '$5,500 + GST',
    description: 'You provide a complete script. We build and design.',
    heroLine1: "Tier 1 it is.",
    heroLine2: "Let's get the details.",
    subtitle: "You have the script ready. We just need a few details to send back a fixed-price quote within 24 hours.",
  },
  tier2: {
    label: 'Tier 2 — Content needs shaping',
    price: '$7,500 + GST',
    description: 'You provide content materials. We structure and build.',
    heroLine1: "Tier 2 it is.",
    heroLine2: "Let's get the details.",
    subtitle: "You have content materials we can work from. Tell us a bit about the project and we'll come back with a fixed-price quote within 24 hours.",
  },
  tier3: {
    label: 'Tier 3 — Start from scratch',
    price: '$10,500 + GST',
    description: 'We write, design, and build everything.',
    heroLine1: "Tier 3 it is.",
    heroLine2: "Let's get the details.",
    subtitle: "We'll write, design, and build the whole course. Share what you've got — even just the topic — and we'll come back with a fixed-price quote within 24 hours.",
  },
  custom: {
    label: 'Custom quote',
    price: 'POA',
    description: 'Specialised tools or complex builds.',
    heroLine1: "Custom quote.",
    heroLine2: "Tell us what you need.",
    subtitle: "For specialised tools, complex builds, or anything that doesn't fit the standard tiers. The more you can share, the sharper the quote.",
  },
};
---

<Layout
  title="Get a Quote | The eLearning Company"
  description="Request a fixed-price quote for your custom eLearning project. We respond within 24 hours with transparent pricing and clear timelines."
>
  <!-- ============================================================
       1. Hero — lilac · welcoming, the conversion page
       Both generic and tier-locked variants render in the HTML.
       Client-side JS shows the right one based on ?tier= in URL.
       ============================================================ -->
  <section class="section section--lilac contact-hero">
    <div class="container">
      <!-- Generic hero (default visible state) -->
      <div data-hero-generic>
        <span class="pill-meta hero-pill">Get a quote</span>
        <h1 class="display display-xl hero-title">
          Let's build<br />
          <span class="accent-blue">something good.</span>
        </h1>
        <p class="lede hero-subtitle">
          Tell us about your training needs and we'll get back to you within 24 hours with a fixed-price quote.
        </p>
      </div>

      <!-- Tier-specific hero (hidden by default; JS shows when ?tier= matches) -->
      <div data-hero-tier hidden>
        <span class="pill-meta hero-pill" data-tier-label>Get a quote</span>
        <h1 class="display display-xl hero-title">
          <span data-tier-hero-line-1></span><br />
          <span class="accent-blue" data-tier-hero-line-2></span>
        </h1>
        <p class="lede hero-subtitle" data-tier-subtitle></p>
      </div>
    </div>
  </section>

  <!-- ============================================================
       2. Form — paper · form left, info right
       ============================================================ -->
  <section class="section section--paper contact-form-section">
    <div class="container">
      <div class="form-wrapper">

        <!-- Form column -->
        <div class="form-column">
          <form
            name="contact"
            method="POST"
            data-netlify="true"
            netlify-honeypot="bot-field"
            action="/thank-you"
            class="contact-form"
          >
            <input type="hidden" name="form-name" value="contact" />

            <p class="hidden-honeypot">
              <label>
                Don't fill this out if you're human:
                <input name="bot-field" />
              </label>
            </p>

            <div class="form-section-block">
              <span class="meta form-section-label">About you</span>

              <div class="form-group">
                <label for="name">Your name <span class="required" aria-hidden="true">*</span></label>
                <input type="text" id="name" name="name" required placeholder="John Smith" />
              </div>

              <div class="form-row">
                <div class="form-group">
                  <label for="email">Email <span class="required" aria-hidden="true">*</span></label>
                  <input type="email" id="email" name="email" required placeholder="john@company.com.au" />
                </div>

                <div class="form-group">
                  <label for="phone">Phone <span class="optional">(optional)</span></label>
                  <input type="tel" id="phone" name="phone" placeholder="+61 4XX XXX XXX" />
                </div>
              </div>

              <div class="form-group">
                <label for="company">Company name <span class="required" aria-hidden="true">*</span></label>
                <input type="text" id="company" name="company" required placeholder="Your Company Pty Ltd" />
              </div>
            </div>

            <div class="form-section-block">
              <span class="meta form-section-label">About the project</span>

              <!-- Tier picker (default visible state) -->
              <div class="form-group" data-tier-picker>
                <label for="tier">Which pricing tier suits your needs? <span class="required" aria-hidden="true">*</span></label>
                <select id="tier" name="tier" required>
                  <option value="">Select a tier</option>
                  <option value="tier1">Tier 1 — Content ready ($5,500 + GST)</option>
                  <option value="tier2">Tier 2 — Content needs shaping ($7,500 + GST)</option>
                  <option value="tier3">Tier 3 — Start from scratch ($10,500 + GST)</option>
                  <option value="custom">Custom quote — something more complex</option>
                  <option value="unsure">Not sure — help me choose</option>
                </select>
              </div>

              <!-- Tier-locked confirmation card (hidden by default; JS shows when ?tier= matches) -->
              <div class="form-group tier-locked" data-tier-locked hidden>
                <span class="meta tier-locked-label">Your selected tier</span>
                <div class="tier-locked-card">
                  <div class="tier-locked-body">
                    <div class="tier-locked-name" data-tier-locked-name></div>
                    <div class="tier-locked-desc" data-tier-locked-desc></div>
                  </div>
                  <div class="tier-locked-price" data-tier-locked-price></div>
                </div>
                <!-- Hidden input — set by JS so the form posts the locked tier -->
                <input type="hidden" name="tier" data-tier-locked-input value="" />
                <a href="/pricing" class="tier-locked-change">Wrong tier? See all options →</a>
              </div>

              <div class="form-group">
                <label for="timeline">When do you need it? <span class="optional">(optional)</span></label>
                <select id="timeline" name="timeline">
                  <option value="">Select timeline</option>
                  <option value="ASAP">ASAP (within 4 weeks)</option>
                  <option value="1-2 months">1-2 months</option>
                  <option value="3-6 months">3-6 months</option>
                  <option value="6+ months">6+ months</option>
                  <option value="exploring">Just exploring options</option>
                </select>
              </div>

              <div class="form-group">
                <label for="description">Tell us about your project <span class="required" aria-hidden="true">*</span></label>
                <textarea
                  id="description"
                  name="description"
                  rows="6"
                  required
                  placeholder="What training do you need? Who is the audience? Do you have existing content? Any specific requirements?"
                ></textarea>
              </div>
            </div>

            <div class="form-section-block">
              <span class="meta form-section-label">Optional</span>

              <div class="form-group">
                <label for="source">How did you hear about us?</label>
                <select id="source" name="source">
                  <option value="">Select source</option>
                  <option value="Google Search">Google search</option>
                  <option value="LinkedIn">LinkedIn</option>
                  <option value="Referral">Referral from colleague or friend</option>
                  <option value="Social Media">Social media</option>
                  <option value="Blog/Article">Blog or article</option>
                  <option value="Directory">Business directory</option>
                  <option value="Other">Other</option>
                </select>
              </div>
            </div>

            <button type="submit" class="btn btn--primary submit-btn">
              Get your quote
            </button>

            <p class="form-note">
              <span class="required" aria-hidden="true">*</span> Required fields. We'll respond within 24 hours with a fixed-price quote.
            </p>
          </form>
        </div>

        <!-- Info column -->
        <aside class="info-column">
          <div class="info-card">
            <span class="meta info-card-label">What happens next</span>
            <div class="next-steps">
              <div class="step">
                <span class="step-num">01</span>
                <div class="step-body">
                  <h4 class="heading-sm">We review your request</h4>
                  <p>Within 24 hours (usually much faster).</p>
                </div>
              </div>
              <div class="step">
                <span class="step-num">02</span>
                <div class="step-body">
                  <h4 class="heading-sm">Quick discovery call</h4>
                  <p>15-20 minute call to clarify your needs.</p>
                </div>
              </div>
              <div class="step">
                <span class="step-num">03</span>
                <div class="step-body">
                  <h4 class="heading-sm">Fixed-price quote</h4>
                  <p>Clear pricing, timeline, and deliverables.</p>
                </div>
              </div>
              <div class="step">
                <span class="step-num">04</span>
                <div class="step-body">
                  <h4 class="heading-sm">Start your project</h4>
                  <p>If you accept, we begin immediately.</p>
                </div>
              </div>
            </div>
          </div>

          <div class="info-card info-card--accent">
            <span class="meta info-card-label">Our guarantee</span>
            <ul class="guarantee-list">
              <li>Fixed pricing, no hidden costs</li>
              <li>3-week delivery timeline</li>
              <li>Unlimited revisions during development</li>
              <li>No-obligation quote</li>
              <li>Transparent process, start to finish</li>
            </ul>
          </div>

          <div class="info-card">
            <span class="meta info-card-label">Prefer email?</span>
            <p class="info-card-text">We're happy to discuss your project by email.</p>
            <dl class="contact-details">
              <dt>Email</dt>
              <dd><a href="mailto:contact@elearningcompany.net" class="contact-link">contact@elearningcompany.net</a></dd>
              <dt>Location</dt>
              <dd>Victoria, Australia</dd>
              <dt>Hours</dt>
              <dd>All Australian time zones</dd>
            </dl>
          </div>

          <div class="info-card">
            <span class="meta info-card-label">Not ready yet?</span>
            <ul class="resource-links">
              <li><a href="/pricing">View detailed pricing</a></li>
              <li><a href="/about">How our process works</a></li>
              <li><a href="/training">Browse training categories</a></li>
              <li><a href="/blog">Read the blog</a></li>
            </ul>
          </div>
        </aside>

      </div>
    </div>
  </section>

  <!-- ============================================================
       3. FAQ — paper-deep · trimmed to contact-specific questions only.
       Generic pricing/process FAQs live canonically on /pricing
       ============================================================ -->
  <section class="section section--paper-deep contact-faq-section">
    <div class="container">
      <span class="section-kicker">FAQ</span>
      <h2 class="heading-xl section-title">Before you submit.</h2>

      <div class="faq-grid">
        <div class="faq-item content-card">
          <h3 class="heading-sm">What information do you need from me?</h3>
          <p>For an accurate quote we need to understand your training topic, audience, timeline, and what content you already have. The more detail you provide, the more precise our quote will be — but rough is fine too. We'll fill in the gaps on a quick call.</p>
        </div>

        <div class="faq-item content-card">
          <h3 class="heading-sm">How quickly can you start?</h3>
          <p>Usually within 1-2 weeks of accepting a quote, depending on our current project load. If you have an urgent deadline, mention it in the description — we'll prioritise where we can.</p>
        </div>

        <div class="faq-item content-card">
          <h3 class="heading-sm">Can you work with international clients?</h3>
          <p>Yes. We work with clients in the UK, US, Canada, New Zealand, and other English-speaking countries. International pricing available on request.</p>
        </div>

        <div class="faq-item content-card">
          <h3 class="heading-sm">What if I'm not sure what I need?</h3>
          <p>That's completely fine. Many clients aren't sure where to start. Pick "Not sure — help me choose" in the tier dropdown and describe what you're trying to achieve. We'll work out the rest together.</p>
        </div>
      </div>

      <div class="faq-cta">
        <p>More questions about pricing or process? <a href="/pricing" class="faq-cta-link">See our pricing FAQs</a>.</p>
      </div>
    </div>
  </section>

  <!-- ================================================================
       Tier copy as JSON, read by the client-side handler below.
       Data is hard-coded in frontmatter (no user input), so XSS risk
       is zero. is:inline keeps Astro from bundling/transforming this.
       ================================================================ -->
  <script id="tier-copy-data" type="application/json" is:inline set:html={JSON.stringify(tierCopy)} />

  <!-- ================================================================
       Client-side tier detection. Reads ?tier= and ?category= from the
       URL on page load and swaps generic content for tier-locked content
       when applicable. Runs immediately (deferred until DOM is parsed).
       Site is statically built, so this runs in the browser, not at build.
       ================================================================ -->
  <script is:inline>
    (function () {
      // Map URL tier values ('1', '2', '3', 'custom') to keys in tierCopy.
      var tierUrlToKey = { '1': 'tier1', '2': 'tier2', '3': 'tier3', 'custom': 'custom' };

      // Read query params.
      var params = new URLSearchParams(window.location.search);
      var rawTier = params.get('tier') || '';
      var category = params.get('category') || '';
      var tierKey = tierUrlToKey[rawTier] || '';

      // Load tier copy from the embedded JSON.
      var dataEl = document.getElementById('tier-copy-data');
      var tierCopy = dataEl ? JSON.parse(dataEl.textContent) : {};
      var locked = tierKey && tierCopy[tierKey] ? tierCopy[tierKey] : null;

      // 1. Tier-aware hero swap.
      if (locked) {
        var heroGeneric = document.querySelector('[data-hero-generic]');
        var heroTier = document.querySelector('[data-hero-tier]');
        if (heroGeneric) heroGeneric.hidden = true;
        if (heroTier) {
          heroTier.hidden = false;
          var label = heroTier.querySelector('[data-tier-label]');
          var line1 = heroTier.querySelector('[data-tier-hero-line-1]');
          var line2 = heroTier.querySelector('[data-tier-hero-line-2]');
          var subtitle = heroTier.querySelector('[data-tier-subtitle]');
          if (label) label.textContent = locked.label;
          if (line1) line1.textContent = locked.heroLine1;
          if (line2) line2.textContent = locked.heroLine2;
          if (subtitle) subtitle.textContent = locked.subtitle;
        }

        // 2. Tier-aware form swap.
        var picker = document.querySelector('[data-tier-picker]');
        var lockedBlock = document.querySelector('[data-tier-locked]');
        if (picker) {
          picker.hidden = true;
          // Critical: remove `required` from the now-hidden picker so the
          // form can submit. The browser blocks submission if a required
          // field has no value, even when hidden.
          var sel = picker.querySelector('#tier');
          if (sel) sel.removeAttribute('required');
        }
        if (lockedBlock) {
          lockedBlock.hidden = false;
          var name = lockedBlock.querySelector('[data-tier-locked-name]');
          var desc = lockedBlock.querySelector('[data-tier-locked-desc]');
          var price = lockedBlock.querySelector('[data-tier-locked-price]');
          var hidden = lockedBlock.querySelector('[data-tier-locked-input]');
          if (name) name.textContent = locked.label;
          if (desc) desc.textContent = locked.description;
          if (price) price.textContent = locked.price;
          if (hidden) hidden.value = tierKey;
        }

        // 3. Update the page title to match the tier (helpful for tabs/bookmarks).
        document.title = locked.label + ' — Get a quote | The eLearning Company';
      }

      // 4. Pre-fill description from ?category= regardless of tier state.
      if (category) {
        var desc = document.getElementById('description');
        if (desc && !desc.value) {
          desc.value = "I'm interested in " + category + " training.\n\n";
        }
      }
    })();
  </script>
</Layout>

<style>
  /* ============================================================
     Page-specific styles only.
     ============================================================ */

  /* ---- 1. Hero ---- */
  .contact-hero { padding-top: clamp(64px, 8vw, 100px); padding-bottom: clamp(56px, 7vw, 80px); }
  .hero-pill { margin-bottom: 24px; }
  .hero-title { margin-bottom: 24px; max-width: 900px; }
  .hero-subtitle { max-width: 640px; }

  /* ---- 2. Form section ---- */
  .form-wrapper {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: clamp(40px, 5vw, 64px);
    align-items: start;
  }

  /* ---- Form ---- */
  .contact-form {
    background: var(--c-paper);
    border: 1px solid rgba(21, 25, 46, 0.08);
    border-radius: var(--r-lg);
    padding: clamp(28px, 4vw, 48px);
  }

  .hidden-honeypot {
    position: absolute;
    left: -10000px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  .form-section-block {
    margin-bottom: 32px;
    padding-bottom: 32px;
    border-bottom: 1px solid rgba(21, 25, 46, 0.08);
  }
  .form-section-block:last-of-type {
    margin-bottom: 24px;
    padding-bottom: 0;
    border-bottom: none;
  }
  .form-section-label {
    display: block;
    color: var(--c-ink-muted);
    margin-bottom: 20px;
  }

  .form-group {
    margin-bottom: 20px;
  }
  .form-group:last-child { margin-bottom: 0; }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  .form-row .form-group { margin-bottom: 20px; }

  .form-group label {
    display: block;
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 500;
    color: var(--c-ink);
    margin-bottom: 8px;
    letter-spacing: -0.005em;
  }
  .required { color: var(--c-blue); }
  .optional {
    color: var(--c-ink-muted);
    font-weight: 400;
    font-size: 12px;
    margin-left: 4px;
  }

  /* Inputs / textareas / selects */
  .form-group input,
  .form-group select,
  .form-group textarea {
    width: 100%;
    padding: 12px 14px;
    background: var(--c-paper);
    border: 1px solid rgba(21, 25, 46, 0.15);
    border-radius: var(--r-md);
    color: var(--c-ink);
    font-family: var(--font-sans);
    font-size: 15px;
    line-height: 1.5;
    transition: border-color 0.15s ease, background 0.15s ease;
    -webkit-appearance: none;
    -moz-appearance: none;
    appearance: none;
  }
  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: var(--c-ink-muted);
    opacity: 0.7;
  }
  .form-group input:hover,
  .form-group select:hover,
  .form-group textarea:hover {
    border-color: rgba(21, 25, 46, 0.3);
  }
  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--c-ink);
    background: var(--c-paper);
  }
  .form-group textarea {
    resize: vertical;
    min-height: 120px;
    font-family: var(--font-sans);
  }

  /* Custom select arrow */
  .form-group select {
    background-image: url("data:image/svg+xml,%3Csvg width='12' height='8' viewBox='0 0 12 8' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1L6 6L11 1' stroke='%2315192E' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: right 14px center;
    padding-right: 36px;
  }

  /* Locked-tier confirmation block — shown when arriving from /pricing
     via a tier-specific CTA. Replaces the tier dropdown. */
  .tier-locked-label {
    display: block;
    margin-bottom: 10px;
  }
  .tier-locked-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    padding: 16px 20px;
    background: var(--c-lilac-tint);
    border: 1px solid var(--c-lilac);
    border-radius: var(--r-md);
  }
  .tier-locked-body { min-width: 0; }
  .tier-locked-name {
    font-family: var(--font-sans);
    font-size: 16px;
    font-weight: 600;
    color: var(--c-ink);
    letter-spacing: -0.01em;
    margin-bottom: 4px;
  }
  .tier-locked-desc {
    font-size: 13px;
    color: var(--c-ink-soft);
    line-height: 1.45;
  }
  .tier-locked-price {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 16px;
    color: var(--c-ink);
    white-space: nowrap;
    letter-spacing: -0.01em;
  }
  .tier-locked-change {
    display: inline-block;
    margin-top: 10px;
    font-size: 13px;
    color: var(--c-blue);
    text-decoration: none;
    border-bottom: 1px solid currentColor;
    padding-bottom: 1px;
    transition: color 0.15s ease;
  }
  .tier-locked-change:hover { color: var(--c-ink); }
  @media (max-width: 480px) {
    .tier-locked-card {
      flex-direction: column;
      align-items: flex-start;
      gap: 8px;
    }
  }
  .submit-btn {
    width: 100%;
    padding: 16px 24px;
    font-size: 16px;
    margin-top: 8px;
  }
  .form-note {
    font-size: 13px;
    color: var(--c-ink-muted);
    margin-top: 16px;
    line-height: 1.5;
  }

  /* ---- Info column ---- */
  .info-column {
    display: flex;
    flex-direction: column;
    gap: 16px;
    position: sticky;
    top: 100px;
  }

  .info-card {
    background: var(--c-paper-deep);
    border: 1px solid rgba(21, 25, 46, 0.06);
    border-radius: var(--r-lg);
    padding: 28px;
  }
  .info-card--accent {
    background: var(--c-lilac-tint);
    border-color: var(--c-lilac);
  }
  .info-card-label {
    display: block;
    color: var(--c-ink-muted);
    margin-bottom: 16px;
  }
  .info-card-text {
    font-size: 15px;
    color: var(--c-ink-soft);
    line-height: 1.55;
    margin-bottom: 16px;
  }

  /* What happens next steps */
  .next-steps {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .step {
    display: flex;
    gap: 14px;
    align-items: flex-start;
  }
  .step-num {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.1em;
    color: var(--c-ink-muted);
    flex-shrink: 0;
    padding-top: 4px;
    min-width: 22px;
  }
  .step-body h4 {
    margin-bottom: 4px;
    font-size: 15px;
    line-height: 1.3;
  }
  .step-body p {
    font-size: 14px;
    color: var(--c-ink-soft);
    line-height: 1.5;
  }

  /* Guarantee list */
  .guarantee-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .guarantee-list li {
    padding: 8px 0 8px 24px;
    position: relative;
    font-size: 15px;
    line-height: 1.5;
    color: var(--c-ink);
  }
  .guarantee-list li::before {
    content: "✓";
    position: absolute;
    left: 0;
    color: var(--c-ink);
    font-weight: 600;
  }

  /* Contact details */
  .contact-details {
