---
// src/pages/contact.astro
import Layout from '../components/layout/Layout.astro';

// Get query params for pre-filling form
const url = new URL(Astro.request.url);
const selectedTier = url.searchParams.get('tier') || '';
const selectedCategory = url.searchParams.get('category') || '';

// Tier value mapping (URL uses '1', '2', '3', 'custom'; form values are 'tier1' etc)
const tierMap: Record<string, string> = {
  '1': 'tier1',
  '2': 'tier2',
  '3': 'tier3',
  'custom': 'custom',
};
const preSelectedTier = tierMap[selectedTier] || '';
---

<Layout
  title="Get a Quote | The eLearning Company"
  description="Request a fixed-price quote for your custom eLearning project. We respond within 24 hours with transparent pricing and clear timelines."
>
  <!-- ============================================================
       1. Hero — lilac · welcoming, the conversion page
       ============================================================ -->
  <section class="section section--lilac contact-hero">
    <div class="container">
      <span class="pill-meta hero-pill">Get a quote</span>
      <h1 class="display display-xl hero-title">
        Let's build<br />
        <span class="accent-blue">something good.</span>
      </h1>
      <p class="lede hero-subtitle">
        Tell us about your training needs and we'll get back to you within 24 hours with a fixed-price quote.
      </p>
    </div>
  </section>

  <!-- ============================================================
       2. Form — paper · form left, info right
       ============================================================ -->
  <section class="section section--paper contact-form-section">
    <div class="container">
      <div class="form-wrapper">

        <!-- Form column -->
        <div class="form-column">
          <form
            name="contact"
            method="POST"
            data-netlify="true"
            netlify-honeypot="bot-field"
            action="/thank-you"
            class="contact-form"
          >
            <input type="hidden" name="form-name" value="contact" />

            <p class="hidden-honeypot">
              <label>
                Don't fill this out if you're human:
                <input name="bot-field" />
              </label>
            </p>

            <div class="form-section-block">
              <span class="meta form-section-label">About you</span>

              <div class="form-group">
                <label for="name">Your name <span class="required" aria-hidden="true">*</span></label>
                <input type="text" id="name" name="name" required placeholder="John Smith" />
              </div>

              <div class="form-row">
                <div class="form-group">
                  <label for="email">Email <span class="required" aria-hidden="true">*</span></label>
                  <input type="email" id="email" name="email" required placeholder="john@company.com.au" />
                </div>

                <div class="form-group">
                  <label for="phone">Phone <span class="optional">(optional)</span></label>
                  <input type="tel" id="phone" name="phone" placeholder="+61 4XX XXX XXX" />
                </div>
              </div>

              <div class="form-group">
                <label for="company">Company name <span class="required" aria-hidden="true">*</span></label>
                <input type="text" id="company" name="company" required placeholder="Your Company Pty Ltd" />
              </div>
            </div>

            <div class="form-section-block">
              <span class="meta form-section-label">About the project</span>

              <div class="form-group">
                <label for="category">Training category <span class="required" aria-hidden="true">*</span></label>
                <select id="category" name="category" required>
                  <option value="">Select a category</option>
                  <optgroup label="Compliance & Risk">
                    <option value="Workplace Health & Safety" selected={selectedCategory === 'Workplace Health & Safety'}>Workplace Health &amp; Safety</option>
                    <option value="Sexual Harassment Prevention" selected={selectedCategory === 'Sexual Harassment Prevention'}>Sexual Harassment Prevention</option>
                    <option value="Cyber Security Awareness" selected={selectedCategory === 'Cyber Security Awareness'}>Cyber Security Awareness</option>
                    <option value="Privacy & Data Protection" selected={selectedCategory === 'Privacy & Data Protection'}>Privacy &amp; Data Protection</option>
                    <option value="Anti-Bribery & Corruption" selected={selectedCategory === 'Anti-Bribery & Corruption'}>Anti-Bribery &amp; Corruption</option>
                    <option value="Code of Conduct" selected={selectedCategory === 'Code of Conduct'}>Code of Conduct</option>
                    <option value="Workplace Bullying Prevention" selected={selectedCategory === 'Workplace Bullying Prevention'}>Workplace Bullying Prevention</option>
                  </optgroup>
                  <optgroup label="Onboarding & Culture">
                    <option value="New Employee Onboarding" selected={selectedCategory === 'New Employee Onboarding'}>New Employee Onboarding</option>
                    <option value="Company Induction" selected={selectedCategory === 'Company Induction'}>Company Induction Programs</option>
                    <option value="Diversity & Inclusion" selected={selectedCategory === 'Diversity & Inclusion'}>Diversity &amp; Inclusion</option>
                    <option value="Mental Health Awareness" selected={selectedCategory === 'Mental Health Awareness'}>Mental Health Awareness</option>
                    <option value="Remote Work Best Practices" selected={selectedCategory === 'Remote Work Best Practices'}>Remote Work Best Practices</option>
                  </optgroup>
                  <optgroup label="Skills Development">
                    <option value="Customer Service Training" selected={selectedCategory === 'Customer Service Training'}>Customer Service Training</option>
                    <option value="Sales Training" selected={selectedCategory === 'Sales Training'}>Sales Training &amp; Enablement</option>
                    <option value="Leadership Development" selected={selectedCategory === 'Leadership Development'}>Leadership Development</option>
                    <option value="Communication Skills" selected={selectedCategory === 'Communication Skills'}>Communication Skills</option>
                    <option value="Time Management" selected={selectedCategory === 'Time Management'}>Time Management &amp; Productivity</option>
                    <option value="Conflict Resolution" selected={selectedCategory === 'Conflict Resolution'}>Conflict Resolution</option>
                    <option value="Feedback & Performance" selected={selectedCategory === 'Feedback & Performance'}>Feedback &amp; Performance Conversations</option>
                  </optgroup>
                  <optgroup label="Operational & Technical">
                    <option value="Product Training" selected={selectedCategory === 'Product Training'}>Product Training</option>
                    <option value="Software/System Training" selected={selectedCategory === 'Software/System Training'}>Software/System Training</option>
                    <option value="Process & Procedure" selected={selectedCategory === 'Process & Procedure'}>Process &amp; Procedure Training</option>
                    <option value="Quality Management" selected={selectedCategory === 'Quality Management'}>Quality Management Systems</option>
                    <option value="Emergency Response" selected={selectedCategory === 'Emergency Response'}>Emergency Response Procedures</option>
                    <option value="Change Management" selected={selectedCategory === 'Change Management'}>Change Management</option>
                  </optgroup>
                  <option value="Other" selected={selectedCategory === 'Other'}>Other (please specify in description)</option>
                </select>
              </div>

              <div class="form-group">
                <label for="tier">Which pricing tier suits your needs? <span class="required" aria-hidden="true">*</span></label>
                <select id="tier" name="tier" required>
                  <option value="">Select a tier</option>
                  <option value="tier1" selected={preSelectedTier === 'tier1'}>Tier 1 — Content ready ($5,500 + GST)</option>
                  <option value="tier2" selected={preSelectedTier === 'tier2'}>Tier 2 — Content needs shaping ($7,500 + GST)</option>
                  <option value="tier3" selected={preSelectedTier === 'tier3'}>Tier 3 — Start from scratch ($10,500 + GST)</option>
                  <option value="custom" selected={preSelectedTier === 'custom'}>Custom quote — something more complex</option>
                  <option value="unsure">Not sure — help me choose</option>
                </select>
              </div>

              <div class="form-group">
                <label for="timeline">When do you need it? <span class="optional">(optional)</span></label>
                <select id="timeline" name="timeline">
                  <option value="">Select timeline</option>
                  <option value="ASAP">ASAP (within 4 weeks)</option>
                  <option value="1-2 months">1-2 months</option>
                  <option value="3-6 months">3-6 months</option>
                  <option value="6+ months">6+ months</option>
                  <option value="exploring">Just exploring options</option>
                </select>
              </div>

              <div class="form-group">
                <label for="description">Tell us about your project <span class="required" aria-hidden="true">*</span></label>
                <textarea
                  id="description"
                  name="description"
                  rows="6"
                  required
                  placeholder="What training do you need? Who is the audience? Do you have existing content? Any specific requirements?"
                ></textarea>
              </div>
            </div>

            <div class="form-section-block">
              <span class="meta form-section-label">Optional</span>

              <div class="form-group">
                <label for="source">How did you hear about us?</label>
                <select id="source" name="source">
                  <option value="">Select source</option>
                  <option value="Google Search">Google search</option>
                  <option value="LinkedIn">LinkedIn</option>
                  <option value="Referral">Referral from colleague or friend</option>
                  <option value="Social Media">Social media</option>
                  <option value="Blog/Article">Blog or article</option>
                  <option value="Directory">Business directory</option>
                  <option value="Other">Other</option>
                </select>
              </div>
            </div>

            <button type="submit" class="btn btn--primary submit-btn">
              Get your quote
            </button>

            <p class="form-note">
              <span class="required" aria-hidden="true">*</span> Required fields. We'll respond within 24 hours with a fixed-price quote.
            </p>
          </form>
        </div>

        <!-- Info column -->
        <aside class="info-column">
          <div class="info-card">
            <span class="meta info-card-label">What happens next</span>
            <div class="next-steps">
              <div class="step">
                <span class="step-num">01</span>
                <div class="step-body">
                  <h4 class="heading-sm">We review your request</h4>
                  <p>Within 24 hours (usually much faster).</p>
                </div>
              </div>
              <div class="step">
                <span class="step-num">02</span>
                <div class="step-body">
                  <h4 class="heading-sm">Quick discovery call</h4>
                  <p>15-20 minute call to clarify your needs.</p>
                </div>
              </div>
              <div class="step">
                <span class="step-num">03</span>
                <div class="step-body">
                  <h4 class="heading-sm">Fixed-price quote</h4>
                  <p>Clear pricing, timeline, and deliverables.</p>
                </div>
              </div>
              <div class="step">
                <span class="step-num">04</span>
                <div class="step-body">
                  <h4 class="heading-sm">Start your project</h4>
                  <p>If you accept, we begin immediately.</p>
                </div>
              </div>
            </div>
          </div>

          <div class="info-card info-card--accent">
            <span class="meta info-card-label">Our guarantee</span>
            <ul class="guarantee-list">
              <li>Fixed pricing, no hidden costs</li>
              <li>3-week delivery timeline</li>
              <li>Unlimited revisions during development</li>
              <li>No-obligation quote</li>
              <li>Transparent process, start to finish</li>
            </ul>
          </div>

          <div class="info-card">
            <span class="meta info-card-label">Prefer email?</span>
            <p class="info-card-text">We're happy to discuss your project by email.</p>
            <dl class="contact-details">
              <dt>Email</dt>
              <dd><a href="mailto:contact@elearningcompany.net" class="contact-link">contact@elearningcompany.net</a></dd>
              <dt>Location</dt>
              <dd>Victoria, Australia</dd>
              <dt>Hours</dt>
              <dd>All Australian time zones</dd>
            </dl>
          </div>

          <div class="info-card">
            <span class="meta info-card-label">Not ready yet?</span>
            <ul class="resource-links">
              <li><a href="/pricing">View detailed pricing</a></li>
              <li><a href="/about">How our process works</a></li>
              <li><a href="/training">Browse training categories</a></li>
              <li><a href="/blog">Read the blog</a></li>
            </ul>
          </div>
        </aside>

      </div>
    </div>
  </section>

  <!-- ============================================================
       3. FAQ — paper-deep · trimmed to contact-specific questions only.
       Generic pricing/process FAQs live canonically on /pricing
       ============================================================ -->
  <section class="section section--paper-deep contact-faq-section">
    <div class="container">
      <span class="section-kicker">FAQ</span>
      <h2 class="heading-xl section-title">Before you submit.</h2>

      <div class="faq-grid">
        <div class="faq-item content-card">
          <h3 class="heading-sm">What information do you need from me?</h3>
          <p>For an accurate quote we need to understand your training topic, audience, timeline, and what content you already have. The more detail you provide, the more precise our quote will be — but rough is fine too. We'll fill in the gaps on a quick call.</p>
        </div>

        <div class="faq-item content-card">
          <h3 class="heading-sm">How quickly can you start?</h3>
          <p>Usually within 1-2 weeks of accepting a quote, depending on our current project load. If you have an urgent deadline, mention it in the description — we'll prioritise where we can.</p>
        </div>

        <div class="faq-item content-card">
          <h3 class="heading-sm">Can you work with international clients?</h3>
          <p>Yes. We work with clients in the UK, US, Canada, New Zealand, and other English-speaking countries. International pricing available on request.</p>
        </div>

        <div class="faq-item content-card">
          <h3 class="heading-sm">What if I'm not sure what I need?</h3>
          <p>That's completely fine. Many clients aren't sure where to start. Pick "Not sure — help me choose" in the tier dropdown and describe what you're trying to achieve. We'll work out the rest together.</p>
        </div>
      </div>

      <div class="faq-cta">
        <p>More questions about pricing or process? <a href="/pricing" class="faq-cta-link">See our pricing FAQs</a>.</p>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ============================================================
     Page-specific styles only.
     ============================================================ */

  /* ---- 1. Hero ---- */
  .contact-hero { padding-top: clamp(64px, 8vw, 100px); padding-bottom: clamp(56px, 7vw, 80px); }
  .hero-pill { margin-bottom: 24px; }
  .hero-title { margin-bottom: 24px; max-width: 900px; }
  .hero-subtitle { max-width: 640px; }

  /* ---- 2. Form section ---- */
  .form-wrapper {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: clamp(40px, 5vw, 64px);
    align-items: start;
  }

  /* ---- Form ---- */
  .contact-form {
    background: var(--c-paper);
    border: 1px solid rgba(21, 25, 46, 0.08);
    border-radius: var(--r-lg);
    padding: clamp(28px, 4vw, 48px);
  }

  .hidden-honeypot {
    position: absolute;
    left: -10000px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  .form-section-block {
    margin-bottom: 32px;
    padding-bottom: 32px;
    border-bottom: 1px solid rgba(21, 25, 46, 0.08);
  }
  .form-section-block:last-of-type {
    margin-bottom: 24px;
    padding-bottom: 0;
    border-bottom: none;
  }
  .form-section-label {
    display: block;
    color: var(--c-ink-muted);
    margin-bottom: 20px;
  }

  .form-group {
    margin-bottom: 20px;
  }
  .form-group:last-child { margin-bottom: 0; }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  .form-row .form-group { margin-bottom: 20px; }

  .form-group label {
    display: block;
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 500;
    color: var(--c-ink);
    margin-bottom: 8px;
    letter-spacing: -0.005em;
  }
  .required { color: var(--c-blue); }
  .optional {
    color: var(--c-ink-muted);
    font-weight: 400;
    font-size: 12px;
    margin-left: 4px;
  }

  /* Inputs / textareas / selects */
  .form-group input,
  .form-group select,
  .form-group textarea {
    width: 100%;
    padding: 12px 14px;
    background: var(--c-paper);
    border: 1px solid rgba(21, 25, 46, 0.15);
    border-radius: var(--r-md);
    color: var(--c-ink);
    font-family: var(--font-sans);
    font-size: 15px;
    line-height: 1.5;
    transition: border-color 0.15s ease, background 0.15s ease;
    -webkit-appearance: none;
    -moz-appearance: none;
    appearance: none;
  }
  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: var(--c-ink-muted);
    opacity: 0.7;
  }
  .form-group input:hover,
  .form-group select:hover,
  .form-group textarea:hover {
    border-color: rgba(21, 25, 46, 0.3);
  }
  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--c-ink);
    background: var(--c-paper);
  }
  .form-group textarea {
    resize: vertical;
    min-height: 120px;
    font-family: var(--font-sans);
  }

  /* Custom select arrow */
  .form-group select {
    background-image: url("data:image/svg+xml,%3Csvg width='12' height='8' viewBox='0 0 12 8' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1L6 6L11 1' stroke='%2315192E' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: right 14px center;
    padding-right: 36px;
  }

  .submit-btn {
    width: 100%;
    padding: 16px 24px;
    font-size: 16px;
    margin-top: 8px;
  }
  .form-note {
    font-size: 13px;
    color: var(--c-ink-muted);
    margin-top: 16px;
    line-height: 1.5;
  }

  /* ---- Info column ---- */
  .info-column {
    display: flex;
    flex-direction: column;
    gap: 16px;
    position: sticky;
    top: 100px;
  }

  .info-card {
    background: var(--c-paper-deep);
    border: 1px solid rgba(21, 25, 46, 0.06);
    border-radius: var(--r-lg);
    padding: 28px;
  }
  .info-card--accent {
    background: var(--c-lilac-tint);
    border-color: var(--c-lilac);
  }
  .info-card-label {
    display: block;
    color: var(--c-ink-muted);
    margin-bottom: 16px;
  }
  .info-card-text {
    font-size: 15px;
    color: var(--c-ink-soft);
    line-height: 1.55;
    margin-bottom: 16px;
  }

  /* What happens next steps */
  .next-steps {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .step {
    display: flex;
    gap: 14px;
    align-items: flex-start;
  }
  .step-num {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.1em;
    color: var(--c-ink-muted);
    flex-shrink: 0;
    padding-top: 4px;
    min-width: 22px;
  }
  .step-body h4 {
    margin-bottom: 4px;
    font-size: 15px;
    line-height: 1.3;
  }
  .step-body p {
    font-size: 14px;
    color: var(--c-ink-soft);
    line-height: 1.5;
  }

  /* Guarantee list */
  .guarantee-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .guarantee-list li {
    padding: 8px 0 8px 24px;
    position: relative;
    font-size: 15px;
    line-height: 1.5;
    color: var(--c-ink);
  }
  .guarantee-list li::before {
    content: "✓";
    position: absolute;
    left: 0;
    color: var(--c-ink);
    font-weight: 600;
  }

  /* Contact details */
  .contact-details {
    margin: 0;
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 8px 12px;
  }
  .contact-details dt {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--c-ink-muted);
    padding-top: 2px;
  }
  .contact-details dd {
    margin: 0;
    font-size: 14px;
    color: var(--c-ink);
    line-height: 1.5;
  }
  .contact-link {
    color: var(--c-blue);
    text-decoration: none;
    border-bottom: 1px solid currentColor;
  }
  .contact-link:hover { color: var(--c-ink); }

  /* Resource links */
  .resource-links {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .resource-links li {
    padding: 6px 0 6px 24px;
    position: relative;
  }
  .resource-links li::before {
    content: "→";
    position: absolute;
    left: 0;
    color: var(--c-ink-muted);
    font-family: var(--font-mono);
  }
  .resource-links a {
    color: var(--c-ink);
    text-decoration: none;
    font-size: 15px;
    transition: color 0.15s ease;
  }
  .resource-links a:hover {
    color: var(--c-blue);
  }

  /* ---- 3. FAQ ---- */
  .contact-faq-section .section-title { margin-bottom: 56px; }
  .faq-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 32px;
  }
  .faq-item h3 { margin-bottom: 12px; }
  .faq-item p {
    color: var(--c-ink-soft);
    line-height: 1.7;
    font-size: 15px;
  }
  .faq-cta {
    text-align: center;
    font-size: 16px;
    color: var(--c-ink-soft);
  }
  .faq-cta-link {
    color: var(--c-blue);
    text-decoration: none;
    font-weight: 500;
    border-bottom: 1px solid currentColor;
  }
  .faq-cta-link:hover { color: var(--c-ink); }

  /* ---- Responsive ---- */
  @media (max-width: 1024px) {
    .form-wrapper { grid-template-columns: 1fr; }
    .info-column { position: static; flex-direction: row; flex-wrap: wrap; }
    .info-card { flex: 1 1 calc(50% - 8px); min-width: 280px; }
  }
  @media (max-width: 768px) {
    .form-row { grid-template-columns: 1fr; gap: 0; }
    .faq-grid { grid-template-columns: 1fr; }
    .info-card { flex: 1 1 100%; }
  }
</style>
