---
// src/pages/tools/[tool].astro
// Authoring tool–specific landing pages
import Layout from '../../components/layout/Layout.astro';

export async function getStaticPaths() {
  const tools = [
    {
      slug: 'articulate-rise',
      name: 'Articulate Rise',
      tagline: 'Modern, responsive courses that work beautifully on any device.',
      description: 'Professional Articulate Rise eLearning development. Clean, mobile-friendly courses delivered in 3 weeks.',
      bestFor: ['Quick deployment', 'Mobile learning', 'Compliance training', 'Onboarding', 'Simple interactions'],
      features: ['Fully responsive design', 'Fast development', 'Built-in templates', 'Clean, modern look', 'Easy to update'],
      limitations: ['Limited custom interactions', 'Template-based design', 'Linear structure'],
      pricing: '$5,500 + GST',
      deliveryTime: '3 weeks',
      complexity: 'Simple to moderate',
    },
    {
      slug: 'articulate-storyline',
      name: 'Articulate Storyline',
      tagline: 'Custom interactions, branching scenarios, and complex simulations.',
      description: 'Professional Articulate Storyline eLearning development for complex, interactive training experiences.',
      bestFor: ['Complex scenarios', 'Branching simulations', 'Software training', 'Decision-making practice', 'Game-based learning'],
      features: ['Full design control', 'Custom interactions', 'Advanced branching', 'Triggers and variables', 'Screen recordings'],
      limitations: ['Longer development time', 'More expensive', 'Requires more planning'],
      pricing: '$10,500 + GST (custom quote required)',
      deliveryTime: '3-6 weeks',
      complexity: 'Moderate to complex',
    },
    {
      slug: 'chameleon-creator',
      name: 'Chameleon Creator',
      tagline: 'SCORM-free, lightweight courses for rapid deployment.',
      description: 'Professional Chameleon Creator development for fast, web-based learning experiences.',
      bestFor: ['No LMS available', 'Web-based delivery', 'Quick updates', 'Lightweight courses', 'Modern aesthetics'],
      features: ['No SCORM needed', 'Cloud-hosted', 'Modern interface', 'Quick updates', 'Analytics built-in'],
      limitations: ['Less widely known', 'Requires Chameleon subscription', 'Limited offline use'],
      pricing: '$7,500 + GST (custom quote required)',
      deliveryTime: '3-4 weeks',
      complexity: 'Simple to moderate',
    },
    {
      slug: 'adobe-captivate',
      name: 'Adobe Captivate',
      tagline: 'Software simulations and responsive eLearning.',
      description: 'Professional Adobe Captivate development for software training and simulations.',
      bestFor: ['Software demonstrations', 'Screen captures', 'Responsive design', 'Interactive simulations', 'Technical training'],
      features: ['Screen recording', 'Software simulations', 'Responsive design', 'Virtual reality support', 'Powerful variables'],
      limitations: ['Steeper learning curve', 'Longer development', 'Higher cost'],
      pricing: '$10,500 + GST (custom quote required)',
      deliveryTime: '4-8 weeks',
      complexity: 'Moderate to complex',
    },
    {
      slug: 'howtoo',
      name: 'HowToo',
      tagline: 'Modern, collaborative course creation platform.',
      description: 'Professional HowToo development for collaborative, template-driven learning.',
      bestFor: ['Team collaboration', 'Fast deployment', 'Modern aesthetics', 'Template-based', 'Cloud delivery'],
      features: ['Team collaboration', 'Modern templates', 'Cloud-based', 'No software install', 'Quick updates'],
      limitations: ['Subscription required', 'Template constraints', 'Less customisation'],
      pricing: '$7,500 + GST (custom quote required)',
      deliveryTime: '2-4 weeks',
      complexity: 'Simple to moderate',
    },
    {
      slug: 'parta',
      name: 'Parta.io',
      tagline: 'Interactive video-based learning experiences.',
      description: 'Professional Parta.io development for engaging video-based courses.',
      bestFor: ['Video-based learning', 'Interactive scenarios', 'Branching stories', 'Engagement focus', 'Modern learners'],
      features: ['Video integration', 'Interactive elements', 'Mobile-friendly', 'Analytics included', 'Branching paths'],
      limitations: ['Video production needed', 'Platform subscription', 'Niche tool'],
      pricing: 'Custom quote required',
      deliveryTime: '4-6 weeks',
      complexity: 'Moderate',
    },
    {
      slug: '7taps',
      name: '7Taps',
      tagline: 'Mobile-first microlearning in minutes.',
      description: 'Professional 7Taps development for quick, mobile-optimised microlearning.',
      bestFor: ['Microlearning', 'Mobile-first', 'Quick tips', 'Just-in-time learning', 'Performance support'],
      features: ['Mobile-optimised', 'Super fast creation', 'Bite-sized content', 'No LMS needed', 'Social sharing'],
      limitations: ['Very limited interactions', 'Short content only', 'Platform subscription'],
      pricing: '$7,500 + GST (custom quote required)',
      deliveryTime: '1-2 weeks',
      complexity: 'Simple',
    },
    {
      slug: 'coassemble',
      name: 'Coassemble',
      tagline: 'Australian-built learning platform.',
      description: 'Professional Coassemble development for modern, template-driven courses.',
      bestFor: ['Australian businesses', 'Template-based', 'LMS included', 'Fast deployment', 'Team training'],
      features: ['Australian-made', 'Templates included', 'LMS built-in', 'Modern interface', 'Cloud-based'],
      limitations: ['Platform subscription', 'Template constraints', 'Less flexibility'],
      pricing: '$7,500 + GST (custom quote required)',
      deliveryTime: '2-4 weeks',
      complexity: 'Simple to moderate',
    },
  ];

  return tools.map(t => ({
    params: { tool: t.slug },
    props: { tool: t, allTools: tools },
  }));
}

const { tool, allTools } = Astro.props;

// Other tools for the comparison section (excluding the current one)
const otherTools = allTools.filter((t) => t.slug !== tool.slug).slice(0, 6);
---

<Layout
  title={`${tool.name} Development | Custom eLearning | The eLearning Company`}
  description={`Professional ${tool.name} eLearning development. ${tool.description} Transparent pricing, expert developers.`}
>
  <!-- ============================================================
       1. Hero — lilac
       ============================================================ -->
  <section class="section section--lilac tool-hero">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span class="breadcrumb-sep">/</span>
        <a href="/tools">Tools</a>
        <span class="breadcrumb-sep">/</span>
        <span class="breadcrumb-current">{tool.name}</span>
      </nav>

      <span class="pill-meta hero-pill">Authoring tool</span>

      <h1 class="display display-lg page-title">
        {tool.name}<br />
        <span class="accent-blue">development.</span>
      </h1>
      <p class="lede tool-tagline">{tool.tagline}</p>
      <p class="page-description">{tool.description}</p>

      <div class="tool-meta-strip">
        <div class="meta-item">
          <span class="meta meta-label">Pricing</span>
          <span class="meta-value">{tool.pricing}</span>
        </div>
        <div class="meta-item">
          <span class="meta meta-label">Timeline</span>
          <span class="meta-value">{tool.deliveryTime}</span>
        </div>
        <div class="meta-item">
          <span class="meta meta-label">Complexity</span>
          <span class="meta-value">{tool.complexity}</span>
        </div>
      </div>

      <div class="hero-cta">
        <a href="/contact" class="btn btn--primary">Get a quote</a>
        <a href="/pricing" class="btn btn--secondary">View pricing</a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       2. Best for — paper
       ============================================================ -->
  <section class="section section--paper best-for-section">
    <div class="container">
      <span class="section-kicker">Best for</span>
      <h2 class="display display-md section-title">
        {tool.name} is best for.
      </h2>

      <ul class="best-for-grid">
        {tool.bestFor.map((item) => (
          <li class="best-for-item">
            <span class="best-for-marker" aria-hidden="true">→</span>
            <span class="best-for-text">{item}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ============================================================
       3. Features & considerations — paper-deep · two-column
       ============================================================ -->
  <section class="section section--paper-deep features-section">
    <div class="container">
      <div class="features-grid">

        <div class="features-column">
          <span class="section-kicker">Strengths</span>
          <h2 class="display display-md column-title">Key features.</h2>
          <ul class="feature-list">
            {tool.features.map((feature) => (
              <li class="feature-item">
                <span class="feature-marker feature-marker--check" aria-hidden="true">+</span>
                <span>{feature}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="features-column">
          <span class="section-kicker">Considerations</span>
          <h2 class="display display-md column-title">Tradeoffs.</h2>
          <ul class="feature-list">
            {tool.limitations.map((limitation) => (
              <li class="feature-item">
                <span class="feature-marker feature-marker--minus" aria-hidden="true">−</span>
                <span>{limitation}</span>
              </li>
            ))}
          </ul>
        </div>

      </div>
    </div>
  </section>

  <!-- ============================================================
       4. When to choose — paper · two-card decision aid
       ============================================================ -->
  <section class="section section--paper when-section">
    <div class="container">
      <span class="section-kicker">Decision guide</span>
      <h2 class="display display-md section-title">
        When to choose {tool.name}.
      </h2>

      <div class="when-cards">
        <div class="when-card when-card--yes">
          <span class="meta when-card-label">Choose {tool.name} when</span>
          <ul class="when-list">
            {tool.bestFor.map((item) => (
              <li>You need {item.toLowerCase()}.</li>
            ))}
            <li>You want professional, reliable development.</li>
            <li>Timeline and budget matter.</li>
          </ul>
        </div>

        <div class="when-card when-card--no">
          <span class="meta when-card-label">Consider alternatives if</span>
          <ul class="when-list">
            {tool.limitations.map((limitation) => (
              <li>{limitation} is a dealbreaker.</li>
            ))}
            <li>You need features outside {tool.name}'s strengths.</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       5. Process — turquoise
       ============================================================ -->
  <section class="section section--turquoise tool-process-section">
    <div class="container">
      <span class="section-kicker">Our process</span>
      <h2 class="display display-md section-title">
        Our {tool.name}<br />
        development process.
      </h2>

      <div class="process-steps">
        <div class="step">
          <div class="step-number">01</div>
          <h3 class="heading-sm">Requirements gathering</h3>
          <p>We discuss your training needs, content, and technical requirements specific to {tool.name}.</p>
        </div>
        <div class="step">
          <div class="step-number">02</div>
          <h3 class="heading-sm">Development</h3>
          <p>We build your course in {tool.name}, leveraging its strengths for your specific use case.</p>
        </div>
        <div class="step">
          <div class="step-number">03</div>
          <h3 class="heading-sm">Review &amp; refinement</h3>
          <p>Unlimited revisions to ensure the course meets your expectations.</p>
        </div>
        <div class="step">
          <div class="step-number">04</div>
          <h3 class="heading-sm">Delivery</h3>
          <p>Published course with source files and deployment support.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       6. Pricing — paper
       ============================================================ -->
  <section class="section section--paper tool-pricing-section">
    <div class="container">
      <span class="section-kicker">Pricing</span>
      <h2 class="display display-md section-title">
        {tool.name} development<br />
        pricing.
      </h2>
      <p class="lede section-subtitle">
        Transparent, fixed pricing based on complexity and content readiness.
      </p>

      <div class="pricing-info-card">
        <span class="meta starting-at-label">Starting at</span>
        <p class="starting-price">{tool.pricing}</p>

        <div class="pricing-factors">
          <span class="meta factors-label">Final pricing depends on</span>
          <ul class="factor-list">
            <li>Content readiness (script ready vs. full creation)</li>
            <li>Course complexity and interactions</li>
            <li>Number of modules or lessons</li>
            <li>Custom requirements specific to {tool.name}</li>
          </ul>
        </div>

        <a href="/contact" class="btn btn--primary pricing-cta">Request custom quote</a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       7. Comparison — paper-deep · other tools
       ============================================================ -->
  <section class="section section--paper-deep comparison-section">
    <div class="container">
      <span class="section-kicker">Other tools</span>
      <h2 class="display display-md section-title">
        Comparing authoring tools.
      </h2>
      <p class="lede section-subtitle">
        Not sure if {tool.name} is right for you? Here's how it compares.
      </p>

      <div class="comparison-grid">
        {otherTools.map((other) => (
          <a href={`/tools/${other.slug}`} class="comparison-card">
            <h4 class="heading-sm comparison-name">{other.name}</h4>
            <p class="comparison-best-for">
              <span class="comparison-best-label">Best for ·</span> {other.bestFor.slice(0, 2).join(', ').toLowerCase()}
            </p>
            <span class="comparison-arrow" aria-hidden="true">→</span>
          </a>
        ))}
      </div>

      <div class="comparison-note">
        <p>Need help choosing? <a href="/contact" class="inline-link">Contact us</a> and we'll recommend the best tool for your specific needs.</p>
      </div>
    </div>
  </section>

  <!-- ============================================================
       8. FAQ — navy
       ============================================================ -->
  <section class="section section--navy tool-faq-section">
    <div class="container">
      <span class="section-kicker">FAQ</span>
      <h2 class="heading-xl section-title">Common {tool.name} questions.</h2>

      <div class="faq-grid">
        <div class="faq-item content-card">
          <h3 class="heading-sm">Do I need to purchase {tool.name}?</h3>
          <p>No. We have the licences and expertise. You just receive the finished course files. If you want to make future updates yourself, you'd need your own licence.</p>
        </div>

        <div class="faq-item content-card">
          <h3 class="heading-sm">Do you provide training on {tool.name}?</h3>
          <p>Our service is course development, not tool training. However, we can recommend resources if you want to learn {tool.name} yourself.</p>
        </div>

        <div class="faq-item content-card">
          <h3 class="heading-sm">What if {tool.name} isn't the right tool for my project?</h3>
          <p>We'll tell you. During our discovery call, we'll recommend the best authoring tool for your needs, even if it's not {tool.name}.</p>
        </div>
      </div>

      <div class="faq-cta">
        <p>For pricing, timeline, and process questions, see our <a href="/pricing#faq" class="faq-cta-link">full FAQ</a>.</p>
      </div>
    </div>
  </section>

  <!-- ============================================================
       9. Final CTA — lilac
       ============================================================ -->
  <section class="section section--lilac final-cta-section">
    <div class="container">
      <div class="cta-content">
        <h2 class="display display-lg cta-title">
          Ready to build your<br />
          <span class="accent-blue">{tool.name} course?</span>
        </h2>
        <p class="lede cta-text">
          Get a fixed-price quote within 24 hours. We'll discuss your requirements and recommend the best approach.
        </p>
        <div class="cta-buttons">
          <a href="/contact" class="btn btn--primary">Request a quote</a>
          <a href="/pricing" class="btn btn--secondary">View pricing guide</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ============================================================
     Page-specific styles only.
     ============================================================ */

  /* ---- 1. Hero ---- */
  .tool-hero {
    padding-top: clamp(56px, 7vw, 80px);
    padding-bottom: clamp(80px, 10vw, 120px);
  }

  .breadcrumb {
    font-family: var(--font-mono);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--c-ink);
    opacity: 0.7;
    margin-bottom: 32px;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 6px;
  }
  .breadcrumb a {
    color: var(--c-ink);
    text-decoration: none;
    transition: opacity 0.15s ease;
  }
  .breadcrumb a:hover { opacity: 0.5; }
  .breadcrumb-sep { opacity: 0.5; }
  .breadcrumb-current { opacity: 0.6; }

  .hero-pill { margin-bottom: 24px; }
  .page-title { margin-bottom: 24px; max-width: 900px; }
  .tool-tagline {
    margin-bottom: 16px;
    font-weight: 500;
    color: var(--c-ink);
    max-width: 700px;
  }
  .page-description {
    color: var(--c-ink-soft);
    font-size: 16px;
    line-height: 1.6;
    margin-bottom: 40px;
    max-width: 640px;
  }

  .tool-meta-strip {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
    margin-bottom: 40px;
    padding: 24px 0;
    border-top: 1px solid rgba(21, 25, 46, 0.15);
    border-bottom: 1px solid rgba(21, 25, 46, 0.15);
    max-width: 800px;
  }
  .meta-item {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .meta-label { color: var(--c-ink-muted); }
  .meta-value {
    font-family: var(--font-sans);
    font-size: 15px;
    font-weight: 600;
    color: var(--c-ink);
    line-height: 1.3;
  }

  .hero-cta { display: flex; gap: 12px; flex-wrap: wrap; }

  /* ---- 2. Best for ---- */
  .best-for-section .section-title { margin-bottom: 56px; max-width: 720px; }

  .best-for-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0;
  }
  .best-for-item {
    display: flex;
    gap: 14px;
    padding: 20px 0;
    border-bottom: 1px solid rgba(21, 25, 46, 0.08);
    align-items: flex-start;
  }
  .best-for-marker {
    font-family: var(--font-mono);
    color: var(--c-ink-muted);
    flex-shrink: 0;
    padding-top: 2px;
  }
  .best-for-text {
    font-size: 17px;
    line-height: 1.5;
    color: var(--c-ink);
  }

  /* ---- 3. Features & considerations ---- */
  .features-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(40px, 6vw, 80px);
  }
  .features-column .section-kicker { margin-bottom: 12px; }
  .column-title { margin-bottom: 32px; max-width: none; }

  .feature-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .feature-item {
    display: flex;
    gap: 14px;
    padding: 14px 0;
    border-bottom: 1px solid rgba(21, 25, 46, 0.08);
    align-items: flex-start;
    font-size: 16px;
    line-height: 1.5;
    color: var(--c-ink);
  }
  .feature-marker {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 13px;
    line-height: 1;
    margin-top: 1px;
  }
  .feature-marker--check {
    background: var(--c-ink);
    color: var(--c-paper);
  }
  .feature-marker--minus {
    background: transparent;
    color: var(--c-ink);
    border: 1.5px solid var(--c-ink);
    opacity: 0.6;
  }

  /* ---- 4. When to choose ---- */
  .when-section .section-title { margin-bottom: 56px; }
  .when-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }
  .when-card {
    background: var(--c-paper-deep);
    border: 1px solid rgba(21, 25, 46, 0.08);
    border-radius: var(--r-lg);
    padding: 32px;
  }
  .when-card--yes {
    background: var(--c-turquoise-tint);
    border-color: var(--c-turquoise-deep);
  }
  .when-card--no {
    background: var(--c-paper-deep);
    border-color: rgba(21, 25, 46, 0.1);
  }
  .when-card-label {
    display: block;
    color: var(--c-ink);
    opacity: 0.75;
    margin-bottom: 20px;
  }
  .when-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .when-list li {
    padding: 8px 0 8px 22px;
    position: relative;
    font-size: 15px;
    line-height: 1.55;
    color: var(--c-ink);
  }
  .when-list li::before {
    content: "→";
    position: absolute;
    left: 0;
    color: var(--c-ink);
    opacity: 0.55;
    font-family: var(--font-mono);
  }

  /* ---- 5. Process ---- */
  .tool-process-section .section-title { margin-bottom: 64px; }
  .process-steps {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
  }
  .step-number {
    font-family: var(--font-display);
    font-size: 48px;
    line-height: 1;
    margin-bottom: 20px;
    color: var(--c-ink);
    letter-spacing: -0.02em;
  }
  .step h3 { margin-bottom: 10px; }
  .step p {
    color: var(--c-ink-soft);
    line-height: 1.6;
    font-size: 15px;
  }

  /* ---- 6. Pricing ---- */
  .tool-pricing-section .section-title { margin-bottom: 16px; }
  .tool-pricing-section .section-subtitle { margin-bottom: 56px; }

  .pricing-info-card {
    background: var(--c-paper-deep);
    border: 1px solid rgba(21, 25, 46, 0.08);
    border-radius: var(--r-lg);
    padding: clamp(32px, 5vw, 48px);
    max-width: 720px;
  }
  .starting-at-label {
    display: block;
    color: var(--c-ink-muted);
    margin-bottom: 8px;
  }
  .starting-price {
    font-family: var(--font-display);
    font-size: clamp(32px, 4vw, 48px);
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--c-ink);
    margin-bottom: 32px;
  }

  .pricing-factors {
    padding: 24px 0 32px;
    border-top: 1px solid rgba(21, 25, 46, 0.1);
  }
  .factors-label {
    display: block;
    color: var(--c-ink-muted);
    margin-bottom: 14px;
  }
  .factor-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .factor-list li {
    padding: 6px 0 6px 22px;
    position: relative;
    font-size: 15px;
    line-height: 1.55;
    color: var(--c-ink);
  }
  .factor-list li::before {
    content: "→";
    position: absolute;
    left: 0;
    color: var(--c-ink-muted);
    font-family: var(--font-mono);
  }

  /* ---- 7. Comparison ---- */
  .comparison-section .section-title { margin-bottom: 16px; }
  .comparison-section .section-subtitle { margin-bottom: 56px; }

  .comparison-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-bottom: 32px;
  }
  .comparison-card {
    background: var(--c-paper);
    border: 1px solid rgba(21, 25, 46, 0.08);
    border-radius: var(--r-lg);
    padding: 24px;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    transition: border-color 0.2s ease, transform 0.2s ease;
    position: relative;
  }
  .comparison-card:hover {
    border-color: var(--c-ink);
    transform: translateY(-2px);
  }
  .comparison-name { margin-bottom: 10px; font-size: 18px; }
  .comparison-best-for {
    color: var(--c-ink-soft);
    font-size: 14px;
    line-height: 1.5;
    margin: 0;
    flex: 1;
  }
