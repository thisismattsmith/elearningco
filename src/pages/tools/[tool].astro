---
// src/pages/tools/[tool].astro
// This template creates authoring tool-specific pages

export async function getStaticPaths() {
  const tools = [
    {
      slug: 'articulate-rise',
      name: 'Articulate Rise',
      tagline: 'Modern, responsive courses that work beautifully on any device',
      description: 'Professional Articulate Rise eLearning development. Clean, mobile-friendly courses delivered in 3 weeks.',
      bestFor: ['Quick deployment', 'Mobile learning', 'Compliance training', 'Onboarding', 'Simple interactions'],
      features: ['Fully responsive design', 'Fast development', 'Built-in templates', 'Clean, modern look', 'Easy to update'],
      limitations: ['Limited custom interactions', 'Template-based design', 'Linear structure'],
      pricing: 'From $5,500 + GST',
      deliveryTime: '3 weeks',
      complexity: 'Simple to Moderate',
    },
    {
      slug: 'articulate-storyline',
      name: 'Articulate Storyline',
      tagline: 'Custom interactions, branching scenarios, and complex simulations',
      description: 'Professional Articulate Storyline eLearning development for complex, interactive training experiences.',
      bestFor: ['Complex scenarios', 'Branching simulations', 'Software training', 'Decision-making practice', 'Game-based learning'],
      features: ['Full design control', 'Custom interactions', 'Advanced branching', 'Triggers and variables', 'Screen recordings'],
      limitations: ['Longer development time', 'More expensive', 'Requires more planning'],
      pricing: 'From $10,500 + GST (custom quote)',
      deliveryTime: '3-6 weeks',
      complexity: 'Moderate to Complex',
    },
    {
      slug: 'chameleon-creator',
      name: 'Chameleon Creator',
      tagline: 'SCORM-free, lightweight courses for rapid deployment',
      description: 'Professional Chameleon Creator development for fast, web-based learning experiences.',
      bestFor: ['No LMS available', 'Web-based delivery', 'Quick updates', 'Lightweight courses', 'Modern aesthetics'],
      features: ['No SCORM needed', 'Cloud-hosted', 'Modern interface', 'Quick updates', 'Analytics built-in'],
      limitations: ['Less widely known', 'Requires Chameleon subscription', 'Limited offline use'],
      pricing: 'From $7,500 + GST (custom quote)',
      deliveryTime: '3-4 weeks',
      complexity: 'Simple to Moderate',
    },
    {
      slug: 'adobe-captivate',
      name: 'Adobe Captivate',
      tagline: 'Software simulations and responsive eLearning',
      description: 'Professional Adobe Captivate development for software training and simulations.',
      bestFor: ['Software demonstrations', 'Screen captures', 'Responsive design', 'Interactive simulations', 'Technical training'],
      features: ['Screen recording', 'Software simulations', 'Responsive design', 'Virtual reality support', 'Powerful variables'],
      limitations: ['Steeper learning curve', 'Longer development', 'Higher cost'],
      pricing: 'Custom quote required',
      deliveryTime: '4-8 weeks',
      complexity: 'Moderate to Complex',
    },
    {
      slug: 'howtoo',
      name: 'HowToo',
      tagline: 'Modern, collaborative course creation platform',
      description: 'Professional HowToo development for collaborative, template-driven learning.',
      bestFor: ['Team collaboration', 'Fast deployment', 'Modern aesthetics', 'Template-based', 'Cloud delivery'],
      features: ['Team collaboration', 'Modern templates', 'Cloud-based', 'No software install', 'Quick updates'],
      limitations: ['Subscription required', 'Template constraints', 'Less customization'],
      pricing: 'From $7,500 + GST (custom quote)',
      deliveryTime: '2-4 weeks',
      complexity: 'Simple to Moderate',
    },
    {
      slug: 'parta',
      name: 'Parta.io',
      tagline: 'Interactive video-based learning experiences',
      description: 'Professional Parta.io development for engaging video-based courses.',
      bestFor: ['Video-based learning', 'Interactive scenarios', 'Branching stories', 'Engagement focus', 'Modern learners'],
      features: ['Video integration', 'Interactive elements', 'Mobile-friendly', 'Analytics included', 'Branching paths'],
      limitations: ['Video production needed', 'Platform subscription', 'Niche tool'],
      pricing: 'Custom quote required',
      deliveryTime: '4-6 weeks',
      complexity: 'Moderate',
    },
    {
      slug: '7taps',
      name: '7Taps',
      tagline: 'Mobile-first microlearning in minutes',
      description: 'Professional 7Taps development for quick, mobile-optimized microlearning.',
      bestFor: ['Microlearning', 'Mobile-first', 'Quick tips', 'Just-in-time learning', 'Performance support'],
      features: ['Mobile-optimized', 'Super fast creation', 'Bite-sized content', 'No LMS needed', 'Social sharing'],
      limitations: ['Very limited interactions', 'Short content only', 'Platform subscription'],
      pricing: 'From $3,500 + GST (custom quote)',
      deliveryTime: '1-2 weeks',
      complexity: 'Simple',
    },
    {
      slug: 'coassemble',
      name: 'Coassemble',
      tagline: 'Australian-built learning platform',
      description: 'Professional Coassemble development for modern, template-driven courses.',
      bestFor: ['Australian businesses', 'Template-based', 'LMS included', 'Fast deployment', 'Team training'],
      features: ['Australian-made', 'Templates included', 'LMS built-in', 'Modern interface', 'Cloud-based'],
      limitations: ['Platform subscription', 'Template constraints', 'Less flexibility'],
      pricing: 'From $7,500 + GST (custom quote)',
      deliveryTime: '2-4 weeks',
      complexity: 'Simple to Moderate',
    },
  ];

  return tools.map(tool => ({
    params: { tool: tool.slug },
    props: { tool },
  }));
}

const { tool } = Astro.props;

import Layout from '../../components/layout/Layout.astro';
---

<Layout 
  title={`${tool.name} Development | Custom eLearning | The E-Learning Company`}
  description={`Professional ${tool.name} eLearning development. ${tool.description} Transparent pricing, expert developers.`}
>
  <!-- Hero Section -->
  <section class="tool-hero">
    <div class="container">
      <div class="breadcrumb">
        <a href="/">Home</a> / <a href="/tools">Tools</a> / <span>{tool.name}</span>
      </div>
      <h1 class="page-title">{tool.name} Development</h1>
      <p class="tool-tagline">{tool.tagline}</p>
      <p class="page-subtitle">{tool.description}</p>
      
      <div class="tool-meta">
        <div class="meta-item">
          <span class="meta-label">Pricing:</span>
          <span class="meta-value">{tool.pricing}</span>
        </div>
        <div class="meta-item">
          <span class="meta-label">Timeline:</span>
          <span class="meta-value">{tool.deliveryTime}</span>
        </div>
        <div class="meta-item">
          <span class="meta-label">Complexity:</span>
          <span class="meta-value">{tool.complexity}</span>
        </div>
      </div>

      <div class="hero-cta">
        <a href="/contact" class="btn-primary">Get a Quote</a>
        <a href="/pricing" class="btn-secondary">View Pricing</a>
      </div>
    </div>
  </section>

  <!-- Best For Section -->
  <section class="best-for-section">
    <div class="container">
      <h2 class="section-title">{tool.name} is Best For</h2>
      
      <div class="best-for-grid">
        {tool.bestFor.map((item) => (
          <div class="best-for-card">
            <span class="check-icon">✓</span>
            <span>{item}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Features & Limitations -->
  <section class="features-section">
    <div class="container">
      <div class="features-grid">
        <div class="features-column">
          <h2>Key Features</h2>
          <ul class="feature-list">
            {tool.features.map((feature) => (
              <li>
                <span class="feature-icon">✓</span>
                {feature}
              </li>
            ))}
          </ul>
        </div>

        <div class="features-column">
          <h2>Considerations</h2>
          <ul class="limitation-list">
            {tool.limitations.map((limitation) => (
              <li>
                <span class="limitation-icon">⚠️</span>
                {limitation}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- When to Choose This Tool -->
  <section class="when-section">
    <div class="container">
      <h2 class="section-title">When to Choose {tool.name}</h2>
      
      <div class="when-content">
        <div class="when-card good">
          <h3>✅ Choose {tool.name} When:</h3>
          <ul>
            {tool.bestFor.map((item) => (
              <li>You need {item.toLowerCase()}</li>
            ))}
            <li>You want professional, reliable development</li>
            <li>Timeline and budget are important</li>
          </ul>
        </div>

        <div class="when-card caution">
          <h3>⚠️ Consider Alternatives If:</h3>
          <ul>
            {tool.limitations.map((limitation) => (
              <li>{limitation} is a dealbreaker</li>
            ))}
            <li>You need features outside {tool.name}'s strengths</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Our Process -->
  <section class="process-section">
    <div class="container">
      <h2 class="section-title">Our {tool.name} Development Process</h2>
      
      <div class="process-steps">
        <div class="step">
          <div class="step-number">1</div>
          <h3>Requirements Gathering</h3>
          <p>We discuss your training needs, content, and technical requirements specific to {tool.name}.</p>
        </div>

        <div class="step-arrow">→</div>

        <div class="step">
          <div class="step-number">2</div>
          <h3>Development</h3>
          <p>We build your course in {tool.name}, leveraging its strengths for your specific use case.</p>
        </div>

        <div class="step-arrow">→</div>

        <div class="step">
          <div class="step-number">3</div>
          <h3>Review & Refinement</h3>
          <p>Unlimited revisions to ensure the course meets your expectations.</p>
        </div>

        <div class="step-arrow">→</div>

        <div class="step">
          <div class="step-number">4</div>
          <h3>Delivery</h3>
          <p>Published course with source files and deployment support.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="tool-pricing-section">
    <div class="container">
      <h2 class="section-title">{tool.name} Development Pricing</h2>
      <p class="section-subtitle">Transparent, fixed pricing based on complexity and content readiness</p>
      
      <div class="pricing-info-card">
        <h3>Starting at {tool.pricing}</h3>
        <p>Final pricing depends on:</p>
        <ul>
          <li>Content readiness (script ready vs. full creation)</li>
          <li>Course complexity and interactions</li>
          <li>Number of modules or lessons</li>
          <li>Custom requirements specific to {tool.name}</li>
        </ul>
        <a href="/contact" class="pricing-cta">Request Custom Quote</a>
      </div>
    </div>
  </section>

  <!-- Comparison -->
  <section class="comparison-section">
    <div class="container">
      <h2 class="section-title">Comparing Authoring Tools</h2>
      <p class="section-subtitle">Not sure if {tool.name} is right for you? Here's how it compares:</p>
      
      <div class="comparison-grid">
        <div class="comparison-card">
          <h4>Articulate Rise</h4>
          <p><strong>Best for:</strong> Fast, responsive, template-based courses</p>
          <a href="/tools/articulate-rise">Learn more →</a>
        </div>

        <div class="comparison-card">
          <h4>Articulate Storyline</h4>
          <p><strong>Best for:</strong> Complex interactions and custom scenarios</p>
          <a href="/tools/articulate-storyline">Learn more →</a>
        </div>

        <div class="comparison-card">
          <h4>Chameleon Creator</h4>
          <p><strong>Best for:</strong> SCORM-free web delivery</p>
          <a href="/tools/chameleon-creator">Learn more →</a>
        </div>

        <div class="comparison-card">
          <h4>Adobe Captivate</h4>
          <p><strong>Best for:</strong> Software simulations</p>
          <a href="/tools/adobe-captivate">Learn more →</a>
        </div>

        <div class="comparison-card">
          <h4>7Taps</h4>
          <p><strong>Best for:</strong> Mobile microlearning</p>
          <a href="/tools/7taps">Learn more →</a>
        </div>

        <div class="comparison-card">
          <h4>Coassemble</h4>
          <p><strong>Best for:</strong> Australian businesses with LMS needs</p>
          <a href="/tools/coassemble">Learn more →</a>
        </div>
      </div>

      <div class="comparison-note">
        <p>Need help choosing? <a href="/contact">Contact us</a> and we'll recommend the best tool for your specific needs.</p>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="tool-faq-section">
    <div class="container">
      <h2 class="section-title">Common {tool.name} Questions</h2>
      
      <div class="faq-list">
        <div class="faq-item">
          <h3>Do I need to purchase {tool.name}?</h3>
          <p>No. We have the licenses and expertise. You just receive the finished course files. If you want to make future updates yourself, you'd need your own license.</p>
        </div>

        <div class="faq-item">
          <h3>Can I see examples of {tool.name} courses you've built?</h3>
          <p>Yes! <a href="/portfolio">View our portfolio</a> or <a href="/contact">contact us</a> for examples specific to {tool.name} and your industry.</p>
        </div>

        <div class="faq-item">
          <h3>How long does {tool.name} development take?</h3>
          <p>Typically {tool.deliveryTime} from kickoff to final delivery, depending on complexity and content readiness.</p>
        </div>

        <div class="faq-item">
          <h3>Will the course work with our LMS?</h3>
          <p>We deliver in formats compatible with all major LMS platforms. We test before delivery to ensure compatibility.</p>
        </div>

        <div class="faq-item">
          <h3>Do you provide training on {tool.name}?</h3>
          <p>Our service is course development, not tool training. However, we can recommend resources if you want to learn {tool.name} yourself.</p>
        </div>

        <div class="faq-item">
          <h3>What if {tool.name} isn't the right tool for my project?</h3>
          <p>We'll tell you! During our discovery call, we'll recommend the best authoring tool for your specific needs, even if it's not {tool.name}.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="final-cta-section">
    <div class="container">
      <div class="cta-card">
        <h2>Ready to Build Your {tool.name} Course?</h2>
        <p>Get a fixed-price quote within 24 hours. We'll discuss your requirements and recommend the best approach.</p>
        <div class="cta-buttons">
          <a href="/contact" class="btn-primary">Request a Quote</a>
          <a href="/pricing" class="btn-secondary">View Pricing Guide</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Hero */
  .tool-hero {
    padding: 80px 0 60px;
    background: var(--bg-primary);
  }

  .breadcrumb {
    font-size: 0.9rem;
    color: var(--text-secondary);
    margin-bottom: 24px;
  }

  .breadcrumb a {
    color: var(--accent-primary);
    text-decoration: none;
  }

  .breadcrumb span {
    color: var(--text-primary);
  }

  .page-title {
    font-size: 3rem;
    font-weight: 800;
    margin-bottom: 16px;
  }

  .tool-tagline {
    font-size: 1.5rem;
    color: var(--accent-primary);
    margin-bottom: 16px;
    font-weight: 600;
  }

  .page-subtitle {
    font-size: 1.125rem;
    color: var(--text-secondary);
    margin-bottom: 32px;
    max-width: 800px;
  }

  .tool-meta {
    display: flex;
    gap: 32px;
    flex-wrap: wrap;
    margin-bottom: 32px;
  }

  .meta-item {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .meta-label {
    font-size: 0.875rem;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .meta-value {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--text-primary);
  }

  .hero-cta {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .btn-primary, .btn-secondary {
    padding: 14px 32px;
    border-radius: 10px;
    text-decoration: none;
    font-weight: 700;
    transition: all 0.3s ease;
  }

  .btn-primary {
    background: var(--accent-gradient);
    color: white;
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 24px rgba(99, 102, 241, 0.5);
  }

  .btn-secondary {
    background: var(--bg-tertiary);
    color: var(--text-primary);
    border: 2px solid var(--border-color);
  }

  .btn-secondary:hover {
    border-color: var(--accent-primary);
  }

  /* Sections */
  .best-for-section, .features-section, .when-section, .process-section, .tool-pricing-section, .comparison-section, .tool-faq-section {
    padding: 80px 0;
  }

  .best-for-section { background: var(--bg-secondary); }
  .features-section { background: var(--bg-primary); }
  .when-section { background: var(--bg-secondary); }
  .process-section { background: var(--bg-primary); }
  .tool-pricing-section { background: var(--bg-secondary); }
  .comparison-section { background: var(--bg-primary); }
  .tool-faq-section { background: var(--bg-secondary); }

  .section-title {
    font-size: 2.5rem;
    font-weight: 800;
    text-align: center;
    margin-bottom: 20px;
  }

  .section-subtitle {
    text-align: center;
    color: var(--text-secondary);
    font-size: 1.125rem;
    margin-bottom: 48px;
  }

  /* Best For */
  .best-for-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 24px;
  }

  .best-for-card {
    background: var(--bg-tertiary);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 24px;
    display: flex;
    align-items: center;
    gap: 16px;
    transition: all 0.3s ease;
  }

  .best-for-card:hover {
    border-color: var(--accent-primary);
    transform: translateY(-2px);
  }

  .check-icon {
    color: var(--accent-primary);
    font-size: 1.5rem;
    font-weight: 700;
    flex-shrink: 0;
  }

  /* Features */
  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: 48px;
    max-width: 1000px;
    margin: 0 auto;
  }

  .features-column h2 {
    font-size: 2rem;
    margin-bottom: 24px;
    font-weight: 700;
  }

  .feature-list, .limitation-list {
    list-style: none;
  }

  .feature-list li, .limitation-list li {
    padding: 16px;
    margin-bottom: 12px;
    background: var(--bg-tertiary);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .feature-icon {
    color: var(--accent-primary);
    font-weight: 700;
    flex-shrink: 0;
  }

  .limitation-icon {
    flex-shrink: 0;
  }

  /* When */
  .when-content {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: 32px;
    max-width: 1000px;
    margin: 0 auto;
  }

  .when-card {
    background: var(--bg-tertiary);
    border: 2px solid var(--border-color);
    border-radius: 16px;
    padding: 32px;
  }

  .when-card.good {
    border-color: var(--accent-primary);
    background: rgba(99, 102, 241, 0.05);
  }

  .when-card.caution {
    border-color: #f59e0b;
    background: rgba(245, 158, 11, 0.05);
  }

  .when-card h3 {
    font-size: 1.5rem;
    margin-bottom: 20px;
    font-weight: 700;
  }

  .when-card ul {
    list-style: none;
  }

  .when-card li {
    color: var(--text-secondary);
    padding-left: 24px;
    margin-bottom: 12px;
    position: relative;
  }

  .when-card li::before {
    content: '•';
    position: absolute;
    left: 8px;
    color: var(--accent-primary);
  }

  /* Process */
  .process-steps {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    max-width: 1100px;
    margin: 0 auto;
  }

  .step {
    flex: 1;
    text-align: center;
  }

  .step-number {
    background: var(--accent-gradient);
    color: white;
    width: 50px;
    height: 50px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 800;
    font-size: 1.5rem;
    margin: 0 auto 16px;
  }

  .step h3 {
    font-size: 1.25rem;
    margin-bottom: 12px;
    font-weight: 700;
  }

  .step p {
    color: var(--text-secondary);
    line-height: 1.6;
  }

  .step-arrow {
    color: var(--accent-primary);
    font-size: 2rem;
    font-weight: 700;
  }

  /* Tool Pricing */
  .pricing-info-card {
    background: linear-gradient(135deg, rgba(99, 102, 241, 0.1) 0%, rgba(139, 92, 246, 0.1) 100%);
    border: 2px solid var(--accent-primary);
    border-radius: 20px;
    padding: 48px;
    max-width: 700px;
    margin: 0 auto;
    text-align: center;
  }

  .pricing-info-card h3 {
    font-size: 2.5rem;
    font-weight: 800;
    margin-bottom: 24px;
    background: var(--accent-gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .pricing-info-card p {
    color: var(--text-secondary);
    margin-bottom: 16px;
    font-size: 1.125rem;
  }

  .pricing-info-card ul {
    list-style: none;
    margin-bottom: 32px;
    text-align: left;
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
  }

  .pricing-info-card li {
    color: var(--text-secondary);
    padding-left: 24px;
    margin-bottom: 12px;
    position: relative;
  }

  .pricing-info-card li::before {
    content: '✓';
    color: var(--accent-primary);
    position: absolute;
    left: 0;
    font-weight: 700;
  }

  .pricing-cta {
    display: inline-block;
    background: var(--accent-gradient);
    color: white;
    padding: 14px 32px;
    border-radius: 10px;
    text-decoration: none;
    font-weight: 700;
    transition: all 0.3s ease;
  }

  .pricing-cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 24px rgba(99, 102, 241, 0.5);
  }

  /* Comparison */
  .comparison-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 24px;
    margin-bottom: 32px;
  }

  .comparison-card {
    background: var(--bg-tertiary);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 24px;
    transition: all 0.3s ease;
  }

  .comparison-card:hover {
    border-color: var(--accent-primary);
    transform: translateY(-4px);
  }

  .comparison-card h4 {
    font-size: 1.125rem;
    margin-bottom: 12px;
    font-weight: 700;
  }

  .comparison-card p {
    color: var(--text-secondary);
    margin-bottom: 16px;
    font-size: 0.95rem;
  }

  .comparison-card a {
    color: var(--accent-primary);
    text-decoration: none;
    font-weight: 600;
  }

  .comparison-card a:hover {
    text-decoration: underline;
  }

  .comparison-note {
    text-align: center;
    padding: 24px;
    background: var(--bg-tertiary);
    border-radius: 12px;
    border: 2px dashed var(--border-color);
  }

  .comparison-note p {
