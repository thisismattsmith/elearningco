---
// src/pages/locations/[city].astro
// Location-specific landing pages for Australian capital cities (SEO)
import Layout from '../../components/layout/Layout.astro';

export async function getStaticPaths() {
  const cities = [
    {
      slug: 'sydney',
      name: 'Sydney',
      state: 'New South Wales',
      timezone: 'AEDT (UTC+11)',
      industries: ['Finance', 'Tech', 'Professional Services', 'Healthcare', 'Retail'],
      businessHub: "Australia's largest business centre with strong financial services and tech sectors.",
    },
    {
      slug: 'melbourne',
      name: 'Melbourne',
      state: 'Victoria',
      timezone: 'AEDT (UTC+11)',
      industries: ['Healthcare', 'Manufacturing', 'Retail', 'Education', 'Professional Services'],
      businessHub: 'Major corporate hub with diverse industries and strong L&D culture.',
    },
    {
      slug: 'brisbane',
      name: 'Brisbane',
      state: 'Queensland',
      timezone: 'AEST (UTC+10)',
      industries: ['Mining', 'Construction', 'Healthcare', 'Tourism', 'Government'],
      businessHub: 'Growing business centre with strong resources and government sectors.',
    },
    {
      slug: 'perth',
      name: 'Perth',
      state: 'Western Australia',
      timezone: 'AWST (UTC+8)',
      industries: ['Mining', 'Resources', 'Energy', 'Construction', 'Healthcare'],
      businessHub: 'Resources capital of Australia with strong mining and energy sectors.',
    },
    {
      slug: 'adelaide',
      name: 'Adelaide',
      state: 'South Australia',
      timezone: 'ACDT (UTC+10:30)',
      industries: ['Healthcare', 'Manufacturing', 'Defence', 'Agriculture', 'Education'],
      businessHub: 'Innovation hub with growing tech, defence, and healthcare sectors.',
    },
    {
      slug: 'canberra',
      name: 'Canberra',
      state: 'Australian Capital Territory',
      timezone: 'AEDT (UTC+11)',
      industries: ['Government', 'Defence', 'Education', 'Professional Services', 'Technology'],
      businessHub: 'Government and policy centre with strong compliance training needs.',
    },
    {
      slug: 'hobart',
      name: 'Hobart',
      state: 'Tasmania',
      timezone: 'AEDT (UTC+11)',
      industries: ['Tourism', 'Government', 'Healthcare', 'Agriculture', 'Education'],
      businessHub: 'Growing business community with strong tourism and government sectors.',
    },
  ];

  return cities.map(city => ({
    params: { city: city.slug },
    props: { city },
  }));
}

const { city } = Astro.props;
---

<Layout
  title={`eLearning Development ${city.name} | Custom Training Courses | The eLearning Company`}
  description={`Professional eLearning development for ${city.name} organisations. 3-week delivery, transparent pricing from $5,500 + GST. Serving ${city.state} businesses with custom training.`}
>
  <!-- ============================================================
       1. Hero — lilac
       ============================================================ -->
  <section class="section section--lilac location-hero">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span class="breadcrumb-sep">/</span>
        <a href="/locations">Locations</a>
        <span class="breadcrumb-sep">/</span>
        <span class="breadcrumb-current">{city.name}</span>
      </nav>

      <span class="pill-meta hero-pill">{city.state}</span>

      <h1 class="display display-lg page-title">
        eLearning development<br />
        in <span class="accent-blue">{city.name}</span>.
      </h1>
      <p class="lede page-subtitle">
        Professional custom eLearning courses for {city.name} organisations. Fixed pricing, 3-week delivery, no project management overhead.
      </p>

      <div class="hero-meta">
        <div class="hero-meta-item">
          <span class="meta meta-label">Working across</span>
          <span class="meta-value">{city.timezone}</span>
        </div>
        <div class="hero-meta-item">
          <span class="meta meta-label">Based in</span>
          <span class="meta-value">Australia</span>
        </div>
      </div>

      <div class="hero-cta">
        <a href="/contact" class="btn btn--primary">Get a quote</a>
        <a href="/pricing" class="btn btn--secondary">View pricing</a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       2. Why us — paper
       ============================================================ -->
  <section class="section section--paper why-us-section">
    <div class="container">
      <span class="section-kicker">Why choose us</span>
      <h2 class="display display-md section-title">
        Why {city.name} organisations<br />
        choose us.
      </h2>

      <div class="benefits-grid">
        <div class="benefit-item">
          <span class="meta benefit-num">01</span>
          <h3 class="heading-md">Australian based</h3>
          <p>We're based in Australia, understand {city.state} business culture, and work in your timezone.</p>
        </div>
        <div class="benefit-item">
          <span class="meta benefit-num">02</span>
          <h3 class="heading-md">Transparent pricing</h3>
          <p>From $5,500 + GST. All pricing published on our website — no surprises.</p>
        </div>
        <div class="benefit-item">
          <span class="meta benefit-num">03</span>
          <h3 class="heading-md">Fast delivery</h3>
          <p>3 weeks from kickoff to final course. Some {city.name} eLearning agencies can take 8-12 weeks.</p>
        </div>
        <div class="benefit-item">
          <span class="meta benefit-num">04</span>
          <h3 class="heading-md">Simple process</h3>
          <p>No complex project management. Clear communication and on-time delivery.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       3. Industries — paper-deep
       ============================================================ -->
  <section class="section section--paper-deep industries-section">
    <div class="container">
      <span class="section-kicker">Industries</span>
      <h2 class="display display-md section-title">
        Industries we serve<br />
        in {city.name}.
      </h2>
      <p class="lede section-subtitle">{city.businessHub}</p>

      <ul class="industries-grid">
        {city.industries.map((industry) => (
          <li class="industry-item">
            <span class="industry-marker" aria-hidden="true">→</span>
            <div>
              <h3 class="heading-sm industry-name">{industry}</h3>
              <p class="industry-desc">Custom training for {city.name}'s {industry.toLowerCase()} sector.</p>
            </div>
          </li>
        ))}
      </ul>

      <div class="all-industries-note">
        <p>We work with organisations across all industries in {city.name} and throughout {city.state}. Not seeing your sector? <a href="/contact" class="inline-link">Contact us</a> — we've likely worked with similar organisations.</p>
      </div>
    </div>
  </section>

  <!-- ============================================================
       4. Services — paper
       ============================================================ -->
  <section class="section section--paper services-section">
    <div class="container">
      <span class="section-kicker">Services</span>
      <h2 class="display display-md section-title">
        eLearning services for<br />
        {city.name} organisations.
      </h2>

      <div class="services-grid">
        <div class="service-card">
          <h3 class="heading-md service-name">Compliance training</h3>
          <ul class="service-list">
            <li>WHS &amp; safety inductions</li>
            <li>Sexual harassment prevention</li>
            <li>Cyber security awareness</li>
            <li>Privacy &amp; data protection</li>
            <li>Code of conduct</li>
          </ul>
          <a href="/training/workplace-health-safety" class="service-link">View compliance courses <span aria-hidden="true">→</span></a>
        </div>

        <div class="service-card">
          <h3 class="heading-md service-name">Onboarding &amp; culture</h3>
          <ul class="service-list">
            <li>New employee onboarding</li>
            <li>Company inductions</li>
            <li>Diversity &amp; inclusion</li>
            <li>Mental health awareness</li>
            <li>Remote work training</li>
          </ul>
          <a href="/training/new-employee-onboarding" class="service-link">View onboarding courses <span aria-hidden="true">→</span></a>
        </div>

        <div class="service-card">
          <h3 class="heading-md service-name">Skills development</h3>
          <ul class="service-list">
            <li>Customer service training</li>
            <li>Sales enablement</li>
            <li>Leadership development</li>
            <li>Communication skills</li>
            <li>Performance management</li>
          </ul>
          <a href="/training/customer-service" class="service-link">View skills courses <span aria-hidden="true">→</span></a>
        </div>

        <div class="service-card">
          <h3 class="heading-md service-name">Operational training</h3>
          <ul class="service-list">
            <li>Product training</li>
            <li>Software &amp; system training</li>
            <li>Process &amp; procedures</li>
            <li>Quality management</li>
            <li>Change management</li>
          </ul>
          <a href="/training/product-training" class="service-link">View operational courses <span aria-hidden="true">→</span></a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       5. Pricing — paper
       ============================================================ -->
  <section class="section section--paper pricing-section">
    <div class="container">
      <span class="section-kicker">Pricing</span>
      <h2 class="display display-md section-title">
        Transparent pricing for<br />
        {city.name} organisations.
      </h2>
      <p class="lede section-subtitle">
        Fixed pricing with no hidden costs. Choose the tier that matches your content readiness.
      </p>

      <div class="pricing-cards">
        <div class="price-card">
          <div class="tier-badge">Tier 1</div>
          <h3 class="heading-md price-name">Content ready</h3>
          <div class="price">
            <span class="price-amount">$5,500</span>
            <span class="price-gst">+ GST</span>
          </div>
          <p class="price-desc">You have a complete script ready to build.</p>
          <a href="/pricing" class="btn btn--secondary price-btn">Learn more</a>
        </div>

        <div class="price-card">
          <div class="tier-badge">Tier 2</div>
          <h3 class="heading-md price-name">Content needs shaping</h3>
          <div class="price">
            <span class="price-amount">$7,500</span>
            <span class="price-gst">+ GST</span>
          </div>
          <p class="price-desc">You have content materials that need structuring.</p>
          <a href="/pricing" class="btn btn--secondary price-btn">Learn more</a>
        </div>

        <div class="price-card">
          <div class="tier-badge">Tier 3</div>
          <h3 class="heading-md price-name">Start from scratch</h3>
          <div class="price">
            <span class="price-amount">$10,500</span>
            <span class="price-gst">+ GST</span>
          </div>
          <p class="price-desc">We create everything from scratch, using your expertise.</p>
          <a href="/pricing" class="btn btn--secondary price-btn">Learn more</a>
        </div>
      </div>

      <div class="pricing-note">
        <p><strong>All prices in AUD + GST.</strong> Competitive rates for {city.name} organisations.</p>
      </div>
    </div>
  </section>

  <!-- ============================================================
       6. Process — turquoise (process role)
       ============================================================ -->
  <section class="section section--turquoise process-section">
    <div class="container">
      <span class="section-kicker">Our process</span>
      <h2 class="display display-md section-title">
        Our simple process<br />
        for {city.name} clients.
      </h2>

      <div class="process-steps">
        <div class="step">
          <div class="step-number">01</div>
          <h3 class="heading-sm">Get a quote</h3>
          <p>Contact us for a fixed-price quote. We respond within 24 hours.</p>
        </div>
        <div class="step">
          <div class="step-number">02</div>
          <h3 class="heading-sm">Kickoff</h3>
          <p>We gather requirements and align on objectives.</p>
        </div>
        <div class="step">
          <div class="step-number">03</div>
          <h3 class="heading-sm">We build</h3>
          <p>First draft delivered in 1 week. You review and provide feedback.</p>
        </div>
        <div class="step">
          <div class="step-number">04</div>
          <h3 class="heading-sm">Final delivery</h3>
          <p>Unlimited revisions in weeks 2 and 3. SCORM package delivered end of week 3.</p>
        </div>
      </div>

      <div class="process-note">
        <p><strong>Total time investment from {city.name} teams:</strong> 3-5 hours over 3 weeks. We handle the heavy lifting.</p>
      </div>
    </div>
  </section>

  <!-- ============================================================
       7. Local presence — paper
       ============================================================ -->
  <section class="section section--paper local-section">
    <div class="container">
      <span class="section-kicker">Working remotely</span>
      <h2 class="display display-md section-title">
        Working with<br />
        {city.name} organisations.
      </h2>

      <div class="local-content">
        <div class="local-card">
          <span class="meta local-num">01</span>
          <h3 class="heading-sm">Remote-first, Australia-based</h3>
          <p>While we're based in Victoria, we work with organisations across Australia including {city.name}. All meetings are conducted via Zoom or Microsoft Teams, making collaboration seamless regardless of location.</p>
        </div>

        <div class="local-card">
          <span class="meta local-num">02</span>
          <h3 class="heading-sm">Understanding {city.state} business</h3>
          <p>We understand Australian business culture, compliance requirements, and workplace standards. Our team has worked with organisations throughout {city.state} over the last 15+ years and knows what {city.name} businesses need.</p>
        </div>

        <div class="local-card">
          <span class="meta local-num">03</span>
          <h3 class="heading-sm">Flexible communication</h3>
          <p>We work across {city.timezone} and can schedule calls to suit {city.name} business hours. Email, phone, or video calls — whatever works best for your team.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       8. FAQ — navy
       ============================================================ -->
  <section class="section section--navy location-faq-section">
    <div class="container">
      <span class="section-kicker">FAQ</span>
      <h2 class="heading-xl section-title">
        Common questions from {city.name} organisations.
      </h2>

      <div class="faq-grid">
        <div class="faq-item content-card">
          <h3 class="heading-sm">Do you work with organisations in {city.name}?</h3>
          <p>Yes. While we're based in Victoria, we work with clients across Australia including {city.name}. All collaboration is done remotely via Zoom/Teams, and we're experienced working across Australian time zones.</p>
        </div>

        <div class="faq-item content-card">
          <h3 class="heading-sm">Can you meet in person in {city.name}?</h3>
          <p>Our process is designed to be entirely remote, which keeps costs down and timelines fast. We've found that video calls are just as effective for kickoffs and reviews. If in-person meetings are essential, we can discuss options for an additional travel fee.</p>
        </div>

        <div class="faq-item content-card">
          <h3 class="heading-sm">How is your pricing compared to {city.name} agencies?</h3>
          <p>We're typically 50-65% less than other {city.name} eLearning agencies, with faster delivery (3 weeks vs 5-12 weeks). Our lean, remote-first operation means lower overhead and better value for you.</p>
        </div>

        <div class="faq-item content-card">
          <h3 class="heading-sm">Do you understand {city.state} compliance requirements?</h3>
          <p>Yes. We develop compliance training for organisations across Australia and are familiar with Australian workplace legislation, WHS requirements, and industry-specific regulations applicable in {city.state}.</p>
        </div>

        <div class="faq-item content-card">
          <h3 class="heading-sm">What if we need changes after delivery?</h3>
          <p>We provide unlimited revisions during weeks 2 and 3 of development. This period can be extended if you need more time — just let us know when you get in touch. If you need to make changes months or years later we can provide a quote, or you can use the source files we provide to make updates yourself.</p>
        </div>

        <div class="faq-item content-card">
          <h3 class="heading-sm">Can you work with our LMS?</h3>
          <p>Yes. We deliver SCORM 1.2 and 2004 packages that work with virtually all LMS platforms (Moodle, Canvas, Cornerstone, SAP SuccessFactors, Workday Learning, Docebo, etc.).</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       9. Final CTA — lilac
       ============================================================ -->
  <section class="section section--lilac final-cta-section">
    <div class="container">
      <div class="cta-content">
        <h2 class="display display-lg cta-title">
          Ready to<br />
          <span class="accent-blue">get started?</span>
        </h2>
        <p class="lede cta-text">
          Get a fixed-price quote for your {city.name} eLearning project within 24 hours.
        </p>
        <div class="cta-buttons">
          <a href="/contact" class="btn btn--primary">Request a quote</a>
          <a href="/pricing" class="btn btn--secondary">View full pricing</a>
        </div>
        <p class="cta-note">
          <span class="meta">Serving organisations throughout {city.name} and {city.state}</span>
        </p>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ============================================================
     Page-specific styles only.
     ============================================================ */

  /* ---- 1. Hero ---- */
  .location-hero {
    padding-top: clamp(56px, 7vw, 80px);
    padding-bottom: clamp(80px, 10vw, 120px);
  }

  .breadcrumb {
    font-family: var(--font-mono);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--c-ink);
    opacity: 0.7;
    margin-bottom: 32px;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 6px;
  }
  .breadcrumb a {
    color: var(--c-ink);
    text-decoration: none;
    transition: opacity 0.15s ease;
  }
  .breadcrumb a:hover { opacity: 0.5; }
  .breadcrumb-sep { opacity: 0.5; }
  .breadcrumb-current { opacity: 0.6; }

  .hero-pill { margin-bottom: 24px; }
  .page-title { margin-bottom: 24px; max-width: 1000px; }
  .page-subtitle { margin-bottom: 40px; max-width: 640px; }

  .hero-meta {
    display: flex;
    gap: 48px;
    margin-bottom: 40px;
    flex-wrap: wrap;
    padding: 20px 0;
    border-top: 1px solid rgba(21, 25, 46, 0.15);
    border-bottom: 1px solid rgba(21, 25, 46, 0.15);
    max-width: 720px;
  }
  .hero-meta-item {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .meta-label { color: var(--c-ink-muted); }
  .meta-value {
    font-family: var(--font-sans);
    font-size: 16px;
    font-weight: 600;
    color: var(--c-ink);
  }

  .hero-cta { display: flex; gap: 12px; flex-wrap: wrap; }

  /* ---- 2. Why us — benefits grid ---- */
  .why-us-section .section-title { margin-bottom: 64px; max-width: 720px; }
  .benefits-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 40px;
  }
  .benefit-num {
    display: block;
    color: var(--c-ink-muted);
    margin-bottom: 14px;
  }
  .benefit-item h3 { margin-bottom: 10px; font-size: 22px; }
  .benefit-item p {
    color: var(--c-ink-soft);
    line-height: 1.6;
    font-size: 15px;
  }

  /* ---- 3. Industries ---- */
  .industries-section .section-title { margin-bottom: 16px; max-width: 800px; }
  .industries-section .section-subtitle { margin-bottom: 56px; }

  .industries-grid {
    list-style: none;
    padding: 0;
    margin: 0 0 48px 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
  }
  .industry-item {
    display: flex;
    gap: 16px;
    padding: 20px 0;
    border-bottom: 1px solid rgba(21, 25, 46, 0.08);
    align-items: flex-start;
  }
  /* For two-column layout we still want the bottom border between rows.
     Last 2 items in a row of 2 lose their border. Handle with nth */
  .industry-marker {
    font-family: var(--font-mono);
    color: var(--c-ink-muted);
    flex-shrink: 0;
    padding-top: 4px;
  }
  .industry-name {
    font-size: 18px;
    margin-bottom: 4px;
  }
  .industry-desc {
    color: var(--c-ink-soft);
    font-size: 14px;
    line-height: 1.55;
  }

  .all-industries-note {
    padding: 24px 0 0;
    border-top: 1px solid rgba(21, 25, 46, 0.08);
  }
  .all-industries-note p {
    font-size: 15px;
    line-height: 1.6;
    color: var(--c-ink-soft);
    max-width: 800px;
  }
  .inline-link {
    color: var(--c-blue);
    text-decoration: none;
    border-bottom: 1px solid currentColor;
    font-weight: 500;
  }
  .inline-link:hover { color: var(--c-ink); }

  /* ---- 4. Services ---- */
  .services-section .section-title { margin-bottom: 56px; max-width: 800px; }
  .services-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }
  .service-card {
    background: var(--c-paper-deep);
    border: 1px solid rgba(21, 25, 46, 0.06);
    border-radius: var(--r-lg);
    padding: 32px;
    display: flex;
    flex-direction: column;
    transition: border-color 0.2s ease;
  }
  .service-card:hover { border-color: var(--c-ink); }
  .service-name { margin-bottom: 20px; font-size: 20px; }
  .service-list {
    list-style: none;
    padding: 0;
    margin: 0 0 24px 0;
    flex: 1;
  }
  .service-list li {
    padding: 6px 0 6px 22px;
    position: relative;
    font-size: 15px;
    line-height: 1.5;
    color: var(--c-ink-soft);
  }
  .service-list li::before {
    content: "→";
    position: absolute;
    left: 0;
    color: var(--c-ink-muted);
    font-family: var(--font-mono);
  }
  .service-link {
    color: var(--c-blue);
    text-decoration: none;
    font-size: 14px;
    font-weight: 500;
    transition: color 0.15s ease;
    margin-top: auto;
  }
  .service-link:hover { color: var(--c-ink); }

  /* ---- 5. Pricing ---- */
  .pricing-section .section-title { margin-bottom: 16px; }
  .pricing-section .section-subtitle { margin-bottom: 56px; }

  .pricing-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-bottom: 32px;
  }
  .price-card {
    background: var(--c-paper);
    border: 1px solid rgba(21, 25, 46, 0.08);
    border-radius: var(--r-lg);
    padding: 32px 28px;
    display: flex;
    flex-direction: column;
    transition: border-color 0.2s ease;
  }
  .price-card:hover { border-color: var(--c-ink); }
  .tier-badge {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--c-ink-muted);
    margin-bottom: 16px;
  }
  .price-name {
    margin-bottom: 16px;
    font-size: 22px;
    line-height: 1.2;
  }
  .price {
    display: flex;
    align-items: baseline;
    gap: 6px;
    margin-bottom: 14px;
  }
  .price-amount {
    font-family: var(--font-display);
    font-size: 40px;
    line-height: 1;
    color: var(--c-ink);
    letter-spacing: -0.02em;
  }
  .price-gst {
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--c-ink-muted);
  }
  .price-desc {
    font-size: 14px;
    line-height: 1.5;
    color: var(--c-ink-soft);
    margin-bottom: 24px;
    flex: 1;
  }
  .price-btn {
    width: 100%;
    margin-top: auto;
  }

  .pricing-note {
    text-align: center;
    font-size: 15px;
    color: var(--c-ink-soft);
  }
