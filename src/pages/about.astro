---
// src/pages/about.astro
import Layout from '../components/layout/Layout.astro';
---

<Layout
  title="How We Build eLearning Without the Drama | The eLearning Company"
  description="Learn about our streamlined 3-week process for custom eLearning development. 15+ years of experience, transparent pricing, and zero project management overhead."
>
  <!-- ============================================================
       1. Hero — paper · asymmetric, big title left, narrow subtitle right
       ============================================================ -->
  <section class="section section--paper about-hero">
    <div class="container hero-grid">
      <div class="hero-headline-col">
        <span class="pill-meta hero-pill">About us</span>
        <h1 class="display display-xl hero-title">
          How we build<br />
          eLearning<br />
          without the<br />
          <span class="accent-blue">drama.</span>
        </h1>
      </div>
      <div class="hero-aside-col">
        <p class="lede hero-subtitle">
          We've built over 200 courses for Australian organisations. Along the way, we learned that most L&amp;D teams don't need another complex agency relationship — they need a reliable partner who delivers on time and on budget.
        </p>
        <div class="hero-meta">
          <span class="meta hero-meta-line">Est. as a different kind of agency</span>
          <span class="meta hero-meta-line">Operating across Australia</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       2. Why we started — paper, editorial single column
       ============================================================ -->
  <section class="section section--paper story-section">
    <div class="container">
      <div class="story-grid">
        <div class="story-aside">
          <span class="meta story-aside-label">The story</span>
          <span class="display display-md story-aside-num">01</span>
        </div>
        <div class="story-content">
          <h2 class="heading-xl story-title">Why we started this.</h2>

          <p class="story-lede">After 15+ years building eLearning for Australian organisations, we kept hearing the same thing: "We just want a good course, delivered on time, at a fair price."</p>

          <p>So we built the company that does exactly that.</p>

          <p>L&amp;D teams told us what mattered to them:</p>
          <ul class="story-list">
            <li>Professional courses that actually work for their learners</li>
            <li>Clear pricing from day one — no surprises</li>
            <li>Fast delivery without sacrificing quality</li>
            <li>Minimal time investment from their already-stretched teams</li>
          </ul>

          <p>So we built a streamlined service around those four things. Custom eLearning in 3 weeks. Transparent pricing. A process that respects your time.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       3. PULL QUOTE — lilac · single statement, full breath
       ============================================================ -->
  <section class="section section--lilac pull-quote-section">
    <div class="container">
      <p class="display display-lg pull-quote">
        We won't <span class="mark--turquoise">win awards.</span><br />
        We'll just <span class="accent-blue">ship the course.</span>
      </p>
    </div>
  </section>

  <!-- ============================================================
       4. What makes us different — paper · 2-col asymmetric
       ============================================================ -->
  <section class="section section--paper different-section">
    <div class="container">
      <div class="different-header">
        <span class="section-kicker">What makes us different</span>
        <h2 class="display display-md different-title">
          Four things<br />
          most agencies aren't.
        </h2>
      </div>

      <div class="different-grid">
        <div class="different-card">
          <span class="meta different-num">01</span>
          <h3 class="heading-md">We're transparent.</h3>
          <p>No hidden costs. No vague timelines. No "it depends." All our pricing is published on our website. What we quote is what you pay.</p>
        </div>

        <div class="different-card">
          <span class="meta different-num">02</span>
          <h3 class="heading-md">We're efficient.</h3>
          <p>We've stripped out unnecessary meetings, endless revision cycles, and project management overhead. What remains is a streamlined process that works.</p>
        </div>

        <div class="different-card">
          <span class="meta different-num">03</span>
          <h3 class="heading-md">We're practical.</h3>
          <p>We deliver what works, not what wins design awards. Effective learning over fancy features. Professional quality without unnecessary complexity.</p>
        </div>

        <div class="different-card">
          <span class="meta different-num">04</span>
          <h3 class="heading-md">We're reliable.</h3>
          <p>We say 3 weeks, we deliver in 3 weeks. No excuses, no delays. We've built a process that's predictable and repeatable.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       5. Process in detail — paper-deep · 5-step timeline (calm/utility)
       ============================================================ -->
  <section class="section section--paper-deep process-detail-section">
    <div class="container">
      <span class="section-kicker">The process, step by step</span>
      <h2 class="display display-md section-title">Our 3-week process in detail.</h2>

      <div class="process-timeline">
        <div class="timeline-item">
          <div class="timeline-marker">
            <span class="marker-number">01</span>
          </div>
          <div class="timeline-content">
            <h3 class="heading-md">Initial contact &amp; scoping</h3>
            <dl class="timeline-details">
              <dt>What happens</dt>
              <dd>You submit a quote request or contact us directly.</dd>
              <dt>Response time</dt>
              <dd>Within 24 hours (usually much faster).</dd>
              <dt>Discovery call</dt>
              <dd>Quick 15-20 minute call to understand your needs.</dd>
              <dt>Quote delivery</dt>
              <dd>Fixed-price quote provided immediately after call.</dd>
              <dt>Your time investment</dt>
              <dd>15-20 minutes.</dd>
            </dl>
          </div>
        </div>

        <div class="timeline-item">
          <div class="timeline-marker">
            <span class="marker-number">02</span>
          </div>
          <div class="timeline-content">
            <h3 class="heading-md">Project kickoff (Week 1, Day 1)</h3>
            <dl class="timeline-details">
              <dt>What happens</dt>
              <dd>You accept the quote.</dd>
              <dt>Kickoff call</dt>
              <dd>30-min structured call to gather everything we need.</dd>
              <dt>We discuss</dt>
              <dd>
                Learning objectives and success criteria, target audience and their context, content review, visual style preferences and branding, assessment approach and pass criteria, delivery timeline confirmation.
              </dd>
              <dt>Your time investment</dt>
              <dd>30 minutes.</dd>
            </dl>
          </div>
        </div>

        <div class="timeline-item">
          <div class="timeline-marker">
            <span class="marker-number">03</span>
          </div>
          <div class="timeline-content">
            <h3 class="heading-md">First draft development (Week 1)</h3>
            <dl class="timeline-details">
              <dt>What we do</dt>
              <dd>Build the complete first draft of your course.</dd>
              <dt>What you do</dt>
              <dd>Nothing. We work independently.</dd>
              <dt>Delivery</dt>
              <dd>By start of Week 2.</dd>
              <dt>Format</dt>
              <dd>You receive a review link to access the course.</dd>
              <dt>Your time investment</dt>
              <dd>Zero during this phase.</dd>
            </dl>
          </div>
        </div>

        <div class="timeline-item">
          <div class="timeline-marker">
            <span class="marker-number">04</span>
          </div>
          <div class="timeline-content">
            <h3 class="heading-md">Review &amp; revisions (Weeks 2-3)</h3>
            <dl class="timeline-details">
              <dt>How it works</dt>
              <dd>Unlimited revisions during this 2-week window.</dd>
              <dt>Review process</dt>
              <dd>
                Access course via review link we provide. Involve as many reviewers as needed (no extra cost). All feedback submitted via review link (keeps it organised). One designated decision-maker to resolve conflicts.
              </dd>
              <dt>Revision turnaround</dt>
              <dd>We update as you leave feedback so you can always see the most up-to-date version.</dd>
              <dt>Most common</dt>
              <dd>Clients only need 1-2 revision rounds.</dd>
              <dt>Your time investment</dt>
              <dd>1-3 hours total for reviews.</dd>
            </dl>
          </div>
        </div>

        <div class="timeline-item">
          <div class="timeline-marker">
            <span class="marker-number">05</span>
          </div>
          <div class="timeline-content">
            <h3 class="heading-md">Final delivery (End of Week 3)</h3>
            <dl class="timeline-details">
              <dt>What you receive</dt>
              <dd>SCORM 1.2 and 2004 packages (tested), source files and transfer of project, any additional assets used.</dd>
              <dt>Payment</dt>
              <dd>We invoice at project commencement with payment terms of 14 days. This can be adjusted depending on your needs or procurement policy.</dd>
            </dl>
          </div>
        </div>
      </div>

      <div class="process-summary">
        <span class="meta process-summary-label">Total time investment from you</span>
        <p class="display display-md process-summary-value">
          3-5 hours.<br />
          <span class="accent-blue">That's it.</span>
        </p>
        <p class="process-summary-text">We handle the heavy lifting.</p>
      </div>
    </div>
  </section>

  <!-- ============================================================
       6. Who we work with — paper · 4-card row
       ============================================================ -->
  <section class="section section--paper clients-section">
    <div class="container">
      <span class="section-kicker">Who we work with</span>
      <h2 class="heading-xl section-title">A few things in common.</h2>

      <div class="clients-grid">
        <div class="client-card">
          <span class="meta client-num">01</span>
          <h3 class="heading-sm">Organisations</h3>
          <p>Mid to large Australian organisations (200-2000 employees) across all industries.</p>
        </div>
        <div class="client-card">
          <span class="meta client-num">02</span>
          <h3 class="heading-sm">Teams</h3>
          <p>HR departments, L&amp;D teams, People &amp; Culture functions — anyone responsible for training.</p>
        </div>
        <div class="client-card">
          <span class="meta client-num">03</span>
          <h3 class="heading-sm">Situations</h3>
          <p>New to eLearning, scaling training programs, or just lost your internal eLearning person.</p>
        </div>
        <div class="client-card">
          <span class="meta client-num">04</span>
          <h3 class="heading-sm">Values</h3>
          <p>Organisations that value efficiency, transparency, and getting things done without drama.</p>
        </div>
      </div>

      <div class="industries-note">
        <span class="meta industries-label">Industries we've served</span>
        <p class="industries-list">
          Healthcare · Finance · Retail · Construction · Technology · Government · Manufacturing · Education · Professional Services · Hospitality · Agriculture · Mining · Energy · Transport · And more.
        </p>
      </div>
    </div>
  </section>

  <!-- ============================================================
       7. Our guarantee — yellow · 6-card row, confident commitments
       ============================================================ -->
  <section class="section section--yellow guarantee-section">
    <div class="container">
      <div class="guarantee-header">
        <span class="section-kicker">Our guarantee to you</span>
        <h2 class="display display-md guarantee-title">
          Six things we<br />
          actually mean.
        </h2>
      </div>

      <div class="guarantees-grid">
        <div class="guarantee-item">
          <span class="meta guarantee-num">01</span>
          <h4 class="heading-sm">3-week delivery</h4>
          <p>We commit to 3 weeks from kickoff.</p>
        </div>
        <div class="guarantee-item">
          <span class="meta guarantee-num">02</span>
          <h4 class="heading-sm">Fixed pricing</h4>
          <p>What we quote is what you pay. No scope creep, no surprise fees, no exceptions.</p>
        </div>
        <div class="guarantee-item">
          <span class="meta guarantee-num">03</span>
          <h4 class="heading-sm">Unlimited revisions</h4>
          <p>During weeks 2 and 3, we'll revise as many times as needed until you're happy.</p>
        </div>
        <div class="guarantee-item">
          <span class="meta guarantee-num">04</span>
          <h4 class="heading-sm">Source files included</h4>
          <p>You get the source files. You own your course completely.</p>
        </div>
        <div class="guarantee-item">
          <span class="meta guarantee-num">05</span>
          <h4 class="heading-sm">Quality assurance</h4>
          <p>Every course is tested before delivery. We catch issues before you do.</p>
        </div>
        <div class="guarantee-item">
          <span class="meta guarantee-num">06</span>
          <h4 class="heading-sm">Clear communication</h4>
          <p>Responses within 24 hours. No ghosting, no waiting days for answers.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       8. Approach to quality — paper · 3 paragraphs editorial
       ============================================================ -->
  <section class="section section--paper quality-section">
    <div class="container">
      <div class="quality-grid">
        <div class="quality-aside">
          <span class="meta quality-aside-label">Our approach to quality</span>
          <span class="display display-md quality-aside-num">02</span>
        </div>
        <div class="quality-content">
          <h2 class="heading-xl quality-title">Effective over impressive.</h2>

          <div class="quality-item">
            <h3 class="heading-sm">Effective learning design</h3>
            <p>We focus on learning outcomes, not feature lists. Clean structure, clear objectives, appropriate interactivity. Adult learning principles applied consistently.</p>
          </div>

          <div class="quality-item">
            <h3 class="heading-sm">Professional visual design</h3>
            <p>Modern, clean design using contemporary templates and styling. Professional stock imagery. Consistent branding. Responsive across all devices.</p>
          </div>

          <div class="quality-item">
            <h3 class="heading-sm">Why this approach works</h3>
            <p>Learners care about clear, effective training they can complete quickly. Stakeholders care about results and ROI. Nobody needs custom animations to learn workplace safety.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       9. Experience stats — navy · asymmetric stat grid
       ============================================================ -->
  <section class="section section--navy experience-section">
    <div class="container">
      <span class="section-kicker">Our experience</span>
      <h2 class="display display-lg section-title">
        The numbers,<br />
        such as they are.
      </h2>

      <div class="experience-stats">
        <div class="stat-card stat-card--large">
          <span class="meta stat-label">Years of experience</span>
          <span class="display display-xl stat-number">15+</span>
        </div>
        <div class="stat-card stat-card--large">
          <span class="meta stat-label">Courses delivered</span>
          <span class="display display-xl stat-number">200+</span>
        </div>
        <div class="stat-card">
          <span class="meta stat-label">Training categories</span>
          <span class="display display-md stat-number">25+</span>
        </div>
        <div class="stat-card">
          <span class="meta stat-label">Week delivery</span>
          <span class="display display-md stat-number">3</span>
        </div>
      </div>

      <div class="experience-content">
        <p>We've developed eLearning across every industry. Compliance training for healthcare. Safety training for construction. Onboarding for tech startups. Product training for retail. Sales enablement for finance.</p>
        <p>What we've learned: good instructional design transcends industry. The principles of effective learning are universal. What matters is understanding your content and your audience — not having built 50 courses in your exact sub-sector.</p>
      </div>
    </div>
  </section>

  <!-- ============================================================
       10. Final CTA — lilac · simple closer
       ============================================================ -->
  <section class="section section--lilac final-cta-section">
    <div class="container">
      <div class="cta-content">
        <h2 class="display display-lg cta-title">
          Ready to<br />
          <span class="accent-blue">work together?</span>
        </h2>
        <p class="lede cta-text">
          Let's start talking about your training needs.
        </p>
        <div class="cta-buttons">
          <a href="/contact" class="btn btn--primary">Get a quote</a>
          <a href="/pricing" class="btn btn--secondary">View pricing</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ============================================================
     Page-specific styles only.
     All tokens, primitives, and shared components live in global.css.

     This page leans into asymmetric layouts (per Matt's brief).
     Each section earns its asymmetry — never decorative.
     ============================================================ */

  /* ---- 1. Hero — asymmetric 2-column grid ---- */
  .about-hero { padding-top: clamp(80px, 10vw, 120px); padding-bottom: clamp(80px, 10vw, 120px); }
  .hero-grid {
    display: grid;
    grid-template-columns: 1.4fr 0.8fr;
    gap: clamp(40px, 6vw, 96px);
    align-items: end;
  }
  .hero-headline-col { }
  .hero-pill { margin-bottom: 32px; }
  .hero-title { margin: 0; }

  .hero-aside-col {
    padding-bottom: 16px;
  }
  .hero-subtitle { margin-bottom: 24px; }
  .hero-meta {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding-top: 20px;
    border-top: 1px solid rgba(21, 25, 46, 0.12);
  }
  .hero-meta-line {
    color: var(--c-ink-muted);
  }

  /* ---- 2. Why we started — editorial with section number aside ---- */
  .story-section { padding-top: clamp(80px, 10vw, 120px); padding-bottom: clamp(80px, 10vw, 120px); }
  .story-grid {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: clamp(32px, 6vw, 80px);
    align-items: start;
  }
  .story-aside {
    position: sticky;
    top: 100px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding-top: 4px;
  }
  .story-aside-label { color: var(--c-ink-muted); }
  .story-aside-num {
    color: var(--c-ink);
    opacity: 0.18;
    line-height: 0.9;
  }

  .story-content { max-width: 700px; }
  .story-title { margin-bottom: 32px; }
  .story-lede {
    font-size: clamp(18px, 1.6vw, 22px);
    line-height: 1.55;
    color: var(--c-ink);
    margin-bottom: 24px;
    font-weight: 500;
  }
  .story-content p {
    font-size: 17px;
    line-height: 1.7;
    color: var(--c-ink-soft);
    margin-bottom: 20px;
  }
  .story-list {
    list-style: none;
    padding: 0;
    margin: 8px 0 24px 0;
  }
  .story-list li {
    padding: 6px 0 6px 24px;
    position: relative;
    font-size: 17px;
    line-height: 1.55;
    color: var(--c-ink-soft);
  }
  .story-list li::before {
    content: "→";
    position: absolute;
    left: 0;
    color: var(--c-ink-muted);
    font-family: var(--font-mono);
  }

  /* ---- 3. Pull quote — single statement, breathe ---- */
  .pull-quote-section {
    padding-top: clamp(96px, 12vw, 160px);
    padding-bottom: clamp(96px, 12vw, 160px);
  }
  .pull-quote {
    max-width: 1000px;
    color: var(--c-ink);
    line-height: 1;
  }

  /* ---- 4. What makes us different — header + grid ---- */
  .different-section { padding-top: clamp(80px, 10vw, 120px); padding-bottom: clamp(80px, 10vw, 120px); }
  .different-header {
    margin-bottom: 64px;
    max-width: 900px;
  }
  .different-header .section-kicker { margin-bottom: 16px; }
  .different-title { margin: 0; }

  .different-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 48px 64px;
  }
  .different-card { }
  .different-num {
    display: block;
    color: var(--c-ink-muted);
    margin-bottom: 14px;
  }
  .different-card h3 { margin-bottom: 12px; }
  .different-card p {
    color: var(--c-ink-soft);
    line-height: 1.65;
    font-size: 16px;
    max-width: 460px;
  }

  /* ---- 5. Process timeline — calm utility layout ---- */
  .process-detail-section .section-title { margin-bottom: 64px; }
  .process-timeline {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-bottom: 64px;
  }
  .timeline-item {
    display: grid;
    grid-template-columns: 100px 1fr;
    gap: 24px;
    background: var(--c-paper);
    border: 1px solid rgba(21, 25, 46, 0.06);
    border-radius: var(--r-lg);
    padding: 32px;
    align-items: start;
  }
  .timeline-marker {
    display: flex;
    align-items: center;
    justify-content: center;
    aspect-ratio: 1;
    width: 64px;
    background: var(--c-ink);
    color: var(--c-paper);
    border-radius: 50%;
  }
  .marker-number {
    font-family: var(--font-mono);
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.05em;
  }
  .timeline-content h3 { margin-bottom: 20px; }
  .timeline-details {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 12px 32px;
    margin: 0;
  }
  .timeline-details dt {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--c-ink-muted);
    padding-top: 4px;
  }
  .timeline-details dd {
    margin: 0;
    color: var(--c-ink-soft);
    line-height: 1.6;
    font-size: 15px;
  }

  .process-summary {
    background: var(--c-paper);
    border: 1px solid rgba(21, 25, 46, 0.08);
    border-radius: var(--r-lg);
    padding: 40px;
    text-align: center;
  }
  .process-summary-label {
    display: block;
    color: var(--c-ink-muted);
    margin-bottom: 16px;
  }
  .process-summary-value {
    color: var(--c-ink);
    margin: 0 0 16px 0;
    line-height: 1;
  }
  .process-summary-text {
    color: var(--c-ink-soft);
    font-size: 17px;
  }

  /* ---- 6. Who we work with ---- */
  .clients-section .section-title { margin-bottom: 56px; }
  .clients-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 40px;
    margin-bottom: 64px;
  }
  .client-num {
    display: block;
    color: var(--c-ink-muted);
    margin-bottom: 14px;
  }
  .client-card h3 { margin-bottom: 10px; }
  .client-card p {
    color: var(--c-ink-soft);
    line-height: 1.6;
    font-size: 15px;
  }

  .industries-note {
    padding-top: 40px;
    border-top: 1px solid rgba(21, 25, 46, 0.08);
  }
  .industries-label {
    display: block;
    color: var(--c-ink-muted);
    margin-bottom: 12px;
  }
  .industries-list {
    font-size: clamp(17px, 1.5vw, 20px);
    line-height: 1.6;
    color: var(--c-ink);
    max-width: 900px;
  }

  /* ---- 7. Guarantee — confident commitments on yellow ---- */
  .guarantee-section { padding-top: clamp(80px, 10vw, 120px); padding-bottom: clamp(80px, 10vw, 120px); }
  .guarantee-header {
    margin-bottom: 64px;
    max-width: 900px;
  }
  .guarantee-header .section-kicker { margin-bottom: 16px; }
  .guarantee-title { margin: 0; }

  .guarantees-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 48px 64px;
  }
  .guarantee-item { }
  .guarantee-num {
    display: block;
    color: var(--c-ink);
    opacity: 0.55;
    margin-bottom: 14px;
  }
  .guarantee-item h4 { margin-bottom: 10px; }
  .guarantee-item p {
    color: var(--c-ink);
    opacity: 0.85;
    line-height: 1.6;
    font-size: 15px;
    max-width: 320px;
  }

  /* ---- 8. Quality — editorial with section number aside ---- */
  .quality-section { padding-top: clamp(80px, 10vw, 120px); padding-bottom: clamp(80px, 10vw, 120px); }
  .quality-grid {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: clamp(32px, 6vw, 80px);
    align-items: start;
  }
  .quality-aside {
    position: sticky;
    top: 100px;
    display: flex;
    flex-direction: column;
    gap: 16px;
