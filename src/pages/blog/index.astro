---
// src/pages/blog/index.astro
import Layout from '../../components/layout/Layout.astro';
import { getCollection } from 'astro:content';

// Get all blog posts, sorted by date (newest first)
const allPosts = await getCollection('blog');
const sortedPosts = allPosts.sort((a, b) =>
  b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

// Get unique categories for filter
const categories = [...new Set(allPosts.map(post => post.data.category))];

// Featured posts (if any)
const featuredPosts = sortedPosts.filter(post => post.data.featured).slice(0, 3);
---

<Layout
  title="eLearning Insights & Resources | The eLearning Company Blog"
  description="Expert insights on eLearning development, training best practices, and cost guides for custom course creation."
>
  <!-- ============================================================
       1. Hero — turquoise (cooler, reading-focused; distinct from
       other heroes which lean lilac)
       ============================================================ -->
  <section class="section section--turquoise blog-hero">
    <div class="container">
      <span class="pill-meta hero-pill">The blog</span>
      <h1 class="display display-xl hero-title">
        eLearning insights<br />
        <span class="accent-blue">&amp; resources.</span>
      </h1>
      <p class="lede hero-subtitle">
        Expert guidance on custom eLearning development, pricing, templates, and best practices.
      </p>
    </div>
  </section>

  <!-- ============================================================
       2. Featured posts — paper · only renders if data exists
       ============================================================ -->
  {featuredPosts.length > 0 && (
    <section class="section section--paper featured-section">
      <div class="container">
        <span class="section-kicker">Featured</span>
        <h2 class="display display-md section-title">Worth your time.</h2>

        <div class="featured-grid">
          {featuredPosts.map((post) => (
            <a href={`/blog/${post.slug}`} class="featured-card">
              <span class="featured-category">{post.data.category}</span>
              <h3 class="heading-md featured-card-title">{post.data.title}</h3>
              <p class="featured-card-desc">{post.data.description}</p>
              <div class="featured-card-meta">
                <span class="meta">
                  {post.data.pubDate.toLocaleDateString('en-AU', {
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric'
                  })}
                </span>
                <span class="featured-card-arrow" aria-hidden="true">→</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ============================================================
       3. Category filter — paper-deep · utility bar
       ============================================================ -->
  <section class="section section--paper-deep blog-filter-section">
    <div class="container">
      <div class="filter-header">
        <span class="meta filter-label">Filter by category</span>
      </div>
      <div class="filter-bar">
        <button class="filter-btn active" data-category="all">All articles</button>
        {categories.map((category) => (
          <button class="filter-btn" data-category={category}>
            {category}
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================
       4. All blog posts — paper
       ============================================================ -->
  <section class="section section--paper blog-posts-section">
    <div class="container">
      <div class="posts-grid">
        {sortedPosts.map((post) => (
          <article class="post-card" data-category={post.data.category}>
            <a href={`/blog/${post.slug}`} class="post-link">
              <div class="post-card-meta">
                <span class="post-category">{post.data.category}</span>
                <span class="meta post-date">
                  {post.data.pubDate.toLocaleDateString('en-AU', {
                    month: 'short',
                    day: 'numeric',
                    year: 'numeric'
                  })}
                </span>
              </div>
              <h3 class="heading-md post-title">{post.data.title}</h3>
              <p class="post-excerpt">{post.data.description}</p>
              {post.data.tags && post.data.tags.length > 0 && (
                <div class="post-tags">
                  {post.data.tags.slice(0, 3).map((tag) => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>
              )}
              <span class="read-more">Read article <span aria-hidden="true">→</span></span>
            </a>
          </article>
        ))}
      </div>

      {sortedPosts.length === 0 && (
        <div class="no-posts">
          <p>No blog posts yet. Check back soon.</p>
        </div>
      )}
    </div>
  </section>

  <!-- ============================================================
       5. Newsletter — navy · closer
       ============================================================ -->
  <section class="section section--navy newsletter-section">
    <div class="container">
      <div class="newsletter-content">
        <span class="section-kicker">Newsletter</span>
        <h2 class="display display-md newsletter-title">
          Get eLearning insights<br />
          <span class="mark--lilac">in your inbox.</span>
        </h2>
        <p class="lede newsletter-text">
          Subscribe to receive guides, templates, and best practices for custom eLearning development.
        </p>
        <form class="newsletter-form" aria-label="Newsletter signup">
          <input type="email" placeholder="your@email.com" required aria-label="Email address" />
          <button type="submit" class="btn btn--accent">Subscribe</button>
        </form>
        <p class="newsletter-note">
          Coming soon. For now, <a href="/contact" class="inline-link">contact us</a> to stay updated.
        </p>
      </div>
    </div>
  </section>
</Layout>

<script>
  // Category filter functionality
  const filterButtons = document.querySelectorAll('.filter-btn');
  const postCards = document.querySelectorAll('.post-card');

  filterButtons.forEach(button => {
    button.addEventListener('click', () => {
      const category = (button as HTMLElement).dataset.category;

      filterButtons.forEach(btn => btn.classList.remove('active'));
      button.classList.add('active');

      postCards.forEach(card => {
        const cardEl = card as HTMLElement;
        if (category === 'all' || cardEl.dataset.category === category) {
          cardEl.style.display = '';
        } else {
          cardEl.style.display = 'none';
        }
      });
    });
  });
</script>

<style>
  /* ============================================================
     Page-specific styles only.
     ============================================================ */

  /* ---- 1. Hero ---- */
  .blog-hero { padding-top: clamp(64px, 8vw, 100px); padding-bottom: clamp(56px, 7vw, 80px); }
  .hero-pill { margin-bottom: 24px; }
  .hero-title { margin-bottom: 24px; max-width: 900px; }
  .hero-subtitle { max-width: 640px; }

  /* ---- 2. Featured ---- */
  .featured-section .section-title { margin-bottom: 56px; }
  .featured-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  .featured-card {
    background: var(--c-paper-deep);
    border: 1px solid rgba(21, 25, 46, 0.06);
    border-radius: var(--r-lg);
    padding: 32px;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }
  .featured-card:hover {
    border-color: var(--c-ink);
    transform: translateY(-2px);
  }
  .featured-category {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--c-ink-muted);
    margin-bottom: 16px;
    display: block;
  }
  .featured-card-title {
    margin-bottom: 12px;
    font-size: 22px;
    line-height: 1.25;
    color: var(--c-ink);
  }
  .featured-card-desc {
    color: var(--c-ink-soft);
    line-height: 1.6;
    font-size: 15px;
    margin-bottom: 24px;
    flex: 1;
  }
  .featured-card-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 16px;
    border-top: 1px solid rgba(21, 25, 46, 0.1);
  }
  .featured-card-meta .meta { color: var(--c-ink-muted); }
  .featured-card-arrow {
    font-family: var(--font-mono);
    color: var(--c-ink);
    font-size: 18px;
    transition: transform 0.2s ease;
  }
  .featured-card:hover .featured-card-arrow {
    transform: translateX(4px);
  }

  /* ---- 3. Category filter ---- */
  .blog-filter-section { padding-top: 48px; padding-bottom: 48px; }
  .filter-header { margin-bottom: 16px; }
  .filter-label { color: var(--c-ink-muted); }
  .filter-bar {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }
  .filter-btn {
    background: var(--c-paper);
    color: var(--c-ink);
    border: 1px solid rgba(21, 25, 46, 0.15);
    padding: 8px 16px;
    border-radius: var(--r-md);
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 14px;
    cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease;
  }
  .filter-btn:hover {
    border-color: var(--c-ink);
  }
  .filter-btn.active {
    background: var(--c-ink);
    color: var(--c-paper);
    border-color: var(--c-ink);
  }

  /* ---- 4. Posts grid ---- */
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  .post-card {
    background: var(--c-paper);
    border: 1px solid rgba(21, 25, 46, 0.08);
    border-radius: var(--r-lg);
    overflow: hidden;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }
  .post-card:hover {
    border-color: var(--c-ink);
    transform: translateY(-2px);
  }
  .post-link {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    padding: 28px;
    height: 100%;
  }
  .post-card-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 18px;
    gap: 12px;
  }
  .post-category {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--c-ink-muted);
    background: var(--c-paper-deep);
    padding: 4px 10px;
    border-radius: var(--r-sm);
  }
  .post-date { color: var(--c-ink-muted); }
  .post-title {
    margin-bottom: 12px;
    font-size: 20px;
    line-height: 1.3;
  }
  .post-excerpt {
    color: var(--c-ink-soft);
    line-height: 1.6;
    font-size: 15px;
    margin-bottom: 20px;
    flex: 1;
  }
  .post-tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-bottom: 20px;
  }
  .tag {
    color: var(--c-ink-muted);
    padding: 3px 10px;
    border-radius: var(--r-sm);
    font-size: 12px;
    border: 1px solid rgba(21, 25, 46, 0.12);
  }
  .read-more {
    color: var(--c-blue);
    font-weight: 500;
    font-size: 14px;
    margin-top: auto;
  }
  .post-card:hover .read-more {
    color: var(--c-ink);
  }
  .no-posts {
    text-align: center;
    padding: 80px 20px;
  }
  .no-posts p {
    font-size: 17px;
    color: var(--c-ink-muted);
  }

  /* ---- 5. Newsletter ---- */
  .newsletter-content {
    max-width: 800px;
  }
  .newsletter-title {
    margin-bottom: 24px;
  }
  .newsletter-text {
    margin-bottom: 32px;
    max-width: 580px;
  }
  .newsletter-form {
    display: flex;
    gap: 12px;
    max-width: 560px;
    margin-bottom: 16px;
  }
  .newsletter-form input {
    flex: 1;
    padding: 14px 18px;
    border-radius: var(--r-md);
    border: 1px solid rgba(250, 248, 243, 0.2);
    background: rgba(250, 248, 243, 0.06);
    color: var(--c-paper);
    font-family: var(--font-sans);
    font-size: 15px;
    transition: border-color 0.15s ease, background 0.15s ease;
  }
  .newsletter-form input::placeholder {
    color: rgba(250, 248, 243, 0.4);
  }
  .newsletter-form input:focus {
    outline: none;
    border-color: var(--c-paper);
    background: rgba(250, 248, 243, 0.1);
  }
  .newsletter-note {
    font-size: 14px;
    color: rgba(250, 248, 243, 0.55);
  }
  .inline-link {
    color: var(--c-paper);
    text-decoration: none;
    border-bottom: 1px solid currentColor;
    font-weight: 500;
  }
  .inline-link:hover {
    color: var(--c-lilac);
  }

  /* ---- Responsive ---- */
  @media (max-width: 900px) {
    .featured-grid,
    .posts-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 600px) {
    .featured-grid,
    .posts-grid { grid-template-columns: 1fr; }
    .newsletter-form { flex-direction: column; }
  }
</style>
