---
// src/pages/blog/[...slug].astro
import Layout from '../../components/layout/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const blogPosts = await getCollection('blog');
  return blogPosts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

// Related posts (same category, exclude current)
const allPosts = await getCollection('blog');
const relatedPosts = allPosts
  .filter(p => p.data.category === post.data.category && p.slug !== post.slug)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

// Per-category hero colour mapping. The colour tells the reader at a glance
// what kind of post they've landed on. With 6 categories and 4 brand colours,
// some pair up — that's fine, the colour groupings still feel coherent.
const categoryColour: Record<string, string> = {
  'Compliance & Risk':         'lilac',
  'Onboarding & Culture':      'yellow',
  'Skills Development':        'lilac',
  'Operational & Technical':   'turquoise',
  'eLearning Best Practices':  'turquoise',
  'Industry Insights':         'yellow',
};
const heroColour = categoryColour[post.data.category] || 'lilac';
---

<Layout
  title={`${post.data.title} | The eLearning Company Blog`}
  description={post.data.description}
>
  <article class="blog-post">
    <!-- ============================================================
         1. Article hero — coloured by category · proper landing
         ============================================================ -->
    <header class={`section section--${heroColour} post-hero`}>
      <div class="container">
        <a href="/blog" class="back-link">
          <span aria-hidden="true">←</span> Back to the blog
        </a>

        <div class="hero-grid">
          <div class="hero-headline-col">
            <div class="post-meta-row">
              <span class="post-category-tag">{post.data.category}</span>
              <span class="meta post-meta-date">
                {post.data.pubDate.toLocaleDateString('en-AU', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric'
                })}
              </span>
            </div>

            <h1 class="display display-lg post-title">{post.data.title}</h1>
          </div>

          <div class="hero-aside-col">
            <p class="lede post-description">{post.data.description}</p>

            <div class="post-byline">
              <span class="meta byline-author">By {post.data.author}</span>
              {post.data.updatedDate && (
                <span class="meta byline-updated">
                  Updated · {post.data.updatedDate.toLocaleDateString('en-AU', {
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric'
                  })}
                </span>
              )}
            </div>

            {post.data.tags && post.data.tags.length > 0 && (
              <div class="post-tags">
                {post.data.tags.map((tag) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            )}
          </div>
        </div>
      </div>
    </header>

    <!-- ============================================================
         2. Article body — paper · long-form prose
         ============================================================ -->
    <div class="section section--paper post-body-section">
      <div class="container-narrow">
        <div class="prose">
          <Content />
        </div>
      </div>
    </div>

    <!-- ============================================================
         3. Article CTA — navy · mid-article-feeling break
         ============================================================ -->
    <footer class="section section--navy post-footer">
      <div class="container-narrow">
        <div class="post-cta-content">
          <span class="section-kicker">Need help with eLearning?</span>
          <h3 class="display display-md post-cta-title">
            We can build it<br />
            <span class="mark--lilac">in three weeks.</span>
          </h3>
          <p class="lede post-cta-text">
            Custom eLearning courses with transparent pricing starting at $5,500 + GST.
          </p>
          <div class="post-cta-buttons">
            <a href="/contact" class="btn btn--accent">Get a quote</a>
            <a href="/pricing" class="btn btn--secondary">View pricing</a>
          </div>
        </div>
      </div>
    </footer>
  </article>

  <!-- ============================================================
       4. Related posts — paper-deep · only if data exists
       ============================================================ -->
  {relatedPosts.length > 0 && (
    <section class="section section--paper-deep related-posts-section">
      <div class="container">
        <span class="section-kicker">Keep reading</span>
        <h2 class="display display-md related-title">More from this category.</h2>

        <div class="related-posts-grid">
          {relatedPosts.map((relatedPost) => (
            <a href={`/blog/${relatedPost.slug}`} class="related-post-card">
              <span class="related-category">{relatedPost.data.category}</span>
              <h3 class="heading-md related-card-title">{relatedPost.data.title}</h3>
              <p class="related-card-desc">{relatedPost.data.description}</p>
              <span class="related-read-more">Read article <span aria-hidden="true">→</span></span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</Layout>

<style>
  /* ============================================================
     Page-specific styles only.
     Reuses .prose styling pattern from the training category template.
     ============================================================ */

  /* Narrow container for long-form reading */
  .container-narrow {
    width: 100%;
    max-width: 760px;
    margin: 0 auto;
    padding: 0 var(--gutter);
  }

  /* ---- 1. Article hero — asymmetric, coloured by category ---- */
  .post-hero {
    padding-top: clamp(48px, 6vw, 80px);
    padding-bottom: clamp(72px, 9vw, 112px);
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--c-ink);
    opacity: 0.65;
    text-decoration: none;
    margin-bottom: 48px;
    transition: opacity 0.15s ease;
  }
  .back-link:hover { opacity: 1; }

  /* Asymmetric grid — title takes the wider left column,
     description/byline sit in the right column, bottom-aligned */
  .hero-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: clamp(32px, 5vw, 80px);
    align-items: end;
  }

  .post-meta-row {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 24px;
    flex-wrap: wrap;
  }
  .post-category-tag {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    background: var(--c-ink);
    color: var(--c-paper);
    padding: 5px 11px;
    border-radius: var(--r-sm);
  }
  .post-meta-date {
    color: var(--c-ink);
    opacity: 0.7;
  }

  .post-title {
    margin: 0;
    color: var(--c-ink);
    line-height: 0.98;
  }

  .hero-aside-col {
    padding-bottom: 8px;
  }
  .post-description {
    margin-bottom: 24px;
    color: var(--c-ink);
    font-weight: 500;
  }
  .post-byline {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
    padding-top: 20px;
    border-top: 1px solid rgba(21, 25, 46, 0.15);
  }
  .byline-author,
  .byline-updated {
    color: var(--c-ink);
    opacity: 0.7;
  }
  .post-tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-top: 16px;
  }
  .tag {
    color: var(--c-ink);
    opacity: 0.8;
    padding: 3px 10px;
    border-radius: var(--r-sm);
    font-size: 12px;
    border: 1px solid rgba(21, 25, 46, 0.25);
    background: rgba(21, 25, 46, 0.03);
  }

  /* ---- 2. Article body — long-form prose ---- */
  .post-body-section {
    padding-top: clamp(24px, 3vw, 40px);
    padding-bottom: clamp(72px, 9vw, 112px);
  }
  .prose {
    color: var(--c-ink-soft);
    font-size: 17px;
    line-height: 1.75;
  }
  .prose :global(h2) {
    color: var(--c-ink);
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: clamp(24px, 2.6vw, 32px);
    line-height: 1.2;
    margin-top: 56px;
    margin-bottom: 20px;
    letter-spacing: -0.015em;
  }
  .prose :global(h2:first-child) { margin-top: 0; }
  .prose :global(h3) {
    color: var(--c-ink);
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: clamp(20px, 2vw, 22px);
    line-height: 1.3;
    margin-top: 40px;
    margin-bottom: 12px;
    letter-spacing: -0.01em;
  }
  .prose :global(h4) {
    color: var(--c-ink);
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 18px;
    margin-top: 32px;
    margin-bottom: 10px;
  }
  .prose :global(p) {
    margin-bottom: 22px;
  }
  .prose :global(ul),
  .prose :global(ol) {
    margin: 0 0 24px 0;
    padding-left: 0;
    list-style: none;
  }
  .prose :global(ul li),
  .prose :global(ol li) {
    padding: 6px 0 6px 28px;
    position: relative;
  }
  .prose :global(ul li::before) {
    content: "→";
    position: absolute;
    left: 0;
    color: var(--c-ink-muted);
    font-family: var(--font-mono);
  }
  .prose :global(ol) { counter-reset: olcount; }
  .prose :global(ol li) { counter-increment: olcount; }
  .prose :global(ol li::before) {
    content: counter(olcount, decimal-leading-zero);
    position: absolute;
    left: 0;
    color: var(--c-ink-muted);
    font-family: var(--font-mono);
    font-size: 13px;
    top: 9px;
  }
  .prose :global(strong) { color: var(--c-ink); font-weight: 600; }
  .prose :global(em) { font-style: italic; }
  .prose :global(a) {
    color: var(--c-blue);
    text-decoration: none;
    border-bottom: 1px solid currentColor;
  }
  .prose :global(a:hover) { color: var(--c-ink); }
  .prose :global(blockquote) {
    border-left: 3px solid var(--c-ink);
    padding: 8px 0 8px 24px;
    margin: 28px 0;
    color: var(--c-ink);
    font-style: italic;
    font-size: clamp(18px, 1.6vw, 21px);
    line-height: 1.55;
  }
  .prose :global(blockquote p) { margin-bottom: 8px; }
  .prose :global(blockquote p:last-child) { margin-bottom: 0; }
  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.9em;
    background: var(--c-paper-deep);
    padding: 2px 6px;
    border-radius: var(--r-sm);
    color: var(--c-ink);
  }
  .prose :global(pre) {
    background: var(--c-navy);
    color: var(--c-paper);
    padding: 20px 24px;
    border-radius: var(--r-md);
    overflow-x: auto;
    margin: 24px 0;
    font-size: 14px;
    line-height: 1.6;
  }
  .prose :global(pre code) {
    background: none;
    padding: 0;
    color: inherit;
  }
  .prose :global(hr) {
    border: none;
    height: 1px;
    background: rgba(21, 25, 46, 0.12);
    margin: 40px 0;
  }
  .prose :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: var(--r-md);
    margin: 24px 0;
  }
  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 24px 0;
    font-size: 15px;
  }
  .prose :global(th),
  .prose :global(td) {
    text-align: left;
    padding: 12px 16px;
    border-bottom: 1px solid rgba(21, 25, 46, 0.1);
  }
  .prose :global(th) {
    font-weight: 600;
    color: var(--c-ink);
    font-family: var(--font-mono);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  /* ---- 3. Article CTA ---- */
  .post-footer {
    padding-top: clamp(64px, 8vw, 96px);
    padding-bottom: clamp(64px, 8vw, 96px);
  }
  .post-cta-content {
    max-width: 720px;
  }
  .post-cta-title {
    margin-bottom: 20px;
  }
  .post-cta-text {
    margin-bottom: 32px;
    max-width: 560px;
  }
  .post-cta-buttons {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  /* ---- 4. Related posts ---- */
  .related-posts-section .related-title {
    margin-bottom: 48px;
  }
  .related-posts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  .related-post-card {
    background: var(--c-paper);
    border: 1px solid rgba(21, 25, 46, 0.08);
    border-radius: var(--r-lg);
    padding: 28px;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }
  .related-post-card:hover {
    border-color: var(--c-ink);
    transform: translateY(-2px);
  }
  .related-category {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--c-ink-muted);
    margin-bottom: 14px;
    display: block;
  }
  .related-card-title {
    margin-bottom: 12px;
    font-size: 20px;
    line-height: 1.3;
  }
  .related-card-desc {
    color: var(--c-ink-soft);
    font-size: 14px;
    line-height: 1.55;
    margin-bottom: 20px;
    flex: 1;
  }
  .related-read-more {
    color: var(--c-blue);
    font-weight: 500;
    font-size: 14px;
    margin-top: auto;
  }
  .related-post-card:hover .related-read-more {
    color: var(--c-ink);
  }

  /* ---- Responsive ---- */
  @media (max-width: 900px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 32px;
      align-items: start;
    }
    .related-posts-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 600px) {
    .related-posts-grid { grid-template-columns: 1fr; }
    .post-cta-buttons .btn { width: 100%; }
  }
</style>
