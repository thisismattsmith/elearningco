---
// src/pages/blog/[...slug].astro
import Layout from '../../components/layout/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const blogPosts = await getCollection('blog');
  return blogPosts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

// Get related posts (same category, exclude current)
const allPosts = await getCollection('blog');
const relatedPosts = allPosts
  .filter(p => p.data.category === post.data.category && p.slug !== post.slug)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<Layout 
  title={`${post.data.title} | The E-Learning Company Blog`}
  description={post.data.description}
>
  <!-- Article Header -->
  <article class="blog-post">
    <header class="post-header">
      <div class="container-narrow">
        <a href="/blog" class="back-link">← Back to Blog</a>
        
        <div class="post-meta-header">
          <span class="post-category">{post.data.category}</span>
          <span class="post-date">
            {post.data.pubDate.toLocaleDateString('en-AU', { 
              year: 'numeric', 
              month: 'long', 
              day: 'numeric' 
            })}
          </span>
        </div>

        <h1 class="post-title">{post.data.title}</h1>
        <p class="post-description">{post.data.description}</p>

        <div class="post-tags">
          {post.data.tags.map((tag) => (
            <span class="tag">{tag}</span>
          ))}
        </div>

        <div class="post-author">
          <span>By {post.data.author}</span>
          {post.data.updatedDate && (
            <span class="updated-date">
              Updated: {post.data.updatedDate.toLocaleDateString('en-AU', { 
                year: 'numeric', 
                month: 'long', 
                day: 'numeric' 
              })}
            </span>
          )}
        </div>
      </div>
    </header>

    <!-- Article Content -->
    <div class="post-content">
      <div class="container-narrow">
        <div class="prose">
          <Content />
        </div>
      </div>
    </div>

    <!-- Article Footer / CTA -->
    <footer class="post-footer">
      <div class="container-narrow">
        <div class="post-cta-card">
          <h3>Need Help With Your eLearning Project?</h3>
          <p>We build custom eLearning courses in 3 weeks with transparent pricing starting at $5,500 + GST.</p>
          <div class="cta-buttons">
            <a href="/pricing" class="btn-primary">View Pricing</a>
            <a href="/contact" class="btn-secondary">Get a Quote</a>
          </div>
        </div>
      </div>
    </footer>
  </article>

  <!-- Related Posts -->
  {relatedPosts.length > 0 && (
    <section class="related-posts-section">
      <div class="container">
        <h2 class="section-title">Related Articles</h2>
        <div class="related-posts-grid">
          {relatedPosts.map((relatedPost) => (
            <a href={`/blog/${relatedPost.slug}`} class="related-post-card">
              <span class="post-category">{relatedPost.data.category}</span>
              <h3>{relatedPost.data.title}</h3>
              <p>{relatedPost.data.description}</p>
              <span class="read-more">Read article →</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</Layout>

<style>
  /* Header */
  .post-header {
    padding: 80px 0 40px;
    background: var(--bg-primary);
  }

  .container-narrow {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    color: var(--text-secondary);
    text-decoration: none;
    font-weight: 600;
    margin-bottom: 32px;
    transition: color 0.2s ease;
  }

  .back-link:hover {
    color: var(--accent-primary);
  }

  .post-meta-header {
    display: flex;
    gap: 16px;
    align-items: center;
    margin-bottom: 24px;
  }

  .post-category {
    background: rgba(99, 102, 241, 0.15);
    color: var(--accent-primary);
    padding: 8px 16px;
    border-radius: 8px;
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .post-date {
    color: var(--text-secondary);
    font-size: 0.95rem;
  }

  .post-title {
    font-size: 3rem;
    font-weight: 800;
    line-height: 1.2;
    margin-bottom: 24px;
    letter-spacing: -0.02em;
  }

  .post-description {
    font-size: 1.25rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: 24px;
  }

  .post-tags {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 24px;
  }

  .tag {
    background: var(--bg-secondary);
    color: var(--text-secondary);
    padding: 6px 16px;
    border-radius: 16px;
    font-size: 0.875rem;
    border: 1px solid var(--border-color);
  }

  .post-author {
    display: flex;
    gap: 16px;
    padding-top: 24px;
    border-top: 1px solid var(--border-color);
    color: var(--text-secondary);
    font-size: 0.95rem;
  }

  .updated-date {
    font-style: italic;
  }

  /* Article Content */
  .post-content {
    padding: 60px 0;
    background: var(--bg-primary);
  }

  /* Prose Styles for Markdown Content */
  .prose {
    color: var(--text-primary);
    font-size: 1.125rem;
    line-height: 1.8;
  }

  .prose :global(h2) {
    font-size: 2rem;
    font-weight: 800;
    margin-top: 48px;
    margin-bottom: 24px;
    line-height: 1.3;
    letter-spacing: -0.01em;
  }

  .prose :global(h3) {
    font-size: 1.5rem;
    font-weight: 700;
    margin-top: 40px;
    margin-bottom: 20px;
    line-height: 1.4;
  }

  .prose :global(h4) {
    font-size: 1.25rem;
    font-weight: 700;
    margin-top: 32px;
    margin-bottom: 16px;
  }

  .prose :global(p) {
    margin-bottom: 24px;
    color: var(--text-secondary);
  }

  .prose :global(strong) {
    color: var(--text-primary);
    font-weight: 700;
  }

  .prose :global(a) {
    color: var(--accent-primary);
    text-decoration: none;
    font-weight: 600;
    transition: opacity 0.2s ease;
  }

  .prose :global(a:hover) {
    text-decoration: underline;
    opacity: 0.8;
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin-bottom: 24px;
    padding-left: 32px;
  }

  .prose :global(li) {
    margin-bottom: 12px;
    color: var(--text-secondary);
  }

  .prose :global(li::marker) {
    color: var(--accent-primary);
  }

  .prose :global(blockquote) {
    border-left: 4px solid var(--accent-primary);
    padding-left: 24px;
    margin: 32px 0;
    font-style: italic;
    color: var(--text-secondary);
  }

  .prose :global(code) {
    background: var(--bg-tertiary);
    color: var(--accent-primary);
    padding: 2px 8px;
    border-radius: 4px;
    font-size: 0.9em;
    font-family: 'Monaco', 'Courier New', monospace;
  }

  .prose :global(pre) {
    background: var(--bg-tertiary);
    padding: 24px;
    border-radius: 12px;
    overflow-x: auto;
    margin: 32px 0;
    border: 1px solid var(--border-color);
  }

  .prose :global(pre code) {
    background: none;
    padding: 0;
    color: var(--text-primary);
  }

  .prose :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 12px;
    margin: 32px 0;
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--border-color);
    margin: 48px 0;
  }

  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 32px 0;
  }

  .prose :global(th),
  .prose :global(td) {
    padding: 12px;
    border: 1px solid var(--border-color);
    text-align: left;
  }

  .prose :global(th) {
    background: var(--bg-tertiary);
    font-weight: 700;
    color: var(--text-primary);
  }

  .prose :global(td) {
    color: var(--text-secondary);
  }

  /* Post Footer CTA */
  .post-footer {
    padding: 60px 0;
    background: var(--bg-secondary);
    border-top: 1px solid var(--border-color);
  }

  .post-cta-card {
    background: linear-gradient(135deg, rgba(99, 102, 241, 0.1) 0%, rgba(139, 92, 246, 0.1) 100%);
    border: 2px solid var(--accent-primary);
    border-radius: 20px;
    padding: 48px;
    text-align: center;
  }

  .post-cta-card h3 {
    font-size: 2rem;
    margin-bottom: 16px;
    font-weight: 800;
  }

  .post-cta-card p {
    font-size: 1.125rem;
    color: var(--text-secondary);
    margin-bottom: 32px;
  }

  .cta-buttons {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-primary,
  .btn-secondary {
    display: inline-block;
    padding: 14px 32px;
    border-radius: 10px;
    text-decoration: none;
    font-weight: 700;
    transition: all 0.3s ease;
  }

  .btn-primary {
    background: var(--accent-gradient);
    color: white;
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 24px rgba(99, 102, 241, 0.5);
  }

  .btn-secondary {
    background: var(--bg-tertiary);
    color: var(--text-primary);
    border: 2px solid var(--border-color);
  }

  .btn-secondary:hover {
    border-color: var(--accent-primary);
    background: rgba(99, 102, 241, 0.1);
  }

  /* Related Posts */
  .related-posts-section {
    padding: 80px 0;
    background: var(--bg-primary);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .section-title {
    font-size: 2rem;
    font-weight: 800;
    text-align: center;
    margin-bottom: 48px;
  }

  .related-posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 32px;
  }

  .related-post-card {
    background: var(--bg-tertiary);
    border: 1px solid var(--border-color);
    border-radius: 16px;
    padding: 32px;
    text-decoration: none;
    display: block;
    transition: all 0.3s ease;
  }

  .related-post-card:hover {
    transform: translateY(-4px);
    border-color: var(--accent-primary);
    box-shadow: var(--shadow-md);
  }

  .related-post-card h3 {
    font-size: 1.25rem;
    color: var(--text-primary);
    margin: 16px 0 12px;
    font-weight: 700;
  }

  .related-post-card p {
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: 16px;
  }

  .read-more {
    color: var(--accent-primary);
    font-weight: 600;
    font-size: 0.95rem;
  }

  .related-post-card:hover .read-more {
    text-decoration: underline;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .post-title {
      font-size: 2rem;
    }

    .post-description {
      font-size: 1.125rem;
    }

    .prose {
      font-size: 1rem;
    }

    .prose :global(h2) {
      font-size: 1.5rem;
    }

    .prose :global(h3) {
      font-size: 1.25rem;
    }

    .post-cta-card {
      padding: 32px 24px;
    }

    .post-cta-card h3 {
      font-size: 1.5rem;
    }

    .cta-buttons {
      flex-direction: column;
    }

    .btn-primary,
    .btn-secondary {
      width: 100%;
    }

    .related-posts-grid {
      grid-template-columns: 1fr;
    }
  }
</style>