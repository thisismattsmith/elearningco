---
// src/pages/thank-you.astro
import Layout from '../components/layout/Layout.astro';
---

<Layout
  title="Thank You | The eLearning Company"
  description="Thank you for your enquiry. We'll be in touch within 24 hours."
>
  <section class="section section--yellow thank-you-section">
    <div class="container">
      <div class="thank-you-content">
        <span class="pill-meta confirmation-pill">
          <span class="confirmation-mark" aria-hidden="true">✓</span>
          Received
        </span>

        <h1 class="display display-xl thank-you-title">
          <span class="accent-teal">Thanks.</span><br />
          We'll be in touch soon.
        </h1>

        <p class="lede thank-you-lede">
          We've received your enquiry and will get back to you within 24 hours.
        </p>

        <div class="next-steps-card">
          <span class="meta next-steps-label">What happens next</span>
          <ol class="next-steps-list">
            <li>
              <span class="step-num">01</span>
              <span>We'll review your project details.</span>
            </li>
            <li>
              <span class="step-num">02</span>
              <span>We'll email you to schedule a quick 15-minute call.</span>
            </li>
            <li>
              <span class="step-num">03</span>
              <span>You'll receive a fixed-price quote with clear timelines.</span>
            </li>
          </ol>
        </div>

        <div class="thank-you-actions">
          <a href="/" class="btn btn--primary">Back to home</a>
          <a href="/pricing" class="btn btn--secondary">View pricing</a>
        </div>

        <div class="urgent-contact">
          <span class="meta urgent-label">Need to reach us urgently?</span>
          <a href="mailto:contact@elearningcompany.net" class="urgent-email">contact@elearningcompany.net</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ============================================================
     Page-specific styles only.
     ============================================================ */

  .thank-you-section {
    min-height: 80vh;
    display: flex;
    align-items: center;
    padding-top: clamp(64px, 8vw, 100px);
    padding-bottom: clamp(64px, 8vw, 100px);
  }

  .thank-you-content {
    max-width: 800px;
  }

  /* Confirmation pill — distinct from regular pill-meta because it has an icon */
  .confirmation-pill {
    margin-bottom: 32px;
    background: var(--c-ink);
    color: var(--c-paper);
    padding: 6px 14px 6px 8px;
    gap: 8px;
  }
  .confirmation-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    background: var(--c-paper);
    color: var(--c-ink);
    border-radius: 50%;
    font-size: 11px;
    font-weight: 700;
    font-family: var(--font-sans);
    line-height: 1;
  }

  .thank-you-title {
    margin-bottom: 32px;
    max-width: 800px;
  }

  .thank-you-lede {
    margin-bottom: 48px;
    max-width: 580px;
  }

  /* Next steps card */
  .next-steps-card {
    background: var(--c-paper);
    border: 1px solid rgba(21, 25, 46, 0.08);
    border-radius: var(--r-lg);
    padding: 32px;
    margin-bottom: 40px;
    max-width: 640px;
  }
  .next-steps-label {
    display: block;
    color: var(--c-ink-muted);
    margin-bottom: 20px;
  }
  .next-steps-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .next-steps-list li {
    display: flex;
    gap: 16px;
    align-items: flex-start;
    color: var(--c-ink);
    font-size: 16px;
    line-height: 1.55;
  }
  .step-num {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.1em;
    color: var(--c-ink-muted);
    flex-shrink: 0;
    padding-top: 4px;
    min-width: 22px;
  }

  /* Actions */
  .thank-you-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 56px;
  }

  /* Urgent contact */
  .urgent-contact {
    padding-top: 32px;
    border-top: 1px solid rgba(21, 25, 46, 0.15);
  }
  .urgent-label {
    display: block;
    color: var(--c-ink-muted);
    margin-bottom: 8px;
  }
  .urgent-email {
    font-family: var(--font-sans);
    font-size: 17px;
    color: var(--c-ink);
    text-decoration: none;
    border-bottom: 1px solid currentColor;
    font-weight: 500;
  }
  .urgent-email:hover {
    color: var(--c-blue);
  }

  /* ---- Responsive ---- */
  @media (max-width: 600px) {
    .thank-you-actions .btn { width: 100%; }
    .next-steps-card { padding: 24px; }
  }
</style>
