            <rect x="0" y="0" width="800" height="120" fill="#EEE6D4" />
            <!-- Floor -->
            <rect x="0" y="120" width="800" height="380" fill="#F1EDE2" />
            <!-- Floor seam shadow -->
            <rect x="0" y="120" width="800" height="2" fill="rgba(21,25,46,0.08)" />

            <!-- ===== Wall fixtures ===== -->
