              <!-- kettle -->
              <ellipse cx="120" cy="346" rx="7" ry="5" fill="#7EE8DA" stroke="#15192E" stroke-width="1" />
              <rect x="119" y="334" width="2" height="6" fill="#15192E" />
              <!-- bowl of fruit -->
