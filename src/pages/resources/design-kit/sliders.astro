<script>
  // Zoom-into-office interactive demo.
  // As the slider moves, scale the SVG and update the caption.
  // Three caption "stops" reflect what the learner is looking at.
  const slider = document.getElementById('zoom-slider') as HTMLInputElement | null;
  const scene = document.querySelector<SVGSVGElement>('.office-scene');
  const valueEl = document.querySelector<HTMLElement>('[data-zoom-value]');
  const captionEl = document.querySelector<HTMLElement>('[data-zoom-caption]');

  if (slider && scene && valueEl && captionEl) {
    const captions = [
      { from: 0,  to: 20,  text: "You're looking at the whole office floor — reception, desks, the meeting room, and the break room." },
      { from: 20, to: 50,  text: "Zooming in. You can see the open work area where the team sits, with the meeting room behind." },
      { from: 50, to: 80,  text: "Closer now. You can see people at their desks — and the meeting in progress nearby." },
      { from: 80, to: 101, text: "Right up close. This is where you'd find your desk on day one." },
    ];

    const update = () => {
      const v = Number(slider.value);
      // Map slider 0-100 to scale 1.0 -> 5.0
      const scale = 1 + (v / 100) * 4;
      scene.style.transform = `scale(${scale})`;
      valueEl.textContent = `${v}%`;
      const caption = captions.find((c) => v >= c.from && v < c.to);
      if (caption) captionEl.textContent = caption.text;
    };

    slider.addEventListener('input', update);
    update();
  }
</script>

