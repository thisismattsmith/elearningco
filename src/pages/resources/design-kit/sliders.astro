            </g>

            <!-- ===== Break room (bottom-left) ===== -->
            <g>
              <rect x="60" y="320" width="240" height="130" fill="#FAF8F3" stroke="#15192E" stroke-width="1.5" />
              <text x="180" y="340" text-anchor="middle" font-family="Inter, sans-serif" font-size="10" font-weight="600" fill="#15192E" letter-spacing="0.5">BREAK ROOM</text>

