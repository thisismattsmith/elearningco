              <ellipse cx="8" cy="-8" rx="6" ry="14" fill="#0F4C5C" transform="rotate(15 8 -8)" />
              <ellipse cx="3" cy="-14" rx="6" ry="15" fill="#0F4C5C" />
            </g>
