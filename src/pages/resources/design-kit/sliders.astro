            <g>
              <rect x="60" y="32" width="180" height="68" fill="#BFDBFE" stroke="#15192E" stroke-width="1.5" />
              <line x1="150" y1="32" x2="150" y2="100" stroke="#15192E" stroke-width="1.5" />
              <line x1="60" y1="66" x2="240" y2="66" stroke="#15192E" stroke-width="1.5" />
              <!-- subtle cloud -->
              <ellipse cx="100" cy="55" rx="20" ry="6" fill="#FAF8F3" opacity="0.7" />
              <ellipse cx="195" cy="80" rx="14" ry="5" fill="#FAF8F3" opacity="0.6" />
            </g>

            <!-- Logo / wall art -->
            <g>
