              <circle cx="143" cy="350" r="3" fill="#F5D547" />
              <circle cx="150" cy="349" r="3" fill="#F5D547" />
              <circle cx="157" cy="350" r="3" fill="#7EE8DA" />

              <!-- Round table with chairs -->
              <ellipse cx="240" cy="400" rx="38" ry="12" fill="#C8B6FF" stroke="#15192E" stroke-width="1.5" />
