                <rect x="-7" y="9" width="14" height="22" rx="3" fill="#15192E" />
                <line x1="-4" y1="31" x2="-6" y2="44" stroke="#15192E" stroke-width="3" stroke-linecap="round" />
                <line x1="4" y1="31" x2="6" y2="44" stroke="#15192E" stroke-width="3" stroke-linecap="round" />
                <!-- arm pointing -->
