              <path d="M -8 0 L -5 28 L 12 28 L 15 0 Z" fill="#15192E" />
              <ellipse cx="-4" cy="-10" rx="7" ry="16" fill="#0F4C5C" transform="rotate(-20 -4 -10)" />
              <ellipse cx="12" cy="-10" rx="7" ry="16" fill="#0F4C5C" transform="rotate(20 12 -10)" />
