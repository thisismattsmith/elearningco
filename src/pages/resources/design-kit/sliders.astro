              <g>
                <circle cx="600" cy="178" r="6" fill="#C68B58" />
                <circle cx="625" cy="172" r="6" fill="#E8C9A0" />
                <circle cx="650" cy="170" r="6" fill="#C68B58" />
                <circle cx="675" cy="172" r="6" fill="#E8C9A0" />
                <circle cx="700" cy="178" r="6" fill="#C68B58" />
                <circle cx="650" cy="205" r="6" fill="#E8C9A0" />
