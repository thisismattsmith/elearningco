        <div class="zoom-controls">
          <label for="zoom-slider" class="zoom-label">
            <span>Zoom level</span>
            <span class="zoom-value" data-zoom-value>0%</span>
          </label>

          <input
            type="range"
            id="zoom-slider"
            class="zoom-slider"
            min="0"
            max="100"
            value="0"
            step="1"
            aria-label="Zoom into the office"
          />

          <div class="zoom-stops" aria-hidden="true">
            <span>Whole office</span>
            <span>Work area</span>
            <span>A desk</span>
          </div>
        </div>

        <p class="zoom-caption" data-zoom-caption>
          You're looking at the whole office floor.
        </p>
      </div>

      <p class="example-note">
        <span class="meta">Note ·</span>
        The slider here uses a native HTML <code>&lt;input type="range"&gt;</code>. It's fully keyboard accessible — focus and use the arrow keys.
      </p>
    </div>
