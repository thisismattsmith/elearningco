---
// src/pages/pricing.astro
import Layout from '../components/layout/Layout.astro';
---

<Layout
  title="Transparent Pricing | The eLearning Company"
  description="Clear, transparent pricing for custom eLearning. From $5,500 + GST. No hidden costs, no surprises. Choose the tier that matches your content readiness."
>
  <!-- ============================================================
       1. Hero — paper (calmer; tiers are the loud moment)
       ============================================================ -->
  <section class="section section--paper pricing-hero">
    <div class="container">
      <span class="pill-meta hero-pill">Pricing</span>
      <h1 class="display display-lg page-title">
        Transparent pricing<br />
        for <span class="accent-blue">custom eLearning.</span>
      </h1>
      <p class="lede page-subtitle">
        No hidden costs. No surprise fees. Choose the tier that matches your content readiness.
      </p>
    </div>
  </section>

  <!-- ============================================================
       2. Pricing tiers — paper-deep (raised surface for the cards)
       ============================================================ -->
  <section class="section section--paper-deep pricing-tiers-section">
    <div class="container">
      <div class="pricing-grid">

        <!-- Tier 1 -->
        <div class="pricing-card">
          <div class="tier-badge">Most affordable</div>
          <h3 class="heading-md tier-name">Content ready</h3>
          <div class="tier-price">
            <span class="price-amount">$5,500</span>
            <span class="price-gst">+ GST</span>
          </div>
          <p class="tier-description">You provide complete script, we build and design.</p>

          <div class="best-for-block best-for-block--lilac">
            <span class="meta best-for-label">Best for</span>
            <p class="best-for-text">Organisations with instructional design capability or pre-written content ready to go.</p>
            <p class="best-for-example">"We have a 10-page Word document with the exact content we want in the course."</p>
          </div>

          <div class="tier-details">
            <h4 class="meta tier-section-label">You provide</h4>
            <ul class="tier-list">
              <li>Complete script written and reviewed</li>
              <li>Content finalised and approved</li>
            </ul>

            <h4 class="meta tier-section-label">We provide</h4>
            <ul class="tier-list">
              <li>Professional visual design</li>
              <li>Articulate Rise development</li>
              <li>SCORM package for any LMS</li>
              <li>Quality assurance testing</li>
            </ul>
          </div>

          <a href="/contact?tier=1" class="btn btn--secondary tier-cta">Choose tier 1</a>
        </div>

        <!-- Tier 2 -->
        <div class="pricing-card">
          <div class="tier-badge">Content provided</div>
          <h3 class="heading-md tier-name">Content needs shaping</h3>
          <div class="tier-price">
            <span class="price-amount">$7,500</span>
            <span class="price-gst">+ GST</span>
          </div>
          <p class="tier-description">You provide content materials, we structure and build.</p>

          <div class="best-for-block best-for-block--yellow">
            <span class="meta best-for-label">Best for</span>
            <p class="best-for-text">SMEs with content expertise who need it shaped into effective learning.</p>
            <p class="best-for-example">"We have PowerPoint slides and training manuals we want converted into eLearning."</p>
          </div>

          <div class="tier-details">
            <h4 class="meta tier-section-label">You provide</h4>
            <ul class="tier-list">
              <li>Extensive content materials</li>
              <li>Documents, presentations, videos</li>
              <li>Training manuals or existing resources</li>
            </ul>

            <h4 class="meta tier-section-label">We provide</h4>
            <ul class="tier-list">
              <li>Content structuring and editing</li>
              <li>Instructional design</li>
              <li>Professional visual design</li>
              <li>Articulate Rise development</li>
              <li>SCORM package for any LMS</li>
            </ul>
          </div>

          <a href="/contact?tier=2" class="btn btn--secondary tier-cta">Choose tier 2</a>
        </div>

        <!-- Tier 3 -->
        <div class="pricing-card">
          <div class="tier-badge">Most comprehensive</div>
          <h3 class="heading-md tier-name">Start from scratch</h3>
          <div class="tier-price">
            <span class="price-amount">$10,500</span>
            <span class="price-gst">+ GST</span>
          </div>
          <p class="tier-description">We write, design, and build everything.</p>

          <div class="best-for-block best-for-block--turquoise">
            <span class="meta best-for-label">Best for</span>
            <p class="best-for-text">Organisations that need complete course creation from concept to delivery.</p>
            <p class="best-for-example">"We know what our team needs to learn but need you to create everything from scratch."</p>
          </div>

          <div class="tier-details">
            <h4 class="meta tier-section-label">You provide</h4>
            <ul class="tier-list">
              <li>Subject matter expertise</li>
              <li>Content guidance and direction</li>
              <li>Access to SMEs for interviews</li>
            </ul>

            <h4 class="meta tier-section-label">We provide</h4>
            <ul class="tier-list">
              <li>Complete instructional design</li>
              <li>Full content writing</li>
              <li>Professional visual design</li>
              <li>Articulate Rise development</li>
              <li>SCORM package for any LMS</li>
            </ul>
          </div>

          <a href="/contact?tier=3" class="btn btn--secondary tier-cta">Choose tier 3</a>
        </div>

        <!-- Custom -->
        <div class="pricing-card pricing-card--custom">
          <div class="tier-badge">Complex projects</div>
          <h3 class="heading-md tier-name">Custom projects</h3>
          <div class="tier-price">
            <span class="price-amount price-amount--custom">Request quote</span>
          </div>
          <p class="tier-description">For specialised tools and complex builds.</p>

          <div class="best-for-block best-for-block--neutral">
            <span class="meta best-for-label">Best for</span>
            <p class="best-for-text">Specialised tools, complex builds, or anything beyond standard Articulate Rise.</p>
            <p class="best-for-example">Timeline and pricing provided based on your specific requirements.</p>
          </div>

          <div class="tier-details">
            <h4 class="meta tier-section-label">Custom solutions include</h4>
            <ul class="tier-list">
              <li>Articulate Storyline with complex interactions</li>
              <li>HowToo courses</li>
              <li>Chameleon Creator builds</li>
              <li>Parta.io experiences</li>
              <li>7Taps microlearning</li>
              <li>Branching scenarios and simulations</li>
              <li>Gamification elements</li>
              <li>Multi-course learning pathways</li>
            </ul>
          </div>

          <a href="/contact?tier=custom" class="btn btn--secondary tier-cta">Request quote</a>
        </div>

      </div>

      <!-- Not sure CTA -->
      <div class="not-sure-cta">
        <p class="not-sure-text">Not sure which tier fits your needs?</p>
        <a href="/contact" class="btn btn--secondary">Contact us for guidance</a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       3. What's included — turquoise (process)
       ============================================================ -->
  <section class="section section--turquoise included-section">
    <div class="container">
      <span class="section-kicker">What's included</span>
      <h2 class="display display-md section-title">In every tier.</h2>

      <div class="included-grid">
        <div class="included-item">
          <span class="meta included-num">01</span>
          <h3 class="heading-sm">3-week delivery</h3>
          <p>Week 1: kickoff + development. Weeks 2-3: review and revisions.</p>
        </div>
        <div class="included-item">
          <span class="meta included-num">02</span>
          <h3 class="heading-sm">Unlimited revisions</h3>
          <p>Unlimited rounds during weeks 2 and 3. No limit on number of reviewers.</p>
        </div>
        <div class="included-item">
          <span class="meta included-num">03</span>
          <h3 class="heading-sm">Modern design</h3>
          <p>Professional, responsive design that works on all devices.</p>
        </div>
        <div class="included-item">
          <span class="meta included-num">04</span>
          <h3 class="heading-sm">SCORM compliant</h3>
          <p>SCORM 1.2 and 2004 packages compatible with any LMS.</p>
        </div>
        <div class="included-item">
          <span class="meta included-num">05</span>
          <h3 class="heading-sm">Source files</h3>
          <p>Full source files provided so you can make future updates.</p>
        </div>
        <div class="included-item">
          <span class="meta included-num">06</span>
          <h3 class="heading-sm">Quality testing</h3>
          <p>Thorough QA testing before delivery to ensure everything works.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       4. Revisions explainer — paper with yellow accents
       ============================================================ -->
  <section class="section section--paper revisions-explainer">
    <div class="container">
      <span class="section-kicker">Unlimited revisions</span>
      <h2 class="display display-md section-title">
        How our <span class="mark">unlimited revisions</span> work.
      </h2>

      <div class="revisions-timeline">
        <div class="timeline-item">
          <div class="timeline-badge">Week 1</div>
          <h4 class="heading-sm">We build</h4>
          <p>We start as soon as you send us your brief, branding and resources.</p>
        </div>
        <div class="timeline-item">
          <div class="timeline-badge">Week 2</div>
          <h4 class="heading-sm">You review</h4>
          <p>You receive the complete first draft for review. Provide feedback via our review link with your whole team.</p>
        </div>
        <div class="timeline-item">
          <div class="timeline-badge">Week 3</div>
          <h4 class="heading-sm">We deliver</h4>
          <p>We'll continue to implement your feedback and finalise the course. Then, at the end of the third week we'll deliver the SCORM package ready for your LMS.</p>
        </div>
      </div>

      <div class="revisions-conditions">
        <h4 class="meta conditions-label">Simple conditions</h4>
        <ul class="conditions-list">
          <li><strong>All feedback via review link</strong> — no emails or documents (keeps everything organised).</li>
          <li><strong>One final decision maker</strong> — to resolve any internal disagreements and approve the final course.</li>
          <li><strong>Within the 2-week window</strong> — revisions beyond this period will be quoted separately.</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- ============================================================
       5. Available as add-ons — paper-deep
       Consolidated section. The fixed price covers a defined scope;
       these are quoted separately and added if you need them.
       ============================================================ -->
  <section class="section section--paper-deep addons-section">
    <div class="container">
      <span class="section-kicker">Beyond the base price</span>
      <h2 class="display display-md section-title">
        Available as <span class="accent-blue">add-ons</span>.
      </h2>
      <p class="lede section-subtitle">
        The fixed price covers a defined scope. Anything below is quoted separately and added if you need it. Transparent either way.
      </p>

      <div class="addons-grid">
        <div class="addon-item">
          <div class="addon-header">
            <h4 class="heading-sm">Professional voiceover</h4>
            <span class="addon-price">$500 per course</span>
          </div>
          <p>Professional narration to enhance engagement and accessibility.</p>
        </div>

        <div class="addon-item">
          <div class="addon-header">
            <h4 class="heading-sm">Translation</h4>
            <span class="addon-price">Quoted on request</span>
          </div>
          <p>Translate your course into other languages. Quote varies by language and word count.</p>
        </div>

        <div class="addon-item">
          <div class="addon-header">
            <h4 class="heading-sm">Custom illustrations &amp; animations</h4>
            <span class="addon-price">Quoted on request</span>
          </div>
          <p>We use high-quality stock assets by default. Custom characters, illustrations, or animations are available — just ask.</p>
        </div>

        <div class="addon-item">
          <div class="addon-header">
            <h4 class="heading-sm">Video production</h4>
            <span class="addon-price">Quoted on request</span>
          </div>
          <p>We can incorporate your videos, or arrange professional filming and editing of your team.</p>
        </div>

        <div class="addon-item">
          <div class="addon-header">
            <h4 class="heading-sm">Rush delivery</h4>
            <span class="addon-price">Quoted on request</span>
          </div>
          <p>Need your course in 2 weeks instead of 3? We can prioritise your project.</p>
        </div>

        <div class="addon-item">
          <div class="addon-header">
            <h4 class="heading-sm">Extended review window</h4>
            <span class="addon-price">Quoted on request</span>
          </div>
          <p>Need longer than two weeks for internal reviews? We can extend the window.</p>
        </div>

        <div class="addon-item">
          <div class="addon-header">
            <h4 class="heading-sm">Complex code &amp; interactions</h4>
            <span class="addon-price">Quoted on request</span>
          </div>
          <p>Need the course to do more than the authoring tool allows? Custom code, integrations, and advanced interactions available.</p>
        </div>

        <div class="addon-item">
          <div class="addon-header">
            <h4 class="heading-sm">LMS hosting &amp; technical support</h4>
            <span class="addon-price">Not included</span>
          </div>
          <p>We provide a SCORM package that works with any LMS. We don't host courses or provide ongoing LMS support — your LMS provider handles that.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       7. Pricing FAQs — navy (variation from homepage FAQ)
       ============================================================ -->
  <section class="section section--navy pricing-faq-section">
    <div class="container">
      <span class="section-kicker">Pricing FAQs</span>
      <h2 class="heading-xl section-title">Pricing questions.</h2>

      <div class="faq-list">
        <div class="faq-item content-card">
          <h3 class="heading-sm">What if my course needs to be longer than 20 minutes?</h3>
          <p>We can accommodate longer courses. We'll provide a quote based on the additional content length.</p>
        </div>

        <div class="faq-item content-card">
          <h3 class="heading-sm">Can I change tiers after we start?</h3>
          <p>Yes, if the scope changes we'll adjust pricing accordingly. We'll always discuss this with you first and get your approval before proceeding.</p>
        </div>

        <div class="faq-item content-card">
          <h3 class="heading-sm">What happens if I need revisions after the 2-week window?</h3>
          <p>We're happy to make updates — we'll provide a quote based on the changes needed. Most clients don't need this because we involve you throughout the development process.</p>
        </div>

        <div class="faq-item content-card">
          <h3 class="heading-sm">What if my team can't agree on the feedback?</h3>
          <p>That's why we require one final decision-maker. They have the authority to approve the course and resolve any internal disagreements, which keeps the project moving forward.</p>
        </div>

        <div class="faq-item content-card">
          <h3 class="heading-sm">Do you offer payment plans?</h3>
          <p>Due to the low cost of the courses we generally don't offer payment plans. We're always open to discussion if you need to negotiate different payment terms or splits due to your procurement policy.</p>
        </div>

        <div class="faq-item content-card">
          <h3 class="heading-sm">Can I see examples before I commit?</h3>
          <p>Absolutely. <a href="/contact" class="inline-link">Contact us</a> to see examples relevant to your training category. Something we find very useful is to mock up an example based on your branding so you can get a realistic idea of what the finished course will look like. This is especially helpful if you have to get internal approvals before hiring us.</p>
        </div>

        <div class="faq-item content-card">
          <h3 class="heading-sm">What if I'm still not sure which tier I need?</h3>
          <p>No problem. <a href="/contact" class="inline-link">Contact us</a> and we'll walk you through which option makes the most sense for your situation. We can usually determine this in a quick 15-minute conversation.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       8. Final CTA — lilac (balances homepage's navy close)
       ============================================================ -->
  <section class="section section--lilac pricing-cta-section">
    <div class="container">
      <div class="cta-content">
        <h2 class="display display-lg cta-title">
          Ready to<br />
          <span class="accent-blue">get started?</span>
        </h2>
        <p class="lede cta-text">
          Choose your tier or request a custom quote.
        </p>
        <div class="cta-buttons">
          <a href="/contact" class="btn btn--primary">Get a quote</a>
          <a href="/about" class="btn btn--secondary">Learn more about us</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ============================================================
     Page-specific styles only.
     All tokens, primitives, and shared components live in global.css.
     ============================================================ */

  /* ---- Hero ---- */
  .pricing-hero { padding-top: clamp(64px, 8vw, 100px); padding-bottom: clamp(56px, 7vw, 80px); }
  .hero-pill { margin-bottom: 24px; }
  .page-title { margin-bottom: 24px; max-width: 900px; }
  .page-subtitle { max-width: 640px; }

  /* ---- Pricing tier cards ---- */
  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    margin-bottom: 56px;
  }

  .pricing-card {
    background: var(--c-paper);
    border: 1px solid rgba(21, 25, 46, 0.08);
    border-radius: var(--r-lg);
    padding: 32px 28px;
    display: flex;
    flex-direction: column;
    position: relative;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }
  .pricing-card:hover {
    border-color: var(--c-ink);
  }

  .tier-badge {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--c-ink-muted);
    margin-bottom: 20px;
  }

  .tier-name {
    margin-bottom: 16px;
    font-size: 22px;
    line-height: 1.2;
  }

  .tier-price {
    display: flex;
    align-items: baseline;
    gap: 6px;
    margin-bottom: 14px;
  }
  .price-amount {
    font-family: var(--font-display);
    font-size: 40px;
    line-height: 1;
    color: var(--c-ink);
    letter-spacing: -0.02em;
  }
  .price-amount--custom {
    font-size: 24px;
  }
  .price-gst {
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--c-ink-muted);
  }

  .tier-description {
    font-size: 14px;
    line-height: 1.5;
    color: var(--c-ink-soft);
    margin-bottom: 20px;
  }

  /* The "Best for" block — distinct background per tier to differentiate
     them without ranking. Acts as the scan-target alongside price. */
  .best-for-block {
    border-radius: var(--r-md);
    padding: 18px 18px 20px;
    margin-bottom: 24px;
  }
  .best-for-block--lilac     { background: var(--c-lilac-tint); }
  .best-for-block--yellow    { background: var(--c-yellow-tint); }
  .best-for-block--turquoise { background: var(--c-turquoise-tint); }
  .best-for-block--neutral   { background: var(--c-paper-deep); }

  .best-for-label {
    display: block;
    color: var(--c-ink);
    opacity: 0.7;
    margin-bottom: 8px;
    font-size: 10px;
  }
  .best-for-text {
    font-family: var(--font-sans);
    font-size: 15px;
    font-weight: 600;
    line-height: 1.4;
    color: var(--c-ink);
    margin-bottom: 8px;
    letter-spacing: -0.01em;
  }
  .best-for-example {
    font-family: var(--font-sans);
    font-size: 13px;
    line-height: 1.5;
    color: var(--c-ink-soft);
    font-style: italic;
  }

  .tier-details { flex: 1; margin-bottom: 24px; }

  .tier-section-label {
    color: var(--c-ink-muted);
    margin-top: 18px;
    margin-bottom: 8px;
    font-size: 10px;
  }
  .tier-section-label:first-child { margin-top: 0; }

  .tier-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .tier-list li {
    font-size: 14px;
    line-height: 1.5;
    padding: 4px 0 4px 18px;
    position: relative;
    color: var(--c-ink-soft);
  }
  .tier-list li::before {
    content: "→";
    position: absolute;
    left: 0;
    color: var(--c-ink-muted);
    font-family: var(--font-mono);
  }

  .tier-cta {
    margin-top: auto;
    width: 100%;
  }

  .not-sure-cta {
    text-align: center;
    padding: 40px 0 0;
  }
  .not-sure-text {
    font-size: 17px;
    color: var(--c-ink-soft);
    margin-bottom: 16px;
  }

  /* ---- What's included ---- */
  .included-section .section-title { margin-bottom: 56px; max-width: 600px; }
  .included-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 40px;
  }
  .included-item { }
  .included-num {
    display: block;
    color: var(--c-ink-muted);
    margin-bottom: 14px;
  }
  .included-item h3 { margin-bottom: 10px; }
  .included-item p {
    color: var(--c-ink-soft);
    line-height: 1.6;
    font-size: 15px;
  }

  /* ---- Revisions explainer ---- */
  .revisions-explainer .section-title { margin-bottom: 64px; max-width: 800px; }

  .revisions-timeline {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-bottom: 56px;
  }
  .timeline-item {
    background: var(--c-paper-deep);
    border: 1px solid rgba(21, 25, 46, 0.06);
    border-radius: var(--r-lg);
    padding: 32px;
    position: relative;
  }
  .timeline-badge {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    background: var(--c-ink);
    color: var(--c-paper);
    padding: 6px 12px;
    border-radius: var(--r-pill);
    margin-bottom: 20px;
  }
  .timeline-item h4 { margin-bottom: 10px; }
  .timeline-item p {
    color: var(--c-ink-soft);
    line-height: 1.6;
    font-size: 15px;
  }

  .revisions-conditions {
    background: var(--c-yellow-tint);
    border-radius: var(--r-lg);
    padding: 32px;
    border: 1px solid var(--c-yellow-deep);
  }
  .conditions-label {
    color: var(--c-ink);
    margin-bottom: 16px;
  }
  .conditions-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .conditions-list li {
    padding: 8px 0 8px 24px;
    position: relative;
    color: var(--c-ink-soft);
    line-height: 1.55;
  }
  .conditions-list li::before {
    content: "✓";
    position: absolute;
    left: 0;
    color: var(--c-ink);
    font-weight: 600;
  }
  .conditions-list li strong { color: var(--c-ink); font-weight: 600; }

  /* ---- Add-ons (consolidated section) ---- */
  .addons-section .section-title { margin-bottom: 24px; max-width: 700px; }
  .addons-section .section-subtitle { margin-bottom: 56px; }
  .addons-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0;
  }
  .addon-item {
    padding: 24px 0;
    border-top: 1px solid rgba(21, 25, 46, 0.12);
  }
  /* Hide the top border on the first row's items so the grid reads
     as a unified table rather than two stacked groups */
  .addon-item:nth-child(-n+2) { border-top: 2px solid var(--c-ink); }
  /* Items past the first row keep the thin divider */
  .addon-item:nth-child(odd) { padding-right: 32px; }
  .addon-item:nth-child(even) { padding-left: 32px; border-left: 1px solid rgba(21, 25, 46, 0.08); }
