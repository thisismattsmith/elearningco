---
// src/pages/index.astro
import Layout from '../components/layout/Layout.astro';
---

<Layout 
  title="The eLearning Company | Custom eLearning in 3 Weeks"
  description="Professional eLearning courses delivered in 3 weeks with transparent pricing. No complexity, no drama. From $5,500 + GST."
>
  <!-- Hero Section -->
  <section class="hero-section">
    <div class="container">
      <div class="hero-content">
        <h1 class="hero-title">
          Custom eLearning in 3 Weeks.<br />
          <span class="gradient-text">Transparent Pricing.</span><br />
          Zero Drama.
        </h1>
        <p class="hero-subtitle">
          We build effective training courses for Australian organisations that don't have time, budget, or patience for traditional agency complexity.
        </p>
        <div class="hero-cta">
          <a href="/contact" class="btn btn-primary">Get a Quote in 24 Hours</a>
          <a href="/pricing" class="btn btn-secondary">View Pricing</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Value Props Section -->
  <section class="value-props-section">
    <div class="container">
      <div class="value-props-grid">
        <div class="value-prop-card">
          <div class="icon">⚡</div>
          <h3>Fixed Timeline</h3>
          <p>3 weeks from kickoff to delivery. No delays, no excuses, no surprises.</p>
        </div>
        <div class="value-prop-card">
          <div class="icon">💎</div>
          <h3>Transparent Pricing</h3>
          <p>From $5,500 + GST. All pricing is on our website. No hidden costs.</p>
        </div>
        <div class="value-prop-card">
          <div class="icon">✨</div>
          <h3>Zero Drama</h3>
          <p>Simple process, clear communication. We handle the complexity, you get results.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works Section -->
  <section class="how-it-works-section">
    <div class="container">
      <h2 class="section-title">How It Works</h2>
      <p class="section-subtitle">Three weeks. Three steps. That's it.</p>
      
      <div class="steps-grid">
        <div class="step">
          <div class="step-number">01</div>
          <h3>Content Kickoff</h3>
          <p>1-hour call to align on objectives, gather content, and understand your audience. We get everything we need to start building.</p>
        </div>
        <div class="step">
          <div class="step-number">02</div>
          <h3>We Build</h3>
          <p>First draft delivered in 1 week for your review. Professional design, effective learning structure, ready for feedback.</p>
        </div>
        <div class="step">
          <div class="step-number">03</div>
          <h3>Finalise & Deliver</h3>
          <p>Unlimited revisions in weeks 2-3. We don't release until you're happy. SCORM package ready for your LMS.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Unlimited Revisions Callout -->
  <section class="revisions-callout">
    <div class="container">
      <div class="callout-card">
        <h2>Unlimited Revisions. Unlimited Reviewers.</h2>
        <p>No more <i>"There's only one round of reviews"</i> or <i>"You can't add an extra reviewer"</i>. Get as many people involved as you need, make as many changes as you want during you two week review period.</p>
        <a href="/pricing" class="btn btn-accent">See How It Works</a>
      </div>
    </div>
  </section>

  <!-- Training Categories Section -->
  <section class="categories-section">
    <div class="container">
      <h2 class="section-title">We Specialise In</h2>
      <p class="section-subtitle">25 training categories with proven templates and expertise</p>
      
      <div class="categories-wrapper">
        <div class="category-group">
          <h4 class="category-group-title">Compliance & Risk</h4>
          <div class="category-tags">
            <a href="/training/workplace-health-safety" class="category-tag">Workplace Health & Safety</a>
            <a href="/training/sexual-harassment-prevention" class="category-tag">Sexual Harassment Prevention</a>
            <a href="/training/cyber-security-awareness" class="category-tag">Cyber Security Awareness</a>
            <a href="/training/privacy-data-protection" class="category-tag">Privacy & Data Protection</a>
            <a href="/training/anti-bribery-corruption" class="category-tag">Anti-Bribery & Corruption</a>
            <a href="/training/code-of-conduct" class="category-tag">Code of Conduct</a>
            <a href="/training/workplace-bullying-prevention" class="category-tag">Workplace Bullying Prevention</a>
          </div>
        </div>

        <div class="category-group">
          <h4 class="category-group-title">Onboarding & Culture</h4>
          <div class="category-tags">
            <a href="/training/new-employee-onboarding" class="category-tag">New Employee Onboarding</a>
            <a href="/training/company-induction" class="category-tag">Company Induction Programs</a>
            <a href="/training/diversity-inclusion" class="category-tag">Diversity & Inclusion</a>
            <a href="/training/mental-health-awareness" class="category-tag">Mental Health Awareness</a>
            <a href="/training/remote-work" class="category-tag">Remote Work Best Practices</a>
          </div>
        </div>

        <div class="category-group">
          <h4 class="category-group-title">Skills Development</h4>
          <div class="category-tags">
            <a href="/training/customer-service" class="category-tag">Customer Service Training</a>
            <a href="/training/sales-training" class="category-tag">Sales Training & Enablement</a>
            <a href="/training/leadership-development" class="category-tag">Leadership Development</a>
            <a href="/training/communication-skills" class="category-tag">Communication Skills</a>
            <a href="/training/time-management" class="category-tag">Time Management</a>
            <a href="/training/conflict-resolution" class="category-tag">Conflict Resolution</a>
            <a href="/training/feedback-performance" class="category-tag">Feedback & Performance</a>
          </div>
        </div>

        <div class="category-group">
          <h4 class="category-group-title">Operational Training</h4>
          <div class="category-tags">
            <a href="/training/product-training" class="category-tag">Product Training</a>
            <a href="/training/software-system" class="category-tag">Software/System Training</a>
            <a href="/training/process-procedure" class="category-tag">Process & Procedure</a>
            <a href="/training/quality-management" class="category-tag">Quality Management</a>
            <a href="/training/emergency-response" class="category-tag">Emergency Response</a>
            <a href="/training/change-management" class="category-tag">Change Management</a>
          </div>
        </div>
      </div>

      <div class="categories-cta">
        <a href="/pricing" class="btn btn-secondary">View All Categories & Pricing</a>
      </div>
    </div>
  </section>

  <!-- Social Proof Section (To be populated) -->
  <section class="social-proof-section">
    <div class="container">
      <h2 class="section-title">Trusted by Australian Organizations</h2>
      <p class="section-subtitle">From healthcare to finance, retail to construction</p>
      
      <div class="testimonial-placeholder">
        <p class="placeholder-text">Client testimonials and case studies coming soon. Currently building our first projects.</p>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="faq-section">
    <div class="container">
      <h2 class="section-title">Common Questions</h2>
      
      <div class="faq-grid">
        <div class="faq-item">
          <h3>How can you deliver in 3 weeks?</h3>
          <p>We've stripped out the unnecessary complexity that traditional agencies add - not the quality. You get effective learning design and professional visuals using modern templates. What you don't get is weeks of revision cycles and project management overhead. We've been doing this for 15+ years.</p>
        </div>

        <div class="faq-item">
          <h3>Why is your pricing lower than other agencies?</h3>
          <p>We operate lean. No account managers, no sales teams, no fancy offices, no unnecessary meetings. Traditional agencies charge $15-20k because they have expensive business models. We charge $5,500-$10,500 because we've eliminated the bloat while keeping the quality.</p>
        </div>

        <div class="faq-item">
          <h3>What if we need revisions?</h3>
          <p>Unlimited revisions during weeks 2-3 of development. Involve as many reviewers as you need. We don't release the course until you're completely happy with it. Most clients only need one round of revisions because we get it right the first time.</p>
        </div>

        <div class="faq-item">
          <h3>Do you have experience in our industry?</h3>
          <p>We've developed training across every industry. But here's what matters more: understanding learning design principles and translating your specific content into effective courses. You're the expert in your business; we're the experts in eLearning.</p>
        </div>
      </div>

      <div class="faq-cta">
        <p>More questions? <a href="/contact">Get in touch</a></p>
      </div>
    </div>
  </section>

  <!-- Final CTA Section -->
  <section class="final-cta-section">
    <div class="container">
      <div class="final-cta-card">
        <h2>Ready to Get Started?</h2>
        <p>Tell us about your training needs and we'll get back to you within 24 hours with a fixed-price quote.</p>
        <div class="cta-buttons">
          <a href="/contact" class="btn btn-primary">Get a Quote</a>
          <a href="/pricing" class="btn btn-secondary">View Pricing First</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Variables */
  :root {
    --bg-primary: #0a0a0f;
    --bg-secondary: #121218;
    --bg-tertiary: #1a1a24;
    --text-primary: #ffffff;
    --text-secondary: #a0a0b2;
    --accent-primary: #6366f1;
    --accent-secondary: #8b5cf6;
    --accent-gradient: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
    --border-color: #2a2a3a;
    --shadow-sm: 0 2px 8px rgba(0, 0, 0, 0.3);
    --shadow-md: 0 4px 16px rgba(0, 0, 0, 0.4);
    --shadow-lg: 0 8px 32px rgba(0, 0, 0, 0.5);
  }

  /* Global Styles */
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
    background: var(--bg-primary);
    color: var(--text-primary);
    line-height: 1.6;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* Hero Section */
  .hero-section {
    padding: 120px 0 80px;
    background: linear-gradient(180deg, var(--bg-primary) 0%, var(--bg-secondary) 100%);
    position: relative;
    overflow: hidden;
  }

  .hero-section::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -20%;
    width: 800px;
    height: 800px;
    background: radial-gradient(circle, rgba(99, 102, 241, 0.15) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 900px;
  }

  .hero-title {
    font-size: 3.5rem;
    font-weight: 800;
    line-height: 1.2;
    margin-bottom: 24px;
    letter-spacing: -0.02em;
  }

  .gradient-text {
    background: var(--accent-gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-subtitle {
    font-size: 1.25rem;
    color: var(--text-secondary);
    margin-bottom: 40px;
    max-width: 700px;
    line-height: 1.7;
  }

  .hero-cta {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  /* Buttons */
  .btn {
    display: inline-block;
    padding: 16px 32px;
    border-radius: 12px;
    font-weight: 600;
    font-size: 1rem;
    text-decoration: none;
    transition: all 0.3s ease;
    cursor: pointer;
    border: none;
  }

  .btn-primary {
    background: var(--accent-gradient);
    color: white;
    box-shadow: 0 4px 16px rgba(99, 102, 241, 0.4);
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 24px rgba(99, 102, 241, 0.5);
  }

  .btn-secondary {
    background: var(--bg-tertiary);
    color: var(--text-primary);
    border: 2px solid var(--border-color);
  }

  .btn-secondary:hover {
    border-color: var(--accent-primary);
    background: rgba(99, 102, 241, 0.1);
  }

  .btn-accent {
    background: white;
    color: var(--bg-primary);
    font-weight: 700;
  }

  .btn-accent:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 24px rgba(255, 255, 255, 0.3);
  }

  /* Value Props Section */
  .value-props-section {
    padding: 80px 0;
    background: var(--bg-secondary);
  }

  .value-props-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 32px;
  }

  .value-prop-card {
    background: var(--bg-tertiary);
    padding: 40px;
    border-radius: 16px;
    border: 1px solid var(--border-color);
    transition: all 0.3s ease;
  }

  .value-prop-card:hover {
    transform: translateY(-4px);
    border-color: var(--accent-primary);
    box-shadow: var(--shadow-md);
  }

  .value-prop-card .icon {
    font-size: 3rem;
    margin-bottom: 20px;
  }

  .value-prop-card h3 {
    font-size: 1.5rem;
    margin-bottom: 12px;
    font-weight: 700;
  }

  .value-prop-card p {
    color: var(--text-secondary);
    line-height: 1.7;
  }

  /* Section Styles */
  .section-title {
    font-size: 2.5rem;
    font-weight: 800;
    text-align: center;
    margin-bottom: 16px;
    letter-spacing: -0.02em;
  }

  .section-subtitle {
    text-align: center;
    font-size: 1.125rem;
    color: var(--text-secondary);
    margin-bottom: 60px;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  /* How It Works Section */
  .how-it-works-section {
    padding: 100px 0;
    background: var(--bg-primary);
  }

  .steps-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 48px;
  }

  .step {
    text-align: center;
  }

  .step-number {
    font-size: 3rem;
    font-weight: 800;
    background: var(--accent-gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 20px;
  }

  .step h3 {
    font-size: 1.5rem;
    margin-bottom: 16px;
    font-weight: 700;
  }

  .step p {
    color: var(--text-secondary);
    line-height: 1.7;
  }

  /* Revisions Callout */
  .revisions-callout {
    padding: 80px 0;
    background: var(--bg-secondary);
  }

  .callout-card {
    background: linear-gradient(135deg, rgba(99, 102, 241, 0.1) 0%, rgba(139, 92, 246, 0.1) 100%);
    border: 2px solid var(--accent-primary);
    border-radius: 20px;
    padding: 60px;
    text-align: center;
  }

  .callout-card h2 {
    font-size: 2.25rem;
    margin-bottom: 20px;
    font-weight: 800;
  }

  .callout-card p {
    font-size: 1.125rem;
    color: var(--text-secondary);
    margin-bottom: 32px;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.7;
  }

  /* Categories Section */
  .categories-section {
    padding: 100px 0;
    background: var(--bg-primary);
  }

  .categories-wrapper {
    display: grid;
    gap: 48px;
    margin-bottom: 48px;
  }

  .category-group {
    background: var(--bg-tertiary);
    padding: 40px;
    border-radius: 16px;
    border: 1px solid var(--border-color);
  }

  .category-group-title {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 20px;
    color: var(--accent-primary);
  }

  .category-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .category-tag {
    background: var(--bg-secondary);
    color: var(--text-primary);
    padding: 10px 20px;
    border-radius: 8px;
    text-decoration: none;
    font-size: 0.95rem;
    border: 1px solid var(--border-color);
    transition: all 0.2s ease;
  }

  .category-tag:hover {
    background: rgba(99, 102, 241, 0.1);
    border-color: var(--accent-primary);
    transform: translateY(-2px);
  }

  .categories-cta {
    text-align: center;
  }

  /* Social Proof Section */
  .social-proof-section {
    padding: 100px 0;
    background: var(--bg-secondary);
  }

  .testimonial-placeholder {
    background: var(--bg-tertiary);
    border: 2px dashed var(--border-color);
    border-radius: 16px;
    padding: 60px;
    text-align: center;
  }

  .placeholder-text {
    color: var(--text-secondary);
    font-size: 1.125rem;
  }

  /* FAQ Section */
  .faq-section {
    padding: 100px 0;
    background: var(--bg-primary);
  }

  .faq-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 32px;
    margin-bottom: 48px;
  }

  .faq-item {
    background: var(--bg-tertiary);
    padding: 32px;
    border-radius: 16px;
    border: 1px solid var(--border-color);
  }

  .faq-item h3 {
    font-size: 1.25rem;
    margin-bottom: 16px;
    font-weight: 700;
  }

  .faq-item p {
    color: var(--text-secondary);
    line-height: 1.7;
  }

  .faq-cta {
    text-align: center;
    font-size: 1.125rem;
  }

  .faq-cta a {
    color: var(--accent-primary);
    text-decoration: none;
    font-weight: 600;
  }

  .faq-cta a:hover {
    text-decoration: underline;
  }

  /* Final CTA Section */
  .final-cta-section {
    padding: 100px 0;
    background: var(--bg-secondary);
  }

  .final-cta-card {
    background: linear-gradient(135deg, rgba(99, 102, 241, 0.15) 0%, rgba(139, 92, 246, 0.15) 100%);
    border: 2px solid var(--accent-primary);
    border-radius: 20px;
    padding: 80px 40px;
    text-align: center;
  }

  .final-cta-card h2 {
    font-size: 2.5rem;
    margin-bottom: 20px;
    font-weight: 800;
  }

  .final-cta-card p {
    font-size: 1.25rem;
    color: var(--text-secondary);
    margin-bottom: 40px;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .cta-buttons {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* Responsive Design */
  @media (max-width: 768px) {
    .hero-title {
      font-size: 2.5rem;
    }

    .hero-subtitle {
      font-size: 1.125rem;
    }

    .section-title {
      font-size: 2rem;
    }

    .callout-card,
    .final-cta-card {
      padding: 40px 24px;
    }

    .value-props-grid,
    .steps-grid,
    .faq-grid {
      grid-template-columns: 1fr;
    }

    .hero-cta {
      flex-direction: column;
    }

    .btn {
      width: 100%;
      text-align: center;
    }
  }
</style>