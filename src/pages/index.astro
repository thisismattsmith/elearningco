---
// src/pages/index.astro
import Layout from '../components/layout/Layout.astro';
---

<Layout
  title="The eLearning Company | Custom eLearning in 3 Weeks"
  description="Professional eLearning courses delivered in 3 weeks with transparent pricing. No complexity, no drama. From $5,500 + GST."
>
  <!-- ============================================================
       1. Hero — lilac (hero & marketing moments)
       ============================================================ -->
  <section class="section section--lilac hero-section">
    <div class="container">
      <div class="hero-content">
        <span class="pill-meta hero-pill">Custom eLearning · Australia-wide</span>
        <h1 class="display display-xl hero-title">
          Custom eLearning<br />
          in 3 weeks.<br />
          <span class="accent-blue">Transparent pricing.</span><br />
          Zero drama.
        </h1>
        <p class="lede hero-subtitle">
          We build effective training courses for Australian organisations that
          don't have time, budget, or patience for traditional agency complexity.
        </p>
        <div class="hero-cta">
          <a href="/contact" class="btn btn--primary">Get a quote in 24 hours</a>
          <a href="/pricing" class="btn btn--secondary">View pricing</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       2. Value props — paper (default neutral)
       ============================================================ -->
  <section class="section section--paper value-props-section">
    <div class="container">
      <div class="value-props-grid">
        <div class="value-prop-card">
          <span class="meta value-prop-num">01</span>
          <h3 class="heading-md">Fixed timeline</h3>
          <p>3 weeks from kickoff to delivery. No delays, no excuses, no surprises.</p>
        </div>
        <div class="value-prop-card">
          <span class="meta value-prop-num">02</span>
          <h3 class="heading-md">Transparent pricing</h3>
          <p>From $5,500 + GST. All pricing is on our website. No hidden costs.</p>
        </div>
        <div class="value-prop-card">
          <span class="meta value-prop-num">03</span>
          <h3 class="heading-md">On time, every time</h3>
          <p>Simple process, clear communication. We handle the complexity, you get results.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       3. How it works — turquoise (process)
       ============================================================ -->
  <section class="section section--turquoise how-it-works-section">
    <div class="container">
      <span class="section-kicker">How it works</span>
      <h2 class="display display-lg section-title">
        Three weeks.<br />
        Three steps.<br />
        That's it.
      </h2>

      <div class="steps-grid">
        <div class="step">
          <div class="step-number">01</div>
          <h3 class="heading-md">We build</h3>
          <p>We design and develop the eLearning based on your requirements and input.</p>
        </div>
        <div class="step">
          <div class="step-number">02</div>
          <h3 class="heading-md">You review</h3>
          <p>You receive the complete first draft for review. Provide feedback via our review link with your whole team.</p>
        </div>
        <div class="step">
          <div class="step-number">03</div>
          <h3 class="heading-md">We deliver</h3>
          <p>We'll continue to implement your feedback and finalise the course. Then, at the end of the third week we'll deliver the SCORM package ready for your LMS.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       4. Revisions callout — yellow (pricing & value moments)
       ============================================================ -->
  <section class="section section--yellow revisions-callout">
    <div class="container">
      <div class="callout-content">
        <h2 class="display display-md callout-title">
          Unlimited revisions.<br />
          <span class="callout-mark"><span class="mark--turquoise">Unlimited reviewers.</span></span>
        </h2>
        <p class="lede callout-text">
          No more <em>"there's only one round of reviews"</em> or <em>"you can't add an extra reviewer"</em>. Get as many people involved as you need, make as many changes as you want during weeks 2 and 3 of development.
        </p>
        <a href="/pricing" class="btn btn--primary">See how it works</a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       5. Training categories — paper (default neutral)
       ============================================================ -->
  <section class="section section--paper categories-section">
    <div class="container">
      <span class="section-kicker">Training categories</span>
      <h2 class="heading-xl section-title">We've done it all.</h2>
      <p class="lede section-subtitle">
        We've created courses across every industry and just about every topic.
      </p>

      <div class="categories-wrapper">
        <div class="category-group">
          <h4 class="meta category-group-title">Compliance &amp; risk</h4>
          <div class="category-tags">
            <a href="/training/workplace-health-safety" class="category-tag">Workplace Health &amp; Safety</a>
            <a href="/training/sexual-harassment-prevention" class="category-tag">Sexual Harassment Prevention</a>
            <a href="/training/cyber-security-awareness" class="category-tag">Cyber Security Awareness</a>
            <a href="/training/privacy-data-protection" class="category-tag">Privacy &amp; Data Protection</a>
            <a href="/training/anti-bribery-corruption" class="category-tag">Anti-Bribery &amp; Corruption</a>
            <a href="/training/code-of-conduct" class="category-tag">Code of Conduct</a>
            <a href="/training/workplace-bullying-prevention" class="category-tag">Workplace Bullying Prevention</a>
          </div>
        </div>

        <div class="category-group">
          <h4 class="meta category-group-title">Onboarding &amp; culture</h4>
          <div class="category-tags">
            <a href="/training/new-employee-onboarding" class="category-tag">New Employee Onboarding</a>
            <a href="/training/company-induction" class="category-tag">Company Induction Programs</a>
            <a href="/training/diversity-inclusion" class="category-tag">Diversity &amp; Inclusion</a>
            <a href="/training/mental-health-awareness" class="category-tag">Mental Health Awareness</a>
            <a href="/training/remote-work" class="category-tag">Remote Work Best Practices</a>
          </div>
        </div>

        <div class="category-group">
          <h4 class="meta category-group-title">Skills development</h4>
          <div class="category-tags">
            <a href="/training/customer-service" class="category-tag">Customer Service Training</a>
            <a href="/training/sales-training" class="category-tag">Sales Training &amp; Enablement</a>
            <a href="/training/leadership-development" class="category-tag">Leadership Development</a>
            <a href="/training/communication-skills" class="category-tag">Communication Skills</a>
            <a href="/training/time-management" class="category-tag">Time Management</a>
            <a href="/training/conflict-resolution" class="category-tag">Conflict Resolution</a>
            <a href="/training/feedback-performance" class="category-tag">Feedback &amp; Performance</a>
          </div>
        </div>

        <div class="category-group">
          <h4 class="meta category-group-title">Operational &amp; technical</h4>
          <div class="category-tags">
            <a href="/training/product-training" class="category-tag">Product Training</a>
            <a href="/training/software-system" class="category-tag">Software/System Training</a>
            <a href="/training/process-procedure" class="category-tag">Process &amp; Procedure</a>
            <a href="/training/quality-management" class="category-tag">Quality Management</a>
            <a href="/training/emergency-response" class="category-tag">Emergency Response</a>
            <a href="/training/change-management" class="category-tag">Change Management</a>
          </div>
        </div>
      </div>

      <div class="categories-cta">
        <a href="/training" class="btn btn--secondary">View all categories</a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       6. Social proof — navy (proof)
       ============================================================ -->
  <section class="section section--navy social-proof-section">
    <div class="container">
      <span class="section-kicker">Social proof</span>
      <h2 class="display display-lg section-title">
        Trusted by Australian<br />
        organisations.
      </h2>
      <p class="lede section-subtitle">
        From healthcare to finance, retail to construction.
      </p>

      <div class="proof-cards">
        <div class="card">
          <div class="card-label">Industries served</div>
          <div class="card-value">Healthcare, finance, retail, construction &amp; more</div>
        </div>
        <div class="card">
          <div class="card-label">On-time delivery</div>
          <div class="card-value">3 weeks, every time</div>
        </div>
        <div class="card">
          <div class="card-label">Tooling</div>
          <div class="card-value">Articulate Rise &amp; Storyline</div>
        </div>
        <div class="card">
          <div class="card-label">Pricing</div>
          <div class="card-value">Fixed, published, no surprises</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       7. Final CTA — navy (proof / dark close)
       ============================================================ -->
  <section class="section section--navy final-cta-section">
    <div class="container">
      <div class="final-cta-content">
        <h2 class="display display-lg final-cta-title">
          Ready to<br />
          <span class="mark--lilac">get started?</span>
        </h2>
        <p class="lede final-cta-text">
          Tell us about your training needs and we'll get back to you within 24 hours with a fixed-price quote.
        </p>
        <div class="cta-buttons">
          <a href="/contact" class="btn btn--accent">Get a quote</a>
          <a href="/pricing" class="btn btn--secondary">View pricing first</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ============================================================
     Page-specific styles only.
     All tokens, primitives, and shared components live in global.css.
     ============================================================ */

  /* ---- Hero ---- */
  .hero-section { padding-top: clamp(64px, 10vw, 120px); padding-bottom: clamp(80px, 12vw, 140px); }
  .hero-content { max-width: 1000px; }
  .hero-pill { margin-bottom: 28px; }
  .hero-title { margin-bottom: 32px; }
  .hero-subtitle { margin-bottom: 40px; max-width: 580px; }
  .hero-cta { display: flex; gap: 12px; flex-wrap: wrap; }

  /* ---- Value props ---- */
  .value-props-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 48px;
  }
  .value-prop-card { }
  .value-prop-num {
    display: block;
    color: var(--c-ink-muted);
    margin-bottom: 16px;
  }
  .value-prop-card h3 { margin-bottom: 12px; }
  .value-prop-card p { color: var(--c-ink-soft); line-height: 1.6; }

  /* ---- How it works ---- */
  .how-it-works-section .section-title { margin-bottom: 64px; max-width: 720px; }
  .steps-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 48px;
  }
  .step { }
  .step-number {
    font-family: var(--font-display);
    font-size: 56px;
    line-height: 1;
    margin-bottom: 24px;
    color: var(--c-ink);
    letter-spacing: -0.02em;
  }
  .step h3 { margin-bottom: 12px; }
  .step p { color: var(--c-ink-soft); line-height: 1.6; }

  /* ---- Revisions callout ---- */
  .callout-content { max-width: 900px; }
  .callout-title { margin-bottom: 28px; }
  .callout-mark { display: inline-block; }
  .callout-text { margin-bottom: 32px; max-width: 700px; }
  .callout-text em { font-style: italic; }

  /* ---- Categories ---- */
  .categories-section .section-title { margin-bottom: 12px; }
  .categories-section .section-subtitle { margin-bottom: 64px; }
  .categories-wrapper {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
    margin-bottom: 48px;
  }
  .category-group {
    background: var(--c-paper-deep);
    border: 1px solid rgba(21, 25, 46, 0.06);
    border-radius: var(--r-lg);
    padding: 32px;
  }
  .category-group-title {
    color: var(--c-ink-muted);
    margin-bottom: 20px;
  }
  .category-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .category-tag {
    background: var(--c-paper);
    color: var(--c-ink);
    padding: 8px 14px;
    border-radius: var(--r-md);
    text-decoration: none;
    font-size: 14px;
    font-weight: 500;
    border: 1px solid rgba(21, 25, 46, 0.08);
    transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease;
  }
  .category-tag:hover {
    background: var(--c-ink);
    color: var(--c-paper);
    border-color: var(--c-ink);
  }
  .categories-cta { text-align: center; }

  /* ---- Social proof ---- */
  .social-proof-section .section-title { margin-bottom: 24px; }
  .social-proof-section .section-subtitle { margin-bottom: 56px; }
  .proof-cards {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }

  /* ---- FAQ ---- */
  .faq-section .section-title { margin-bottom: 56px; }
  .faq-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    margin-bottom: 48px;
  }
  .faq-item h3 { margin-bottom: 14px; }
  .faq-item p { color: var(--c-ink-soft); line-height: 1.7; }
  .faq-cta { text-align: center; font-size: 16px; }
  .faq-cta-link {
    color: var(--c-blue);
    text-decoration: none;
    font-weight: 500;
    border-bottom: 1px solid currentColor;
  }
  .faq-cta-link:hover { color: var(--c-ink); }

  /* ---- Final CTA ---- */
  .final-cta-content { max-width: 800px; }
  .final-cta-title { margin-bottom: 28px; }
  .final-cta-text { margin-bottom: 40px; max-width: 600px; }
  .cta-buttons {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  /* ---- Responsive ---- */
  @media (max-width: 900px) {
    .value-props-grid,
    .steps-grid,
    .categories-wrapper,
    .faq-grid {
      grid-template-columns: 1fr;
    }
    .proof-cards { grid-template-columns: 1fr 1fr; }
  }

  @media (max-width: 600px) {
    .proof-cards { grid-template-columns: 1fr; }
    .hero-cta .btn,
    .cta-buttons .btn { width: 100%; }
  }
</style>
